---
/**
 * Base HTML layout shell.
 * Provides <head> with meta tags, OG/Twitter cards, and analytics.
 * Use named slots for header/footer customization.
 */
import '../styles/tailwind.css'
import SeoHead from '@/components/shared/SeoHead.astro'
import { useTranslations, buildCanonicalMeta } from '@/utils'

interface Props {
  title: string
  titleSuffix?: string
  description?: string
  theme?: 'light' | 'dark'
  ogType?: string
  ogImageUrl?: string
  canonicalURL?: string
  bodyClass?: string
  bodyStyle?: string
  datePublished?: string
}

const { routeLocale, currentSlug, currentBasePath } = Astro.locals
const t = useTranslations(routeLocale)
const canonicalMeta = buildCanonicalMeta(
  Astro.site!,
  routeLocale,
  currentSlug,
  currentBasePath
)
const {
  title,
  titleSuffix = t('site.title.foundation'),
  description = t('site.description'),
  theme = 'light',
  ogType = 'website',
  ogImageUrl = new URL('/img/og-foundation.png', Astro.site).href,
  canonicalURL = canonicalMeta.canonical,
  bodyClass = '',
  bodyStyle = '',
  datePublished
} = Astro.props
---

<!doctype html>
<html lang={routeLocale} data-theme={theme}>
  <head>
    <link
      rel="preload"
      href="/fonts/poppins-regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/poppins-medium.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/poppins-semibold.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <SeoHead
      title={title}
      description={description}
      siteName={titleSuffix}
      ogType={ogType}
      ogImageUrl={ogImageUrl}
      canonicalURL={canonicalURL}
      hreflang={canonicalMeta.hreflang}
      xDefault={canonicalMeta.xDefault}
      datePublished={datePublished}
    />
    <slot name="head" />
    <script
      defer
      src="https://ilf-site-analytics.netlify.app/script.js"
      data-website-id="60547518-fd38-4f64-abf3-d03688e321b9"></script>
  </head>

  <body class={bodyClass} style={bodyStyle}>
    <slot name="header" />
    <slot />
    <slot name="footer" />
  </body>
</html>
