---
/**
 * Base HTML layout shell.
 * Provides <head> with meta tags, OG/Twitter cards, and analytics.
 * Use named slots for header/footer customization.
 */
import '../styles/tailwind.css'
import SeoHead from '@/components/SeoHead.astro'
import { useTranslations, buildCanonicalMeta } from '@/utils'

interface Props {
  title: string
  titleSuffix?: string
  description?: string
  theme?: 'light' | 'dark'
  ogType?: string
  ogImageUrl?: string
  canonicalURL?: string
  bodyClass?: string
  bodyStyle?: string
  datePublished?: string
}

const { routeLocale, currentSlug, currentBasePath } = Astro.locals
const t = useTranslations(routeLocale)
const canonicalMeta = buildCanonicalMeta(Astro.site!, routeLocale, currentSlug, currentBasePath)
const {
  title,
  titleSuffix = t('site.title'),
  description = t('site.description'),
  theme = 'light',
  ogType = 'website',
  ogImageUrl = new URL('/img/blog/og-ilf.png', Astro.site).href,
  canonicalURL = canonicalMeta.canonical,
  bodyClass = '',
  bodyStyle = '',
  datePublished
} = Astro.props
---

<!doctype html>
<html lang={routeLocale} data-theme={theme}>
  <head>
    <SeoHead
      title={title}
      description={description}
      siteName={titleSuffix}
      ogType={ogType}
      ogImageUrl={ogImageUrl}
      canonicalURL={canonicalURL}
      hreflang={canonicalMeta.hreflang}
      xDefault={canonicalMeta.xDefault}
      datePublished={datePublished}
    />
    <slot name="head" />
    <script
      defer
      src="https://uwa.interledger.org/script.js"
      data-website-id="50d81dd1-bd02-4f82-8a55-34a09ccbbbd9"
      data-domains="interledger.org"></script>
  </head>

  <body class={bodyClass} style={bodyStyle}>
    <slot name="header" />
    <slot />
    <slot name="footer" />
  </body>
</html>
