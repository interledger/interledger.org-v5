---
/**
 * Summit site layout.
 * Extends BaseLayout with Summit header/footer and dark theme.
 */
import BaseLayout from './BaseLayout.astro'
import SummitFooter from '../components/pages/SummitFooter.astro'
import SummitHeader from '../components/pages/SummitHeader.astro'
import type { Locale } from '@/utils/translationMap'

interface Props {
  title: string
  description?: string
  gradient?: string
  ogImageUrl?: string
  canonicalURL?: string
  currentLocale?: Locale
  currentSlug?: string
  currentBasePath?: string
}

const {
  title,
  description,
  gradient = 'option1',
  ogImageUrl,
  canonicalURL,
  currentLocale = Astro.url.pathname.startsWith('/es') ? 'es' : 'en',
  currentSlug = '',
  currentBasePath = '/summit'
} = Astro.props
---

<BaseLayout
  title={title}
  titleSuffix="Interledger Summit"
  description={description}
  ogImageUrl={ogImageUrl ?? '/img/og-summit.png'}
  canonicalURL={canonicalURL}
  theme="dark"
  bodyClass="flex min-h-full min-w-[360px] flex-col overflow-x-hidden bg-fixed bg-no-repeat font-titillium text-step-0 text-white"
  bodyStyle={`--gradient:var(--${gradient}); background-image: var(--gradient);`}
>
  <SummitHeader
    slot="header"
    currentLocale={currentLocale}
    currentSlug={currentSlug}
    currentBasePath={currentBasePath}
  />
  <div
    class="flex-1 text-step-0 [&>section]:w-full [&>section]:py-space-m [&_h1]:text-step-4 [&_h2]:text-step-2 [&_h3]:text-step-1 [&_h4]:text-step-0 [&_a]:text-current [&_a]:transition-colors [&_a]:duration-slow [&_a:hover]:text-[hsla(26,100%,76%,1)]"
  >
    <slot />
  </div>
  <SummitFooter slot="footer" />
</BaseLayout>
