---
/**
 * Foundation site layout.
 * Extends BaseLayout with Foundation header/footer.
 */
import BaseLayout from './BaseLayout.astro'
import FoundationFooter from '../components/pages/FoundationFooter.astro'
import FoundationHeader from '../components/pages/FoundationHeader.astro'
import type { Locale } from '@/utils/translationMap'

interface Props {
  title: string
  description?: string
  ogType?: string
  ogImageUrl?: string
  canonicalURL?: string
  datePublished?: string
  currentLocale?: Locale
  currentSlug?: string
  currentBasePath?: string
}

const {
  title,
  description,
  ogType,
  ogImageUrl,
  canonicalURL,
  datePublished,
  currentLocale = Astro.url.pathname.startsWith('/es') ? 'es' : 'en',
  currentSlug = '',
  currentBasePath = ''
} = Astro.props
---

<BaseLayout
  title={title}
  description={description}
  ogType={ogType}
  ogImageUrl={ogImageUrl}
  canonicalURL={canonicalURL}
  datePublished={datePublished}
  bodyClass="flex flex-col min-h-full min-w-[360px] font-titillium overflow-x-clip before:content-[''] before:fixed before:inset-0 before:-z-10 before:bg-[url('/img/bg-swirl.svg')] before:bg-repeat before:bg-[length:150%] before:blur-[150px] before:opacity-25 before:transform-gpu max-[430px]:before:hidden"
>
  <Fragment slot="head">
    <slot name="head" />
  </Fragment>
  <FoundationHeader
    slot="header"
    currentLocale={currentLocale}
    currentSlug={currentSlug}
    currentBasePath={currentBasePath}
  />
  <slot />
  <FoundationFooter slot="footer" />
</BaseLayout>
