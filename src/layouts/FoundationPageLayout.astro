---
/**
 * Foundation site layout.
 * Extends BaseLayout with Foundation header/footer.
 */
import BaseLayout from './BaseLayout.astro'
import FoundationFooter from '@/components/layout/FoundationFooter.astro'
import FoundationHeader from '@/components/layout/FoundationHeader.astro'

interface Props {
  title: string
  description?: string
  ogType?: string
  ogImageUrl?: string
  canonicalURL?: string
  datePublished?: string
  headerTheme?: 'light' | 'dark'
}

const {
  title,
  description,
  ogType,
  ogImageUrl,
  canonicalURL,
  datePublished,
  headerTheme = 'dark'
} = Astro.props
---

<BaseLayout
  title={title}
  description={description}
  ogType={ogType}
  ogImageUrl={ogImageUrl}
  canonicalURL={canonicalURL}
  datePublished={datePublished}
  theme={headerTheme}
  bodyClass="flex flex-col min-h-full min-w-[360px] overflow-x-clip before:content-[''] before:fixed before:inset-0 before:-z-10 before:bg-[url('/img/bg-swirl.svg')] before:bg-repeat before:bg-[length:150%] before:blur-[150px] before:opacity-25 before:transform-gpu max-[430px]:before:hidden"
>
  <Fragment slot="head">
    <slot name="head" />
  </Fragment>
  <FoundationHeader slot="header" theme={headerTheme} />
  <slot />
  <FoundationFooter slot="footer" />
</BaseLayout>
