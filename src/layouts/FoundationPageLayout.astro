---
/**
 * Foundation site layout.
 * Extends BaseLayout with Foundation header/footer.
 */
import BaseLayout from './BaseLayout.astro'
import FoundationFooter from '@/components/layout/FoundationFooter.astro'
import FoundationHeader from '@/components/layout/FoundationHeader.astro'

interface Props {
  title: string
  description?: string
  ogType?: string
  ogImageUrl?: string
  canonicalURL?: string
  datePublished?: string
  headerTheme?: 'light' | 'dark'
  pageTheme?: 'light' | 'dark'
  bodyClass?: string
}

const defaultBodyClass =
  'flex flex-col min-h-full min-w-[360px] overflow-x-clip'

const {
  title,
  description,
  ogType,
  ogImageUrl,
  canonicalURL,
  datePublished,
  headerTheme = 'light',
  pageTheme = 'light',
  bodyClass = defaultBodyClass
} = Astro.props
---

<BaseLayout
  title={title}
  description={description}
  ogType={ogType}
  ogImageUrl={ogImageUrl}
  canonicalURL={canonicalURL}
  datePublished={datePublished}
  theme={pageTheme}
  bodyClass={bodyClass}
>
  <Fragment slot="head">
    <slot name="head" />
  </Fragment>
  <FoundationHeader slot="header" theme={headerTheme} />
  <slot />
  <FoundationFooter slot="footer" />
</BaseLayout>
