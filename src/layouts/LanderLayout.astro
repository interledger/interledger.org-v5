---
import Footer from '../components/pages/Footer.astro'
import LanderHeader from '../components/pages/LanderHeader.astro'
import '../styles/tailwind.css'
import { useTranslations } from '@/utils/main/i18'

interface Props {
  title: string
  description?: string
  gradient?: string
}

const { routeLocale } = Astro.locals
const t = useTranslations(routeLocale)
const { title, description, gradient = 'option1' } = Astro.props
---

<!doctype html>
<html lang={routeLocale} data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="author" content="Interledger Foundation" />
    <meta
      name="description"
      content={description ? description : t('site.description')}
    />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>
      {title ? `${title} | ${t('site.title')}` : t('site.title')}
    </title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script
      defer
      src="https://ilf-site-analytics.netlify.app/script.js"
      data-website-id="60547518-fd38-4f64-abf3-d03688e321b9"></script>
  </head>

  <body
    class="flex min-h-full min-w-[360px] flex-col overflow-x-hidden bg-fixed bg-no-repeat font-titillium text-step-0 text-white"
    style={`--gradient:var(--${gradient}); background-image: var(--gradient);`}
  >
    <LanderHeader />
    <div
      data-prose-summit
      class="flex-1 text-step-0 [&>section]:w-full [&>section]:py-space-m"
    >
      <slot />
    </div>
    <Footer />
  </body>
</html>
