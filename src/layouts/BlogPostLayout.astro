---
/**
 * Single-column layout for the blog post template.
 *
 * Styling is intentionally minimal — the visual design lands in INTORG-768.
 * This layout owns the article chrome (feature image, title, dates, byline);
 * the page component supplies body content, author bios, categories and the
 * related-articles section via slots.
 */
import FoundationPageLayout from './FoundationPageLayout.astro'
import { useTranslations } from '@/utils'
import type { FoundationBlogFrontmatterType } from '@/schemas/content.ts'

interface Props {
  frontmatter: FoundationBlogFrontmatterType
  canonicalURL?: string
}

const { frontmatter, canonicalURL } = Astro.props
const { routeLocale } = Astro.locals
const t = useTranslations(routeLocale)

const site = Astro.site!
const ogImageUrl = new URL('/img/blog/og-ilf.png', site).href

// Desktop feature image: 720 x 428. Mobile: 358 x 240.
const FEATURE_DESKTOP = { width: 720, height: 428 }
const FEATURE_MOBILE = { width: 358, height: 240 }

const publishedDate = new Date(frontmatter.date)
const publishedIso = publishedDate.toISOString().slice(0, 10)
const publishedLong = publishedDate.toDateString().substring(4)

const updatedDate = frontmatter.lastUpdated
  ? new Date(frontmatter.lastUpdated)
  : null
const updatedIso = updatedDate?.toISOString().slice(0, 10)
const updatedLong = updatedDate?.toDateString().substring(4)

const authors = frontmatter.articleBios ?? []
---

<FoundationPageLayout
  title={frontmatter.title}
  description={frontmatter.description}
  ogType="article"
  ogImageUrl={ogImageUrl}
  canonicalURL={canonicalURL}
  datePublished={publishedDate.toISOString()}
>
  <main class="flex flex-col pt-space-m pb-space-xl">
    <slot name="disclaimer" />
    <article
      data-prose-blog
      itemscope
      itemtype="http://schema.org/Article"
      class="mx-auto w-full max-w-180 px-[5%]"
    >
      {
        frontmatter.featureImage && (
          <picture>
            {frontmatter.featureImageMobile && (
              <source
                media="(max-width: 767px)"
                srcset={frontmatter.featureImageMobile}
                width={FEATURE_MOBILE.width}
                height={FEATURE_MOBILE.height}
              />
            )}
            <img
              src={frontmatter.featureImage}
              alt={frontmatter.featureImageAlt ?? ''}
              width={FEATURE_DESKTOP.width}
              height={FEATURE_DESKTOP.height}
              loading="eager"
              fetchpriority="high"
              decoding="async"
              class="mb-space-xs w-full h-auto"
            />
          </picture>
        )
      }
      <h1
        itemprop="headline"
        class="text-primary font-bold text-step-4 leading-tight mb-space-2xs"
      >
        {frontmatter.title}
      </h1>
      <time
        datetime={publishedIso}
        itemprop="datePublished"
        class="block mb-space-3xs text-step--1"
      >
        {publishedLong}
      </time>
      {
        updatedDate && (
          <time
            datetime={updatedIso}
            itemprop="dateModified"
            class="block mb-space-3xs text-step--1"
          >
            {t('blog.updated')} {updatedLong}
          </time>
        )
      }
      {
        authors.length > 0 && (
          <address class="text-step-0 mb-space-s not-italic">
            {t('blog.written_by')}{' '}
            {authors.map((bio, index) => (
              <Fragment>
                {index > 0 && ', '}
                {bio.link ? (
                  <a href={bio.link} rel="author">
                    {bio.author}
                  </a>
                ) : (
                  <span>{bio.author}</span>
                )}
              </Fragment>
            ))}
          </address>
        )
      }
      <slot />
    </article>
  </main>
</FoundationPageLayout>
