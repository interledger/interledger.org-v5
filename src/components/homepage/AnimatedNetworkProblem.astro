---
/**
 * Single source for “The Problem We're Solving” copy and media on the homepage.
 * Rendered once inside AnimatedNetwork.astro (mobile + tablet+ layouts via CSS).
 */
import TextMediaSection from '@/components/shared/TextMediaSection.astro'
import VideoEmbed from '@/components/shared/VideoEmbed.astro'
import { twMerge, useTranslations } from '@/utils'

/** YouTube embed for the homepage “problem we're solving” block. */
const PROBLEM_VIDEO_URL = 'https://www.youtube.com/watch?v=oJNFsO3k7LM'

/** Stable id for section `aria-labelledby` in AnimatedNetwork.astro. */
export const ANIMATED_NETWORK_PROBLEM_HEADING_ID =
  'animated-network-problem-heading'

interface Props {
  class?: string
}

const { class: className } = Astro.props
const t = useTranslations(Astro.locals.routeLocale)
---

<TextMediaSection
  mediaSide="right"
  theme="dark"
  ariaLabel={t('animatedNetwork.problem.heading')}
  class={twMerge(
    'network-problem-section relative z-1 min-h-min justify-start',
    'bg-royal-purple-100 px-lg pt-5xl pb-3xl',
    'tablet:min-h-screen tablet:justify-center tablet:bg-transparent tablet:px-3xl-tight tablet:py-5xl',
    className
  )}
  data-nav-dark
  data-umami-component="animated-network-problem"
  data-section="home-problem"
>
  <h2 slot="heading" id={ANIMATED_NETWORK_PROBLEM_HEADING_ID}>
    {t('animatedNetwork.problem.heading')}
  </h2>
  <p>{t('animatedNetwork.problem.body_1')}</p>
  <p>{t('animatedNetwork.problem.body_2')}</p>
  <div
    slot="media"
    class="mx-auto aspect-video w-full max-w-full overflow-hidden rounded-3xl bg-black tablet:w-[80%] desktop:mx-0 desktop:w-[512px]"
  >
    <VideoEmbed
      url={PROBLEM_VIDEO_URL}
      title={t('animatedNetwork.problem.video_title')}
      poster="/img/home/video-problem-poster.jpg"
    />
  </div>
</TextMediaSection>
