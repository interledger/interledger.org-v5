---
/**
 * Decorative network graphic that rotates as it scrolls through the viewport,
 * with a purple disc that grows from a centre dot to a viewport-sized backdrop
 * over the same scroll. Both effects share the section's view-timeline so they
 * stay in lockstep. Driven by the scroll-driven animations API where supported;
 * Firefox and other browsers without `animation-timeline: view()` use the JS
 * fallback in src/scripts/animated-network.ts. Reduced motion hides the art on
 * tablet+ and shows the problem block in-flow with a solid purple background.
 *
 * Below 810px (tablet:): problem copy in-flow; network SVG is the HomepageHero background.
 * From 810px: scroll animation, circle, and problem block anchored to the art.
 *
 * Problem copy (heading, body, video) lives only in AnimatedNetworkProblem.astro — one
 * instance in the tree, repositioned via responsive classes (not duplicated markup).
 */
import AnimatedNetworkProblem, {
  ANIMATED_NETWORK_PROBLEM_HEADING_ID
} from '@/components/homepage/AnimatedNetworkProblem.astro'
---

<section
  data-component="AnimatedNetwork"
  data-umami-component="animated-network"
  aria-labelledby={ANIMATED_NETWORK_PROBLEM_HEADING_ID}
  class="relative isolate z-0 flex flex-col bg-neutral-150"
>
  <div class="network-stage relative flex flex-col">
    <figure
      class="network-art pointer-events-none hidden tablet:block"
      aria-hidden="true"
    >
      <img
        src="/img/homepage/hero-animated-network.svg"
        alt=""
        width="1920"
        height="3186"
        loading="lazy"
        decoding="async"
        class="network-svg block h-auto w-full max-w-none opacity-50"
      />
      <div class="circle-anchor" aria-hidden="true">
        <div class="growing-circle"></div>
      </div>
    </figure>

    <div class="network-problem relative z-3">
      <AnimatedNetworkProblem class="relative z-3" />
    </div>
  </div>
</section>

<style>
  [data-component='AnimatedNetwork'] {
    view-timeline: --network-track block;
    --network-hero-overlap: 10vh;
    /* Fraction from art top where problem copy begins (tracks SVG hub ~52%). */
    --network-problem-start: 0.78;
    --network-svg-aspect: calc(3186 / 1920);
    /* Pull circle anchor up from the SVG hub (52% of art height). */
    --network-circle-y-nudge: 2vh;
    --network-circle-x-nudge: 0.75vw;
    /* Extra top room for scale(1.25) + rotation bleeding into HomepageHero. */
    --network-clip-top: calc(var(--network-hero-overlap) + 22vh);
    --network-problem-padding-bottom: clamp(12rem, 7.5rem + 8vw, 16rem);
    /* Negative top inset lets transformed SVG paint above this section's top edge. */
    clip-path: inset(calc(-1 * var(--network-clip-top)) 0 0 0);
  }

  @media (max-width: 809px) {
    [data-component='AnimatedNetwork'] {
      clip-path: none;
    }

    [data-component='AnimatedNetwork'] .network-problem-section > div {
      gap: var(--spacing-xl);
    }

    [data-component='AnimatedNetwork'] .network-problem-section {
      padding-bottom: var(--network-problem-padding-bottom);
    }
  }

  @media (min-width: 1024px) {
    [data-component='AnimatedNetwork'] {
      --network-hero-overlap: 20vh;
    }
  }

  @media (min-width: 810px) {
    [data-component='AnimatedNetwork'] .network-stage {
      container-type: inline-size;
      overflow: visible;
    }
  }

  [data-component='AnimatedNetwork'] .network-art {
    position: relative;
    z-index: 1;
    flex-shrink: 0;
    margin-top: calc(-1 * var(--network-hero-overlap));
    width: 100%;
    /* Must stay visible so rotate/scale paint can bleed into HomepageHero below tablet. */
    overflow: visible;
  }

  /*
   * In document flow (reserves height, no overlap with next section). Pull-up is
   * a fraction of art height via container query so it tracks width reflow.
   */
  @media (min-width: 810px) {
    [data-component='AnimatedNetwork'] .network-problem {
      flex-shrink: 0;
      width: 100%;
      margin-top: calc(
        (var(--network-problem-start) - 1) * 100cqi * var(--network-svg-aspect)
      );
    }

    [data-component='AnimatedNetwork'] .network-problem-section {
      padding-bottom: var(--network-problem-padding-bottom);
    }
  }

  @supports not (width: 100cqi) {
    @media (min-width: 810px) {
      [data-component='AnimatedNetwork'] .network-problem {
        margin-top: -30vh;
      }
    }
  }

  @media (min-width: 810px) {
    [data-component='AnimatedNetwork'] .network-svg:not(.network-svg--static) {
      transform-origin: 50% 52%; /* registration mark in the SVG (960/1920, 1648/3186) */
      /* 1ms duration: scroll-driven pattern — timeline controls progress, not duration. */
      animation: network-rotate 1ms linear both;
      animation-timeline: --network-track;
      animation-range: entry 0% exit 100%;
    }

    [data-component='AnimatedNetwork'].network--compositing
      .network-svg:not(.network-svg--static),
    [data-component='AnimatedNetwork'].network--compositing .growing-circle {
      will-change: transform;
    }
  }

  /* Hub at SVG registration point (50% / 52%) — nudge adjusts anchor from there. */
  [data-component='AnimatedNetwork'] .circle-anchor {
    display: none;
    position: absolute;
    left: calc(50% + var(--network-circle-x-nudge));
    z-index: 2;
    transform: translate(-50%, -50%);
    pointer-events: none;
  }

  @media (min-width: 810px) {
    [data-component='AnimatedNetwork'] .circle-anchor {
      display: block;
      /* % is art height; nudge subtracts viewport height to move hub up. */
      top: calc(52% - var(--network-circle-y-nudge));
    }

    /* Grows via transform scale (not width) to limit compositor layer size on low-end devices. */
    [data-component='AnimatedNetwork'] .growing-circle {
      --network-circle-size: 4vw;
      /* ~80× covers viewport from hub; 500× inflated document scroll height. */
      --network-circle-max-scale: 80;
      width: var(--network-circle-size);
      aspect-ratio: 1;
      flex: none;
      border-radius: 50%;
      background-color: var(--color-royal-purple-100);
      opacity: 0;
      transform: scale(1);
      transform-origin: center center;
      /* 1ms duration: scroll-driven pattern — timeline controls progress, not duration. */
      animation: growing-circle-grow 1ms linear forwards;
      animation-timeline: --network-track;
      animation-range: cover 35% cover 91%;
    }
  }

  [data-component='AnimatedNetwork'].network--js-fallback
    .network-svg:not(.network-svg--static),
  [data-component='AnimatedNetwork'].network--js-fallback .growing-circle {
    animation: none;
  }

  @keyframes network-rotate {
    from {
      transform: rotate(-15deg) scale(1.25);
    }
    to {
      transform: rotate(65deg) scale(1.25);
    }
  }

  @keyframes growing-circle-grow {
    from {
      transform: scale(1);
      opacity: 1;
    }
    to {
      transform: scale(var(--network-circle-max-scale));
      opacity: 1;
    }
  }

  @media (prefers-reduced-motion: reduce) and (min-width: 810px) {
    [data-component='AnimatedNetwork'] {
      clip-path: none;
    }

    [data-component='AnimatedNetwork'] .network-art {
      display: none;
    }

    [data-component='AnimatedNetwork'] .network-problem {
      margin-top: 0;
    }

    [data-component='AnimatedNetwork'] .network-problem-section {
      background-color: var(--color-royal-purple-100);
    }
  }
</style>

<script>
  import '@/scripts/animated-network'
</script>
