---
/**
 * Decorative network graphic that rotates as it scrolls through the viewport,
 * with a purple disc that grows from a centre dot to a viewport-sized backdrop
 * over the same scroll. Both effects share the section's view-timeline so they
 * stay in lockstep. Driven entirely by the scroll-driven animations API — no
 * JS, no library. Browsers without support (older Safari) fall back to the
 * reduced-motion end state.
 */
---

<section
  data-component="AnimatedNetwork"
  class="relative isolate z-0 hidden flow-root bg-neutral-150 md:block"
  aria-hidden="true"
>
  <div class="-mt-[10vh] lg:-mt-[20vh]">
    <img
      src="/img/homepage/hero-animated-network.svg"
      alt=""
      width="1920"
      height="3186"
      loading="lazy"
      decoding="async"
      class="network-svg block w-full max-w-none opacity-50"
    />
  </div>
  <div class="circle-overlay">
    <div class="circle-pin">
      <div class="growing-circle"></div>
    </div>
  </div>
</section>

<style>
  [data-component='AnimatedNetwork'] {
    view-timeline-name: --network-track;
  }

  [data-component='AnimatedNetwork'] .network-svg {
    transform-origin: 50% 52%; /* registration mark in the SVG (960/1920, 1648/3186) */
    will-change: transform;
    animation: network-rotate linear both;
    animation-timeline: --network-track;
    animation-range: entry 0% exit 100%;
  }

  [data-component='AnimatedNetwork'] .circle-overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  [data-component='AnimatedNetwork'] .circle-pin {
    position: sticky;
    top: 0;
    display: flex;
    height: 100vh;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  [data-component='AnimatedNetwork'] .growing-circle {
    width: 4vw;
    aspect-ratio: 1;
    flex: none;
    border-radius: 50%;
    background-color: #48156e;
    opacity: 0;
    animation: growing-circle-grow linear forwards;
    animation-timeline: --network-track;
    animation-range: cover 50% cover 100%;
    will-change: width;
  }

  @keyframes network-rotate {
    from {
      transform: rotate(-15deg) scale(1.25);
    }
    to {
      transform: rotate(65deg) scale(1.25);
    }
  }

  @keyframes growing-circle-grow {
    from {
      width: 4vw;
      opacity: 1;
    }
    to {
      width: 1500vmax;
      opacity: 1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    [data-component='AnimatedNetwork'] .network-svg {
      animation: none;
      transform: rotate(20deg) scale(1.25);
    }

    [data-component='AnimatedNetwork'] .growing-circle {
      animation: none;
      width: 1500vmax;
    }
  }
</style>
