---
import { generateSlug, type Locale } from '@/utils'
import type { FaqSectionType } from '@/schemas/content'
import Icon from '@/components/shared/Icon.astro'
import FaqSectionsNav from '@/components/faq/FaqSectionsNav.astro'

interface Props {
  sections: FaqSectionType[]
  uiLocale: Locale
}

const { sections, uiLocale } = Astro.props

/** Derives a unique anchor id per section from its heading (never authored). */
function withIds(rawSections: FaqSectionType[]) {
  const seen = new Map<string, number>()
  return rawSections.map((section) => {
    const base = generateSlug(section.heading) || 'section'
    const count = seen.get(base) ?? 0
    seen.set(base, count + 1)
    const id = count === 0 ? base : `${base}-${count + 1}`
    return { ...section, id }
  })
}

const sectionsWithIds = withIds(sections)
---

<div class="flex flex-col gap-xl desktop:flex-row desktop:gap-5xl">
  <div class="hidden desktop:block desktop:w-2/5 desktop:shrink-0">
    <FaqSectionsNav
      sections={sectionsWithIds.map(({ id, heading }) => ({ id, heading }))}
      uiLocale={uiLocale}
    />
  </div>

  <div
    data-faq-mobile-sections
    class="flex flex-col gap-3xl desktop:w-3/5 desktop:gap-3xl"
  >
    {
      sectionsWithIds.map((section) => (
        <details
          open
          data-faq-mobile-section
          data-faq-section
          id={section.id}
          class="group/section scroll-mt-(--site-header-height-desktop)"
        >
          <summary class="flex list-none cursor-pointer items-center justify-between gap-sm rounded-lg border-b-2 border-transparent bg-neutral-25 px-lg py-md text-left [&::-webkit-details-marker]:hidden group-open/section:rounded-b-none group-open/section:border-orchid-100 desktop:cursor-default desktop:rounded-none desktop:border-none desktop:bg-transparent desktop:px-0 desktop:py-0 desktop:pointer-events-none">
            <h2 class="text-h4 text-neutral-100 mb-0 group-open/section:text-orchid-100 tablet:group-open/section:text-neutral-100 desktop:text-h3-lg desktop:text-neutral-900">
              {section.heading}
            </h2>
            <Icon
              name="arrow-down"
              class="size-8 shrink-0 text-neutral-100 transition-transform duration-200 group-open/section:rotate-180 group-open/section:text-orchid-100 desktop:hidden"
            />
          </summary>
          <div class="flex flex-col gap-lg rounded-b-lg border border-t-0 border-neutral-25 px-lg pt-xl pb-lg desktop:gap-xl desktop:rounded-none desktop:border-none desktop:px-0 desktop:pt-xl desktop:pb-0">
            {section.items.map((item, index) => (
              <details
                open={index === 0}
                class="group/item border-b border-neutral-25 pb-lg first:pt-0 last:border-b-0 last:pb-0 desktop:pb-xl"
              >
                <summary class="flex cursor-pointer list-none items-start justify-between gap-sm text-left [&::-webkit-details-marker]:hidden">
                  <span class="text-h5 tablet:text-h5-md desktop:text-h5-lg text-neutral-100 group-open/item:text-neutral-900">
                    {item.question}
                  </span>
                  <Icon
                    name="arrow-down"
                    class="size-8 shrink-0 text-neutral-100 transition-transform duration-200 group-open/item:rotate-180"
                  />
                </summary>
                <p class="text-body-lg-standard tablet:text-body-lg-standard-md text-neutral-75 mt-md mb-0">
                  {item.answer}
                </p>
              </details>
            ))}
          </div>
        </details>
      ))
    }
  </div>
</div>

<script>
  // Mobile: FAQ sections themselves become an exclusive accordion (only one
  // open at a time, via the native <details name> group so the browser
  // handles closing the others for free) — first section open by default.
  // Desktop: every section stays open; the `toggle` guard below reasserts
  // `open` if a keyboard user still manages to collapse one (pointer-events
  // is disabled on the summary, but that doesn't block keyboard activation).
  // 1200px matches the `desktop:` breakpoint in tailwind.config.mjs (see the
  // same hardcoded value in src/scripts/header-nav.ts — no shared JS/CSS
  // breakpoint token exists in this codebase yet).
  document
    .querySelectorAll<HTMLElement>('[data-faq-mobile-sections]')
    .forEach((container) => {
      const detailsEls = Array.from(
        container.querySelectorAll<HTMLDetailsElement>(
          '[data-faq-mobile-section]'
        )
      )
      if (detailsEls.length === 0) return

      const desktopQuery = window.matchMedia('(min-width: 810px)')

      const applyMode = (isDesktop: boolean) => {
        detailsEls.forEach((details, index) => {
          if (isDesktop) {
            details.removeAttribute('name')
            details.open = true
          } else {
            details.setAttribute('name', 'faq-mobile-section')
            details.open = index === 0
          }
        })
      }

      detailsEls.forEach((details) => {
        details.addEventListener('toggle', () => {
          if (desktopQuery.matches && !details.open) {
            //details.open = true
          }
        })
      })

      applyMode(desktopQuery.matches)
      desktopQuery.addEventListener('change', (event) =>
        applyMode(event.matches)
      )
    })
</script>
