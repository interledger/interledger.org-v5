---
import {
  translatePath,
  useTranslations,
  buildUmamiAttrs,
  getNavigation,
  localizeRoute,
  type UiKey
} from '@/utils'
import Icon from '@/components/shared/Icon.astro'
import InterledgerIcon from '@/components/logos/InterledgerIcon.astro'

const { routeLocale } = Astro.locals
const t = useTranslations(routeLocale)

const { mainMenu } = getNavigation('foundation', routeLocale)

const subscribeHref = translatePath(
  'foundation-pages',
  routeLocale,
  'subscribe'
)
const contactHref = translatePath('foundation-pages', routeLocale, 'contact')
const homeHref = localizeRoute('/', routeLocale)

const footerLink = (href: string, ariaLabel?: string, linkText?: string) =>
  buildUmamiAttrs({
    pathname: Astro.url.pathname,
    lang: routeLocale,
    section: 'footer',
    href,
    ariaLabel,
    linkText
  })

const focusRing =
  'focus-visible:ring-2 focus-visible:ring-current focus-visible:ring-offset-2 focus-visible:outline-none'

const navLinkClass = `text-body-sm-standard text-neutral-75 transition-colors hover:text-black rounded-sm ${focusRing}`

const btnBase = `inline-flex items-center gap-2 rounded-card text-caption no-underline transition-colors ${focusRing}`
const btnPrimary = `${btnBase} bg-button-primary text-white hover:bg-button-primary-hover`
const btnOutline = `${btnBase} border border-[rgb(201,201,201)] hover:bg-black/5`
const btnPadding = 'px-space-s py-space-2xs'

const socialBtnClass = `inline-flex h-13 w-13 shrink-0 items-center justify-center rounded-card border border-[rgb(201,201,201)] bg-transparent transition-colors hover:bg-black/5 ${focusRing}`

type SocialIconName =
  | 'youtube'
  | 'mastodon'
  | 'x'
  | 'github'
  | 'instagram'
  | 'linkedin'
  | 'slack'

const socialLinks: Array<{
  href: string
  icon: SocialIconName
  labelKey: UiKey
}> = [
  {
    href: 'https://www.youtube.com/@InterledgerFoundation',
    icon: 'youtube',
    labelKey: 'footer.youtube'
  },
  {
    href: 'https://interledger.social/about',
    icon: 'mastodon',
    labelKey: 'footer.mastodon'
  },
  { href: 'https://x.com/interledger', icon: 'x', labelKey: 'footer.x' },
  {
    href: 'https://github.com/interledger',
    icon: 'github',
    labelKey: 'footer.github'
  },
  {
    href: 'https://www.instagram.com/interledgerfoundation/',
    icon: 'instagram',
    labelKey: 'footer.instagram'
  },
  {
    href: 'https://www.linkedin.com/company/interledger-foundation/',
    icon: 'linkedin',
    labelKey: 'footer.linkedin'
  },
  {
    href: 'https://communityinviter.com/apps/interledger/interledger-working-groups-slack',
    icon: 'slack',
    labelKey: 'footer.slack'
  }
]
---

<footer
  data-component="FoundationFooter"
  class="font-poppins border-t border-[rgb(201,201,201)] bg-[rgb(243,255,252)]"
  role="contentinfo"
>
  <div
    class="mx-auto max-w-[1600px] min-w-[360px] max-[1660px]:px-[5%]"
  >
    <!-- Top: Subscribe | Contact | Social -->
    <div
      class="grid grid-cols-1 gap-space-l py-space-l md:grid-cols-3 md:gap-space-xl"
    >
      <!-- Subscribe -->
      <section aria-labelledby="footer-subscribe-heading">
        <h5
          id="footer-subscribe-heading"
          class="mb-space-2xs text-h5 md:text-h5-md lg:text-h5-lg"
        >
          {t('footer.stay_up_to_date')}
        </h5>
        <p class="mb-space-s text-body-sm-standard text-neutral-75">
          {t('footer.newsletter_description')}
        </p>
        <a
          href={subscribeHref}
          class={`${btnPrimary} ${btnPadding}`}
          {...footerLink(subscribeHref, undefined, t('footer.subscribe'))}
        >
          {t('footer.subscribe')}
          <Icon name="arrow-right" />
        </a>
      </section>

      <!-- Contact -->
      <section aria-labelledby="footer-contact-heading">
        <h5
          id="footer-contact-heading"
          class="mb-space-2xs text-h5 md:text-h5-md lg:text-h5-lg"
        >
          {t('footer.contact_us')}
        </h5>
        <p class="mb-space-s text-body-sm-standard text-neutral-75">
          {t('footer.contact_description')}
        </p>
        <a
          href={contactHref}
          class={`${btnOutline} ${btnPadding}`}
          {...footerLink(contactHref, undefined, t('footer.contact_us'))}
        >
          {t('footer.contact_us')}
        </a>
      </section>

      <!-- Social Links -->
      <section aria-labelledby="footer-social-heading">
        <h5
          id="footer-social-heading"
          class="mb-space-2xs text-h5 md:text-h5-md lg:text-h5-lg"
        >
          {t('footer.social_links')}
        </h5>
        <ul class="m-0 flex w-full list-none flex-wrap justify-between gap-space-xs p-0" role="list">
          {
            socialLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  aria-label={t(link.labelKey)}
                  class={socialBtnClass}
                  {...footerLink(link.href, t(link.labelKey))}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  <Icon name={link.icon} class="size-6" />
                </a>
              </li>
            ))
          }
        </ul>
      </section>
    </div>

    <!-- Navigation columns -->
    <nav
      aria-label={t('footer.nav_label')}
      class="border-t border-[rgb(201,201,201)] py-space-l"
    >
      <ul
        class="m-0 grid list-none grid-cols-1 gap-space-l p-0 sm:grid-cols-2 md:grid-cols-3 min-[1200px]:flex min-[1200px]:flex-wrap"
        role="list"
      >
        {
          mainMenu.map((group, groupIndex) => {
            const groupHeadingId = `footer-nav-group-${groupIndex}`
            return (
              <li class="min-w-0 lg:flex-1">
                <h6
                  id={groupHeadingId}
                  class="mb-space-s text-body-lg-standard-md font-normal uppercase tracking-wide text-gray"
                >
                  {group.label}
                </h6>

                {group.items && group.items.length > 0 && !group.subGroups && (
                  <ul
                    class="m-0 flex list-none flex-col gap-space-2xs p-0"
                    role="list"
                    aria-labelledby={groupHeadingId}
                  >
                    {group.items.map((item) => (
                      <li>
                        <a
                          href={item.href ?? '#'}
                          class={navLinkClass}
                          {...footerLink(item.href ?? '#', undefined, item.label)}
                          {...(item.openInNewTab
                            ? { target: '_blank', rel: 'noopener noreferrer' }
                            : {})}
                        >
                          {item.label}
                        </a>
                      </li>
                    ))}
                  </ul>
                )}

                {group.subGroups && group.subGroups.length > 0 && (
                  <div class="flex flex-col gap-space-s">
                    {group.subGroups.map((sub, subIndex) => {
                      const subHeadingId = `${groupHeadingId}-sub-${subIndex}`
                      return (
                        <div>
                          <p
                            id={subHeadingId}
                            class="mb-space-xs text-caption font-normal uppercase tracking-wide text-black"
                          >
                            <span class="border-b border-black pb-space-3xs">
                              {sub.label}
                            </span>
                          </p>
                          <ul
                            class="m-0 flex list-none flex-col gap-space-2xs p-0"
                            role="list"
                            aria-labelledby={subHeadingId}
                          >
                            {sub.items.map((item) => (
                              <li>
                                <a
                                  href={item.href ?? '#'}
                                  class={navLinkClass}
                                  {...footerLink(
                                    item.href ?? '#',
                                    undefined,
                                    item.label
                                  )}
                                  {...(item.openInNewTab
                                    ? {
                                        target: '_blank',
                                        rel: 'noopener noreferrer'
                                      }
                                    : {})}
                                >
                                  {item.label}
                                </a>
                              </li>
                            ))}
                          </ul>
                        </div>
                      )
                    })}
                  </div>
                )}
              </li>
            )
          })
        }
      </ul>
    </nav>

    <!-- Bottom: copyright, legal links, logo -->
    <div class="border-t border-[rgb(201,201,201)] py-space-m text-center">
      <p class="mb-space-m text-step--3 text-neutral-75">
        {t('footer.copyright')}
      </p>

      <a
        href={homeHref}
        aria-label={t('footer.logo_home')}
        class="inline-block rounded-sm transition-opacity hover:opacity-80 focus-visible:ring-2 focus-visible:ring-current focus-visible:ring-offset-4 focus-visible:outline-none"
        {...footerLink(homeHref, t('footer.logo_home'), t('footer.logo_home'))}
      >
        <InterledgerIcon class="h-10 w-10" />
      </a>
    </div>
  </div>
</footer>
