---
import {
  translatePath,
  useTranslations,
  buildUmamiAttrs,
  getNavigation,
  localizeRoute,
  type UiKey
} from '@/utils'
import type { MenuGroup } from '@/types/navigation'
import Icon from '@/components/shared/Icon.astro'
import LinkButton from '@/components/shared/LinkButton.astro'
import InterledgerIcon from '@/components/logos/InterledgerIcon.astro'

const { routeLocale } = Astro.locals
const t = useTranslations(routeLocale)

const { mainMenu } = getNavigation('foundation', routeLocale)

const resourcesColumn: MenuGroup = {
  label: 'Resources',
  items: [
    { label: 'Terms of Service', href: '/terms-of-service' },
    { label: 'Privacy Policy', href: '/privacy-policy' },
    { label: 'Press & Media', href: '/press-and-media' },
    { label: 'FAQ', href: '/faq' }
  ]
}

const footerColumns = [...mainMenu, resourcesColumn]

const subscribeHref = translatePath(
  'foundation-pages',
  routeLocale,
  'subscribe'
)
const contactHref = translatePath('foundation-pages', routeLocale, 'contact')
const homeHref = localizeRoute('/', routeLocale)

const footerLink = (href: string, ariaLabel?: string, linkText?: string) =>
  buildUmamiAttrs({
    pathname: Astro.url.pathname,
    lang: routeLocale,
    section: 'footer',
    href,
    ariaLabel,
    linkText
  })

const focusRing =
  'focus-visible:ring-2 focus-visible:ring-current focus-visible:ring-offset-2 focus-visible:outline-none'

const navLinkClass = `inline-flex items-center gap-space-3xs text-[18px] md:text-[14px] whitespace-nowrap text-neutral-75 transition-colors hover:text-black aria-[current=page]:text-orchid-100 rounded-sm ${focusRing}`

const footerExternalLinkIconClass = 'size-4 shrink-0 translate-y-[-1px]'

const currentPath = Astro.url.pathname.replace(/\/$/, '')
const isActive = (href: string | null | undefined) =>
  !!href && currentPath === localizeRoute(href, routeLocale).replace(/\/$/, '')

const socialBtnClass =
  'inline-flex h-13 w-13 shrink-0 items-center justify-center rounded-card border border-neutral-50 bg-transparent transition-colors hover:border-neutral-900 hover:text-neutral-900 focus-visible:bg-neutral-25 focus-visible:text-neutral-900 focus-visible:outline-2 focus-visible:outline-solid focus-visible:-outline-offset-2 focus-visible:outline-neutral-900'

type SocialIconName =
  | 'youtube'
  | 'mastodon'
  | 'x'
  | 'github'
  | 'instagram'
  | 'linkedin'
  | 'slack'

const socialLinks: Array<{
  href: string
  icon: SocialIconName
  labelKey: UiKey
}> = [
  {
    href: 'https://www.youtube.com/@InterledgerFoundation',
    icon: 'youtube',
    labelKey: 'footer.youtube'
  },
  {
    href: 'https://interledger.social/about',
    icon: 'mastodon',
    labelKey: 'footer.mastodon'
  },
  { href: 'https://x.com/interledger', icon: 'x', labelKey: 'footer.x' },
  {
    href: 'https://github.com/interledger',
    icon: 'github',
    labelKey: 'footer.github'
  },
  {
    href: 'https://www.instagram.com/interledgerfoundation/',
    icon: 'instagram',
    labelKey: 'footer.instagram'
  },
  {
    href: 'https://www.linkedin.com/company/interledger-foundation/',
    icon: 'linkedin',
    labelKey: 'footer.linkedin'
  },
  {
    href: 'https://communityinviter.com/apps/interledger/interledger-working-groups-slack',
    icon: 'slack',
    labelKey: 'footer.slack'
  }
]
---

<footer
  data-component="FoundationFooter"
  class="bg-ice-mint-50"
  role="contentinfo"
>
  <div
    class="mx-auto max-w-wide min-w-[360px] px-lg md:px-xl desktop:px-3xl-tight"
  >
    <!-- Top: Subscribe | Contact | Social -->
    <div
      class="grid grid-cols-1 gap-3xl py-3xl desktop:grid-cols-6 desktop:gap-space-xl"
    >
      <!-- Subscribe -->
      <section
        aria-labelledby="footer-subscribe-heading"
        class="desktop:col-span-2"
      >
        <h5
          id="footer-subscribe-heading"
          class="mb-space-2xs text-h5-md lg:text-h5-lg"
        >
          {t('footer.stay_up_to_date')}
        </h5>
        <p class="mb-lg max-w-[44ch] text-body-sm-standard text-neutral-75">
          {t('footer.newsletter_description')}
        </p>
        <LinkButton
          href={subscribeHref}
          size="lg"
          class="max-md:w-full"
          {...footerLink(subscribeHref, undefined, t('footer.subscribe'))}
        >
          {t('footer.subscribe')}
          <Icon slot="icon-right" name="arrow-right" />
        </LinkButton>
      </section>

      <!-- Contact -->
      <section
        aria-labelledby="footer-contact-heading"
        class="desktop:col-span-2"
      >
        <h5
          id="footer-contact-heading"
          class="mb-space-2xs text-h5-md lg:text-h5-lg"
        >
          {t('footer.contact_us')}
        </h5>
        <p class="mb-lg max-w-[44ch] text-body-sm-standard text-neutral-75">
          {t('footer.contact_description')}
        </p>
        <LinkButton
          href={contactHref}
          variant="secondary"
          size="lg"
          class="max-md:w-full"
          {...footerLink(contactHref, undefined, t('footer.contact_us'))}
        >
          {t('footer.contact_us')}
        </LinkButton>
      </section>

      <!-- Social Links -->
      <section
        aria-labelledby="footer-social-heading"
        class="desktop:col-span-2"
      >
        <h5
          id="footer-social-heading"
          class="mb-space-2xs text-h5-md lg:text-h5-lg"
        >
          {t('footer.social_links')}
        </h5>
        <ul
          class="mb-0 mt-space-xs flex list-none flex-wrap gap-md p-0 tablet:gap-xl mx-0"
          role="list"
        >
          {
            socialLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  aria-label={t(link.labelKey)}
                  class={socialBtnClass}
                  {...footerLink(link.href, t(link.labelKey))}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  <Icon name={link.icon} class="size-6" />
                </a>
              </li>
            ))
          }
        </ul>
      </section>
    </div>

    <!-- Navigation columns -->
    <nav
      aria-label={t('footer.nav_label')}
      class="border-t border-neutral-50 py-3xl"
    >
      <ul
        class="m-0 grid list-none grid-cols-1 gap-3xl p-0 md:gap-space-l md:grid-cols-3 desktop:grid-cols-6 desktop:gap-space-xl"
        role="list"
      >
        {
          footerColumns.map((group, groupIndex) => {
            const groupHeadingId = `footer-nav-group-${groupIndex}`
            return (
              <li class="min-w-0">
                <h6
                  id={groupHeadingId}
                  class="mb-space-s text-[20px] md:text-body-lg-standard-md font-normal uppercase tracking-wide text-black md:text-gray"
                >
                  {group.label}
                </h6>

                {group.items && group.items.length > 0 && !group.subGroups && (
                  <ul
                    class="m-0 flex list-none flex-col gap-md md:gap-space-2xs p-0"
                    role="list"
                    aria-labelledby={groupHeadingId}
                  >
                    {group.items.map((item) => (
                      <li>
                        <a
                          href={item.href ?? '#'}
                          class={navLinkClass}
                          aria-current={
                            isActive(item.href) ? 'page' : undefined
                          }
                          {...footerLink(
                            item.href ?? '#',
                            undefined,
                            item.label
                          )}
                          {...(item.openInNewTab
                            ? { target: '_blank', rel: 'noopener noreferrer' }
                            : {})}
                        >
                          {item.label}
                          {item.openInNewTab && (
                            <Icon
                              name="external-link"
                              class={footerExternalLinkIconClass}
                            />
                          )}
                        </a>
                      </li>
                    ))}
                  </ul>
                )}

                {group.subGroups && group.subGroups.length > 0 && (
                  <div class="flex flex-col gap-xl md:flex-wrap md:flex-row md:gap-x-10 md:gap-y-space-m lg:flex-col lg:gap-space-m">
                    {group.subGroups.map((sub, subIndex) => {
                      const subHeadingId = `${groupHeadingId}-sub-${subIndex}`
                      return (
                        <div class="flex flex-col gap-md">
                          <p
                            id={subHeadingId}
                            class="mb-2 text-caption font-normal uppercase tracking-wide text-black whitespace-nowrap"
                          >
                            <span class="border-b border-black pb-space-3xs">
                              {sub.label}
                            </span>
                          </p>
                          <ul
                            class="m-0 flex list-none flex-col gap-md md:gap-space-2xs p-0"
                            role="list"
                            aria-labelledby={subHeadingId}
                          >
                            {sub.items.map((item) => (
                              <li>
                                <a
                                  href={item.href ?? '#'}
                                  class={navLinkClass}
                                  aria-current={
                                    isActive(item.href) ? 'page' : undefined
                                  }
                                  {...footerLink(
                                    item.href ?? '#',
                                    undefined,
                                    item.label
                                  )}
                                  {...(item.openInNewTab
                                    ? {
                                        target: '_blank',
                                        rel: 'noopener noreferrer'
                                      }
                                    : {})}
                                >
                                  {item.label}
                                  {item.openInNewTab && (
                                    <Icon
                                      name="external-link"
                                      class={footerExternalLinkIconClass}
                                    />
                                  )}
                                </a>
                              </li>
                            ))}
                          </ul>
                        </div>
                      )
                    })}
                  </div>
                )}
              </li>
            )
          })
        }
      </ul>
    </nav>

    <!-- Bottom: copyright, legal links, logo -->
    <div class="border-t border-neutral-50 py-space-m text-center">
      <p class="mb-space-m text-step--3 text-neutral-75">
        {t('footer.copyright')}
      </p>

      <a
        href={homeHref}
        aria-label={t('footer.logo_home')}
        class="inline-block rounded-sm transition-opacity hover:opacity-80 focus-visible:ring-2 focus-visible:ring-current focus-visible:ring-offset-4 focus-visible:outline-none"
        {...footerLink(homeHref, t('footer.logo_home'), t('footer.logo_home'))}
      >
        <InterledgerIcon class="h-10 w-10" />
      </a>
    </div>
  </div>
</footer>
