---
import { useTranslations, buildUmamiAttrs, type UiKey } from '@/utils'
import Icon from '@/components/shared/Icon.astro'

const { routeLocale } = Astro.locals
const t = useTranslations(routeLocale)
const currentYear = new Date().getFullYear()
const umamiBase = {
  pathname: Astro.url.pathname,
  lang: routeLocale,
  section: 'footer' as const
}

type SocialIconName = 'mastodon' | 'x' | 'slack' | 'github' | 'linkedin'

const socialLinks: Array<{
  href: string
  icon: SocialIconName
  labelKey: UiKey
}> = [
  {
    href: 'https://interledger.social/@Interledger',
    icon: 'mastodon',
    labelKey: 'footer.social.mastodon'
  },
  {
    href: 'https://twitter.com/interledger',
    icon: 'x',
    labelKey: 'footer.social.twitter'
  },
  {
    href: 'https://communityinviter.com/apps/interledger/interledger-working-groups-slack',
    icon: 'slack',
    labelKey: 'footer.social.slack'
  },
  {
    href: 'https://github.com/interledger',
    icon: 'github',
    labelKey: 'footer.social.github'
  },
  {
    href: 'https://www.linkedin.com/company/interledger-foundation/',
    icon: 'linkedin',
    labelKey: 'footer.social.linkedin'
  }
]
---

<footer
  class="text-center py-space-2xs px-space-xs text-step--1 bg-black/15 flex flex-col gap-4 justify-center items-center xs:flex-row xs:justify-between"
>
  <ul class="list-none flex gap-6 justify-center p-0 mt-space-2xs xs:mt-0">
    {
      socialLinks.map((link) => (
        <li>
          <a
            href={link.href}
            aria-label={t(link.labelKey)}
            {...buildUmamiAttrs({
              ...umamiBase,
              href: link.href,
              ariaLabel: t(link.labelKey)
            })}
          >
            <Icon name={link.icon} class="size-6" />
          </a>
        </li>
      ))
    }
  </ul>
  <p>&copy; 2020–{currentYear}, Interledger Foundation</p>
</footer>
