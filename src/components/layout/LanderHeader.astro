---
import DevelopersLogo from '@/components/logos/DevelopersLogo.astro'
import Icon from '@/components/shared/Icon.astro'
import {
  HOME_CONTENT_SLUG,
  translatePath,
  useTranslations,
  buildUmamiAttrs
} from '@/utils'

const { routeLocale } = Astro.locals
const t = useTranslations(routeLocale)
const homeHref = translatePath(
  'foundation-pages',
  routeLocale,
  HOME_CONTENT_SLUG
)

const navLink = (href: string, linkText?: string, ariaLabel?: string) =>
  buildUmamiAttrs({
    pathname: Astro.url.pathname,
    lang: routeLocale,
    section: 'nav',
    href,
    linkText,
    ariaLabel
  })
---

<header class="bg-[var(--color-bg)] px-space-m py-space-2xs">
  <div
    class="flex justify-between items-center max-w-[95rem] mx-auto gap-space-s"
  >
    <a
      href={homeHref}
      class="flex items-center gap-space-xs flex-none"
      {...navLink(homeHref, undefined, t('aria.logo.foundation'))}
    >
      <DevelopersLogo class="w-[7em] flex-none text-[var(--color-text)]" />
    </a>
    <a
      href={homeHref}
      class="ml-auto inline-flex h-[1.5em] max-w-full flex-wrap overflow-hidden whitespace-nowrap text-step--1"
      {...navLink(homeHref, t('aria.logo.foundation'))}
    >
      <span
        class="block w-0 flex-auto overflow-hidden text-ellipsis text-right"
        aria-hidden="true"
        title={t('aria.logo.foundation_title')}
      >
        ILF
      </span>
      <span class="inline flex-[0_1_100%]"> {t('aria.logo.foundation')} </span>
    </a>
    <a
      href="https://github.com/interledger"
      aria-label={t('aria.logo.github')}
      class="inline-flex h-[1.25em] w-[1.25em] items-center justify-center"
      {...navLink(
        'https://github.com/interledger',
        undefined,
        t('aria.logo.github')
      )}
    >
      <Icon name="github" class="h-full w-full" />
    </a>
  </div>
</header>
