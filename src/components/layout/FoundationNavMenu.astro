---
import Icon from '@/components/shared/Icon.astro'
import type { MenuGroup } from '@/types/navigation'
import { buildUmamiAttrs } from '@/utils'

interface Props {
  menuGroups: MenuGroup[]
  theme?: 'light' | 'dark'
}

const { menuGroups, theme = 'light' } = Astro.props
const isDark = theme === 'dark'
const { routeLocale } = Astro.locals

const navAttrs = (
  href: string | null | undefined,
  linkText?: string,
  action?: string
) =>
  buildUmamiAttrs({
    pathname: Astro.url.pathname,
    lang: routeLocale,
    section: 'nav',
    href,
    linkText,
    action
  })

const navButtonHoverClass = isDark
  ? 'hover:bg-neutral-100'
  : 'hover:bg-gray-header'

const navButtonClass = `peer inline-flex items-center text-current whitespace-nowrap py-2 pl-space-xs pr-1.5 rounded-lg border-none bg-transparent transition-colors duration-200 ${navButtonHoverClass} group/submenu data-[active=true]:underline data-[active=true]:decoration-current data-[active=true]:decoration-2 data-[active=true]:underline-offset-8`

const navButtonChevronClass =
  'ml-2 inline-flex size-5 shrink-0 items-center justify-center origin-center transition-transform duration-150 motion-reduce:transition-none group-hover:rotate-180 group-data-[open=true]/submenu:rotate-180'

// Visibility + positioning toggles shared by both panel variants.
// Hidden by default; shown on group-hover (desktop pointer), peer-data-open
// (keyboard/click via data-submenu-button), or peer-data-open on mobile.
const panelBgClass = isDark
  ? 'min-[1060px]:bg-neutral-150 min-[1060px]:border min-[1060px]:border-neutral-100'
  : 'min-[1060px]:bg-white min-[1060px]:border min-[1060px]:border-gray-header'

const panelToggleClass =
  'max-[1059px]:hidden ' +
  'min-[1060px]:absolute ' +
  `${panelBgClass} ` +
  'min-[1060px]:transition-opacity min-[1060px]:duration-fast ' +
  'min-[1060px]:invisible min-[1060px]:opacity-0 ' +
  'min-[1060px]:top-[calc(100%+0.25rem)] ' +
  'min-[1060px]:shadow-[2px_3px_6px_-3px_hsla(0,0%,0%,0.06),-2px_3px_6px_-3px_hsla(0,0%,0%,0.06)] ' +
  'min-[1060px]:group-hover:visible min-[1060px]:group-hover:opacity-100 min-[1060px]:group-hover:left-0 ' +
  'min-[1060px]:peer-data-[open=true]:visible min-[1060px]:peer-data-[open=true]:opacity-100 min-[1060px]:peer-data-[open=true]:left-0 ' +
  'max-[1059px]:peer-data-[open=true]:block'

const flatSubmenuClass = `list-none ps-0 max-[1059px]:ps-space-m min-[1060px]:min-w-full min-[1060px]:group-hover:w-max min-[1060px]:peer-data-[open=true]:w-max ${panelToggleClass}`

const itemTextClass = isDark
  ? 'text-neutral-25 hover:bg-neutral-100'
  : 'text-black hover:bg-gray-header'

const submenuItemClass = `block no-underline ${itemTextClass} max-[1059px]:py-space-s max-[1059px]:px-space-s min-[1060px]:py-space-2xs min-[1060px]:px-space-2xs data-[active=true]:underline data-[active=true]:decoration-current data-[active=true]:decoration-2 data-[active=true]:underline-offset-8`

const megaMenuClass = `max-[1059px]:ps-space-m min-[1060px]:grid min-[1060px]:grid-cols-3 min-[1060px]:gap-space-l min-[1060px]:p-space-l min-[1060px]:min-w-[40rem] ${panelToggleClass}`

const subGroupHeadingTextClass = isDark
  ? 'text-neutral-50 border-neutral-100'
  : 'text-neutral-75 border-neutral-50'

const subGroupHeadingClass = `font-poppins text-caption uppercase tracking-wide pb-space-2xs border-b mb-space-xs max-[1059px]:mt-space-s max-[1059px]:first:mt-0 ${subGroupHeadingTextClass}`

const megaMenuLinkClass = `block no-underline ${itemTextClass} data-[active=true]:underline data-[active=true]:decoration-current data-[active=true]:decoration-2 data-[active=true]:underline-offset-8 max-[1059px]:py-space-xs min-[1060px]:py-space-2xs min-[1060px]:px-space-2xs`
---

<ul
  class="list-none ps-0 justify-center font-poppins min-[1060px]:flex min-[1060px]:items-center min-[1060px]:gap-space-2xs"
  id="siteNavMenu"
  data-nav-list
>
  {
    menuGroups.map((group) => (
      <li class="group min-[1060px]:relative" data-menu-level="1">
        <button
          aria-expanded="false"
          {...navAttrs(undefined, group.label, `${group.label}_menu`)}
          class={navButtonClass}
          data-submenu-button
          data-open="false"
        >
          {group.label}
          <span class={navButtonChevronClass} aria-hidden="true">
            <Icon name="arrow-down" class="size-5" />
          </span>
        </button>

        {group.subGroups && group.subGroups.length > 0 ? (
          <div class={megaMenuClass}>
            {group.subGroups.map((subGroup) => (
              <div>
                <p class={subGroupHeadingClass}>{subGroup.label}</p>
                <ul class="list-none ps-0">
                  {subGroup.items.map((item) => (
                    <li data-menu-level="2">
                      <a
                        href={item.href || '#'}
                        {...navAttrs(item.href || '#', item.label)}
                        class={megaMenuLinkClass}
                        {...(item.openInNewTab
                          ? { target: '_blank', rel: 'noopener noreferrer' }
                          : {})}
                      >
                        {item.label}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        ) : group.items && group.items.length > 0 ? (
          <ul class={flatSubmenuClass}>
            {group.items.map((item) => (
              <li data-menu-level="2">
                <a
                  href={item.href || '#'}
                  {...navAttrs(item.href || '#', item.label)}
                  class={submenuItemClass}
                  {...(item.openInNewTab
                    ? { target: '_blank', rel: 'noopener noreferrer' }
                    : {})}
                >
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        ) : null}
      </li>
    ))
  }
</ul>
