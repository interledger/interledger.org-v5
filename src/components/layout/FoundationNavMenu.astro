---
import Icon from '@/components/shared/Icon.astro'
import type { MenuGroup } from '@/types/navigation'
import { buildUmamiAttrs } from '@/utils'

interface Props {
  menuGroups: MenuGroup[]
  theme?: 'light' | 'dark'
}

const { menuGroups, theme = 'light' } = Astro.props
const isDark = theme === 'dark'
const { routeLocale } = Astro.locals

const navAttrs = (
  href: string | null | undefined,
  linkText?: string,
  action?: string
) =>
  buildUmamiAttrs({
    pathname: Astro.url.pathname,
    lang: routeLocale,
    section: 'nav',
    href,
    linkText,
    action
  })

const navButtonClass = `peer inline-flex items-center text-current whitespace-nowrap rounded-lg border-none bg-transparent transition-colors duration-200 group/submenu data-[active=true]:underline data-[active=true]:decoration-current data-[active=true]:decoration-2 data-[active=true]:underline-offset-8 w-full justify-between py-space-s px-lg text-[1.25rem] focus-visible:outline-none desktop:w-auto desktop:justify-start desktop:py-sm desktop:pl-space-xs desktop:pr-space-3xs desktop:text-base`

const navButtonChevronClass =
  'ml-sm inline-flex size-8 shrink-0 items-center justify-center origin-center text-neutral-75 transition-transform duration-150 motion-reduce:transition-none group-hover:rotate-180 group-data-[open=true]/submenu:rotate-180 desktop:size-5 desktop:text-current'

const panelBgClass = isDark
  ? 'desktop:bg-neutral-150 desktop:border desktop:border-neutral-100'
  : 'desktop:bg-white desktop:border desktop:border-gray-header'

const panelMobileClass =
  'block max-h-0 overflow-hidden border-0 bg-transparent shadow-none ' +
  'transition-[max-height] duration-500 ease-out motion-reduce:transition-none ' +
  'peer-data-[open=true]:max-h-screen'

const panelDesktopClass =
  'desktop:absolute desktop:invisible desktop:opacity-0 desktop:top-[calc(100%+1.5rem)] ' +
  'desktop:max-h-none desktop:overflow-visible ' +
  'desktop:transition-opacity desktop:duration-fast ' +
  'desktop:shadow-[2px_3px_6px_-3px_hsla(0,0%,0%,0.06),-2px_3px_6px_-3px_hsla(0,0%,0%,0.06)] ' +
  'desktop:before:absolute desktop:before:bottom-full desktop:before:inset-x-0 desktop:before:h-6 desktop:before:content-[""] ' +
  'desktop:group-hover:visible desktop:group-hover:opacity-100 desktop:group-hover:left-0 ' +
  'desktop:peer-data-[open=true]:visible desktop:peer-data-[open=true]:opacity-100 desktop:peer-data-[open=true]:left-0'

const panelToggleClass = `submenu-panel ${panelMobileClass} ${panelDesktopClass} ${panelBgClass}`

const submenuListClass =
  'list-none flex flex-col gap-y-0 desktop:block desktop:gap-0 desktop:ps-0'

const flatSubmenuPanelClass = `w-full px-space-s ${panelToggleClass} desktop:min-w-full desktop:px-space-m desktop:py-space-s desktop:group-hover:w-max desktop:peer-data-[open=true]:w-max`

const flatSubmenuListClass = submenuListClass

const itemTextClass = isDark ? 'text-neutral-25' : 'text-black'

const navLinkClass =
  'nav-link relative block no-underline after:absolute after:inset-x-0 after:bottom-0 after:h-px ' +
  'after:origin-left after:bg-current after:scale-x-0 after:transition-transform after:content-[""] ' +
  'after:hidden desktop:after:block desktop:hover:after:scale-x-100 desktop:focus-visible:after:scale-x-100 ' +
  'motion-reduce:after:transition-none'

const mobileNavLinkLayoutClass =
  'max-desktop:-mx-space-s max-desktop:rounded-lg max-desktop:px-lg max-desktop:py-lg'

const submenuItemClass = `${navLinkClass} ${itemTextClass} ${mobileNavLinkLayoutClass} px-0 desktop:py-space-2xs desktop:pe-space-2xs data-[active=true]:underline data-[active=true]:decoration-current data-[active=true]:decoration-2 data-[active=true]:underline-offset-8`

const megaMenuClass = `flex flex-col gap-y-0 px-space-s ${panelToggleClass} desktop:grid desktop:gap-space-l desktop:p-space-l`

const subGroupHeadingTextClass = isDark
  ? 'text-neutral-50 border-neutral-75'
  : 'text-neutral-75 border-neutral-100'

const megaSubGroupClass =
  'mt-lg flex flex-col gap-y-md desktop:mt-0 desktop:gap-0'

const subGroupHeadingClass = `nav-subgroup-heading w-full border-b font-poppins text-caption uppercase tracking-wide whitespace-nowrap desktop:mb-space-3xs desktop:w-fit desktop:pb-space-2xs ${subGroupHeadingTextClass}`

const megaMenuLinkClass = `${navLinkClass} ${mobileNavLinkLayoutClass} whitespace-nowrap ${itemTextClass} px-0 desktop:py-space-2xs desktop:pe-space-2xs data-[active=true]:underline data-[active=true]:decoration-current data-[active=true]:decoration-2 data-[active=true]:underline-offset-8`
---

<ul
  class="list-none flex flex-col gap-[20px] ps-0 font-poppins desktop:flex desktop:flex-row desktop:items-center desktop:justify-center desktop:gap-space-2xs desktop:relative"
  id="siteNavMenu"
  data-nav-list
>
  {
    menuGroups.map((group) => (
      <li
        class={`group ${group.subGroups && group.subGroups.length > 3 ? 'desktop:static' : 'desktop:relative'}`}
        data-menu-level="1"
      >
        <button
          aria-expanded="false"
          {...navAttrs(undefined, group.label, `${group.label}_menu`)}
          class={navButtonClass}
          data-submenu-button
          data-open="false"
        >
          {group.label}
          <span class={navButtonChevronClass} aria-hidden="true">
            <Icon name="arrow-down" class="size-8 desktop:size-5" />
          </span>
        </button>

        {group.subGroups && group.subGroups.length > 0 ? (
          <div
            class={megaMenuClass}
            style={`--mega-menu-cols: ${group.subGroups.length}; grid-template-columns: repeat(var(--mega-menu-cols), max-content);`}
          >
            {group.subGroups.map((subGroup) => (
              <div class={megaSubGroupClass}>
                <p class={subGroupHeadingClass}>{subGroup.label}</p>
                <ul class={submenuListClass}>
                  {subGroup.items.map((item) => (
                    <li data-menu-level="2">
                      <a
                        href={item.href || '#'}
                        {...navAttrs(item.href || '#', item.label)}
                        class={megaMenuLinkClass}
                        {...(item.openInNewTab
                          ? { target: '_blank', rel: 'noopener noreferrer' }
                          : {})}
                      >
                        {item.label}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        ) : group.items && group.items.length > 0 ? (
          <div class={flatSubmenuPanelClass}>
            <ul class={flatSubmenuListClass}>
              {group.items.map((item) => (
                <li data-menu-level="2">
                  <a
                    href={item.href || '#'}
                    {...navAttrs(item.href || '#', item.label)}
                    class={submenuItemClass}
                    {...(item.openInNewTab
                      ? { target: '_blank', rel: 'noopener noreferrer' }
                      : {})}
                  >
                    {item.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ) : null}
      </li>
    ))
  }
</ul>
