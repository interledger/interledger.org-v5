---
/**
 * Foundation site header.
 * Composes navigation menu, action links, and mobile toggle.
 *
 * `theme="dark"` is used on pages where the nav sits over a dark hero
 * (e.g. the homepage). It renders a translucent backdrop-blurred bar,
 * light text, and dark dropdown panels. Default `"light"` is the
 * white-bar treatment used on inner pages.
 */
import FoundationNavMenu from '@/components/layout/FoundationNavMenu.astro'
import FoundationNavActions from '@/components/layout/FoundationNavActions.astro'
import HamburgerButton from '@/components/shared/HamburgerButton.astro'
import LanguageSwitcher from '@/components/shared/LanguageSwitcher.astro'
import LinkButton from '@/components/shared/LinkButton.astro'
import Icon from '@/components/shared/Icon.astro'

import {
  translatePath,
  HOME_CONTENT_SLUG,
  useTranslations,
  getNavigation,
  buildUmamiAttrs
} from '@/utils'

interface Props {
  theme?: 'light' | 'dark'
}

const { theme = 'light' } = Astro.props
const isDark = theme === 'dark'

const { routeLocale } = Astro.locals
const t = useTranslations(routeLocale)

const { mainMenu, ctaButton } = getNavigation('foundation', routeLocale)
const homeHref = translatePath(
  'foundation-pages',
  routeLocale,
  HOME_CONTENT_SLUG
)

const navLink = (href: string, linkText?: string, ariaLabel?: string) =>
  buildUmamiAttrs({
    pathname: Astro.url.pathname,
    lang: routeLocale,
    section: 'nav',
    href,
    linkText,
    ariaLabel
  })

const headerClass = isDark
  ? 'foundation-header sticky top-0 z-[2] px-space-xs desktop:px-space-m bg-[rgba(13,13,13,0.7)] text-neutral-50'
  : 'foundation-header sticky top-0 z-[2] px-space-xs desktop:px-space-m bg-[rgba(255,255,255,0.7)] shadow'
---

<header class={headerClass} role="banner" data-theme={theme}>
  <nav
    class="mx-auto w-full max-w-wide flex items-center justify-between desktop:grid desktop:grid-cols-[auto_1fr_auto] desktop:gap-space-s desktop:h-[76px] max-desktop:h-[var(--site-header-height)]"
    role="navigation"
    aria-labelledby="block-interledger-mainnavigation-menu"
    id="block-interledger-mainnavigation"
    data-nav
  >
    <h2 class="sr-only" id="block-interledger-mainnavigation-menu">
      {t('nav.main')}
    </h2>
    <a
      href={homeHref}
      class="flex-none desktop:col-start-1 desktop:col-end-2 desktop:z-[1]"
      aria-label={t('aria.logo.foundation')}
      {...navLink(homeHref, undefined, t('aria.logo.foundation'))}
    >
      <img
        src="/img/interledger-foundation-logo-white.svg"
        alt=""
        width="236"
        height="40"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        class="foundation-logo--dark block h-10 w-auto"
      />
      <img
        src="/img/interledger-foundation-logo-purple.svg"
        alt=""
        width="148"
        height="40"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        class="foundation-logo--light block h-10 w-auto"
      />
    </a>
    <div
      class="header-nav-wrapper header-nav-wrapper--foundation"
      data-nav-wrapper
      data-offscreen="true"
      inert
      id="siteNavLinks"
    >
      <div
        class="max-desktop:flex desktop:hidden items-center justify-between gap-space-s px-space-s pt-space-xs pb-space-s"
      >
        <span class="font-poppins text-h3 text-neutral-75">
          {t('nav.language')}
        </span>
        <LanguageSwitcher />
      </div>
      <hr class="desktop:hidden mx-space-s my-0 h-px border-0 bg-neutral-100" />
      <FoundationNavMenu menuGroups={mainMenu} theme={theme} />
      {
        ctaButton && (
          <div class="desktop:hidden mx-space-s mt-space-m mb-space-xl">
            <LinkButton
              href={ctaButton.href || '#'}
              variant="primary"
              size="sm"
              external={ctaButton.openInNewTab}
              class="w-full"
              {...navLink(ctaButton.href || '#', ctaButton.label)}
            >
              {ctaButton.label}
              <Icon slot="icon-right" name="arrow-right" />
            </LinkButton>
          </div>
        )
      }
    </div>
    <FoundationNavActions ctaButton={ctaButton} />
    <HamburgerButton menuId="siteNavMenu" iconId="foundationMenuIcon" />
  </nav>
</header>

<script>
  import './foundation-header.ts'
</script>
