---
import OptimizedImage from '@/components/shared/OptimizedImage.astro'
import LinkButton from '@/components/shared/LinkButton.astro'
import Icon from '@/components/shared/Icon.astro'
import {
  translatePath,
  useTranslations,
  buildUmamiAttrs,
  type Locale
} from '@/utils'

/** Intrinsic dimensions of homepage hero raster (CLS / decode hint). Mirrors `stefan-thomas.webp`. */
const HERO_LCP_IMAGE_WIDTH = 1920
const HERO_LCP_IMAGE_HEIGHT = 1280

interface Props {
  pageLang: Locale
  pathname: string
}

const { pageLang, pathname } = Astro.props
const t = useTranslations(pageLang)

const exploreTechHref = translatePath(
  'foundation-pages',
  pageLang,
  'developers'
)
const exploreGrantsHref = translatePath(
  'foundation-pages',
  pageLang,
  'grants'
)

const heroUmami = (href: string, linkText: string) =>
  buildUmamiAttrs({
    pathname,
    lang: pageLang,
    section: 'hero',
    href,
    linkText
  })
---

<section
  data-component="HomepageHero"
  data-umami-component="homepage-hero"
  class="relative isolate -mt-(--site-header-height) bg-black pt-(--site-header-height) text-white desktop:-mt-(--site-header-height-desktop) desktop:pt-(--site-header-height-desktop) tablet:h-[90dvh] tablet:min-h-[90dvh] tablet:overflow-visible"
  aria-labelledby="home-hero-title"
>
  <div
    class="pointer-events-none absolute top-full left-0 right-0 -z-10 bg-neutral-150"
    aria-hidden="true"
  >
  </div>

  <div class="bottom-mask" aria-hidden="true"></div>

  <figure
    class="hero-network-bg pointer-events-none absolute inset-0 overflow-hidden tablet:hidden"
    aria-hidden="true"
  >
    <picture>
      <source
        media="(max-width: 809px)"
        srcset="/img/homepage/hero-animated-network.svg"
        type="image/svg+xml"
      />
      <img
        alt=""
        width="1920"
        height="3186"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        class="hero-network-svg block h-auto w-full max-w-none opacity-50"
      />
    </picture>
  </figure>

  <div
    class="hero-stefan-wrap pointer-events-none absolute inset-0 -z-10 overflow-hidden"
    aria-hidden="true"
  >
    <OptimizedImage
      src="/img/homepage/stefan-thomas.webp"
      alt=""
      width={HERO_LCP_IMAGE_WIDTH}
      height={HERO_LCP_IMAGE_HEIGHT}
      loading="eager"
      fetchpriority="high"
      media="(min-width: 810px)"
      sizes="(min-width: 1880px) 100vw, 58vw"
      pictureClass="hero-stefan-picture absolute inset-0 hidden tablet:block"
      class="hero-stefan-photo h-full w-full object-cover"
    />
  </div>

  <div
    class="relative z-[1] mx-auto flex w-full max-w-full items-center px-space-m py-space-2xl tablet:max-w-wide tablet:min-h-[90dvh] md:py-space-3xl"
  >
    <div
      class="w-full max-w-full motion-safe:animate-fade-in motion-safe:opacity-0 motion-safe:[animation-fill-mode:forwards] motion-reduce:opacity-100 tablet:max-w-[50%] desktop:max-w-[var(--layout-homepage-hero-copy-max-lg)]"
    >
      <h1 id="home-hero-title" class="text-h2-md desktop:text-h2-lg">
        <span class="inline desktop:block"
          >{t('homepageHero.title_lead')}
        </span>
        <span class="inline text-aqua-mint-100 desktop:block">
          {t('homepageHero.title_accent')}
        </span>
      </h1>

      <p class="mt-space-m text-h4-md desktop:text-h4-lg text-white/85">
        {t('homepageHero.description')}
      </p>

      <nav
        aria-label={t('homepageHero.cta_navigation')}
        class="mt-space-s flex w-full flex-col gap-space-s tablet:flex-row tablet:flex-wrap"
      >
        <LinkButton
          href={exploreTechHref}
          class="w-full tablet:w-auto"
          {...heroUmami(exploreTechHref, t('homepageHero.cta_explore_tech'))}
        >
          {t('homepageHero.cta_explore_tech')}
          <Icon slot="icon-right" name="arrow-right" />
        </LinkButton>
        <LinkButton
          href={exploreGrantsHref}
          variant="secondary"
          mode="dark"
          class="w-full tablet:w-auto"
          {...heroUmami(exploreGrantsHref, t('homepageHero.cta_explore_grants'))}
        >
          {t('homepageHero.cta_explore_grants')}
        </LinkButton>
      </nav>
    </div>
  </div>
</section>

<style>
  [data-component='HomepageHero'] {
    --hero-fade-fill: var(--color-neutral-150);
  }

  /* Gradient masks fading neutral-150 in from left, right, and bottom.
     Hidden below tablet since the hero image only renders at 810px+. */
  [data-component='HomepageHero']::before,
  [data-component='HomepageHero']::after {
    content: '';
    position: absolute;
    inset-block: 0;
    background-color: var(--hero-fade-fill);
    pointer-events: none;
    display: none;
    z-index: 0;
  }

  [data-component='HomepageHero']::before {
    left: 0;
    width: 60%;
    -webkit-mask: linear-gradient(270deg, #0000 3%, #000 100%);
    mask: linear-gradient(270deg, #0000 3%, #000 100%);
  }

  [data-component='HomepageHero']::after {
    right: 0;
    width: 30%;
    -webkit-mask: linear-gradient(90deg, #0000 18%, #000 81%);
    mask: linear-gradient(90deg, #0000 18%, #000 81%);
  }

  [data-component='HomepageHero'] .bottom-mask {
    position: absolute;
    inset-inline: 0;
    bottom: 0;
    height: 40%;
    background-color: var(--hero-fade-fill);
    pointer-events: none;
    display: none;
    z-index: 0;
    -webkit-mask: linear-gradient(180deg, #0000 0%, #000 100%);
    mask: linear-gradient(180deg, #0000 0%, #000 100%);
  }

  @media (min-width: 810px) {
    [data-component='HomepageHero'] {
      --hero-stefan-object-x: 78%;
      --hero-stefan-object-y: top;
      --hero-stefan-offset-x: 0;
      /* Negative = shift photo up to trim source headroom; height calc keeps bottom filled. */
      --hero-stefan-offset-y: -18vh;
    }

    [data-component='HomepageHero']::before,
    [data-component='HomepageHero']::after,
    [data-component='HomepageHero'] .bottom-mask {
      display: block;
    }

    [data-component='HomepageHero'] .hero-stefan-wrap {
      height: 100%;
    }

    [data-component='HomepageHero'] .hero-stefan-picture {
      display: block;
      height: 100%;
    }

    [data-component='HomepageHero'] .hero-stefan-photo {
      display: block;
      width: 100%;
      height: calc(100% - var(--hero-stefan-offset-y));
      object-fit: cover;
      object-position: var(--hero-stefan-object-x) var(--hero-stefan-object-y);
      transform: translate(
        var(--hero-stefan-offset-x),
        var(--hero-stefan-offset-y)
      );
      transform-origin: top center;
    }
  }

  @media (min-width: 810px) and (max-width: 1879px) {
    [data-component='HomepageHero'] {
      --hero-stefan-width: 58vw;
      --hero-stefan-offset-x: -2vw;
    }

    [data-component='HomepageHero'] .hero-stefan-picture {
      inset: auto;
      top: 0;
      right: 5vw;
      bottom: 0;
      left: auto;
      width: var(--hero-stefan-width);
      height: 100%;
    }

    [data-component='HomepageHero'] .hero-stefan-photo {
      transform-origin: right top;
    }
  }

  @media (min-width: 1880px) {
    [data-component='HomepageHero'] {
      --hero-stefan-object-x: 80%;
    }
  }

  @media (max-width: 809px) {
    [data-component='HomepageHero'] {
      overflow: hidden;
    }

    [data-component='HomepageHero'] .hero-network-bg {
      z-index: 0;
    }

    [data-component='HomepageHero'] .hero-network-svg {
      position: absolute;
      top: 8%;
      left: 0;
      width: 100%;
      max-width: none;
      transform: translateX(1vw) translateY(-6vh) rotate(-2deg) scale(1.55);
      transform-origin: 50% 52%;
    }
  }
</style>
