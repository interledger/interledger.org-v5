---
import { getCollection } from 'astro:content'
import FoundationPageLayout from '@/layouts/FoundationPageLayout.astro'
import TranslationDisclaimer from '@/components/shared/TranslationDisclaimer.astro'
import Breadcrumbs from '@/components/shared/Breadcrumbs.astro'
import FaqSections from '@/components/faq/FaqSections.astro'
import {
  type Locale,
  useTranslations,
  buildSectionEntryBreadcrumbs
} from '@/utils'

interface Props {
  slug: string
  contentLocale: Locale
  isFallback?: boolean
}

const { slug, contentLocale, isFallback = false } = Astro.props
const { routeLocale } = Astro.locals
const t = useTranslations(routeLocale)

const allFaqs = await getCollection('faqs')
const entry = allFaqs.find(
  (f) => f.data.pathSlug === slug && f.data.locale === contentLocale
)

if (!entry) throw new Error(`Faq not found: ${slug} (${contentLocale})`)

const { title, heading, description, introParagraph, faqSections } = entry.data

const breadcrumbs = buildSectionEntryBreadcrumbs(
  entry.data.pathSlug,
  entry.data.section,
  heading,
  routeLocale,
  t('nav.home')
)
---

<FoundationPageLayout
  title={title}
  description={description}
  headerTheme="light"
>
  <main
    class="flex flex-col px-lg pt-[calc(var(--spacing-6xl)-var(--site-header-height))] pb-6xl tablet:px-xl desktop:px-5xl desktop:pt-[calc(var(--spacing-7xl)-var(--site-header-height-desktop))] desktop:pb-7xl"
  >
    <TranslationDisclaimer isVisible={isFallback} />
    <div class="mx-auto max-w-content">
      <Breadcrumbs breadcrumbs={breadcrumbs} />
      <h1
        class="text-neutral-900 text-h2 tablet:text-h2-md desktop:text-h2-lg mt-xl tablet:mt-3xl"
      >
        {heading}
      </h1>
      {
        introParagraph && (
          <section
            aria-label={t('faq.introduction')}
            class="mt-xl tablet:mt-3xl"
          >
            <p class="text-neutral-100 text-h4 tablet:text-h4-md desktop:text-h5-lg">
              {introParagraph}
            </p>
          </section>
        )
      }
      <section class="mt-4xl desktop:mt-6xl">
        <FaqSections sections={faqSections} uiLocale={routeLocale} />
      </section>
    </div>
  </main>
</FoundationPageLayout>
