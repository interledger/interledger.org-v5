---
import {
  type Locale,
  parseMarkdown,
  useTranslations,
  localizeRoute
} from '@/utils'
import { getCollection, render } from 'astro:content'
import FoundationPageLayout from '@/layouts/FoundationPageLayout.astro'
import PageHero from '@/components/shared/PageHero.astro'
import CtaStrip from '@/components/blocks/CtaStrip.astro'
import InfoCards from '@/components/blocks/InfoCards.astro'
import ProfileGrid from '@/components/shared/ProfileGrid.astro'
import LogoCarousel from '@/components/blocks/LogoCarousel.astro'
import GrantFaqSection from '@/components/grant/GrantFaqSection.astro'
import LinkButton from '@/components/shared/LinkButton.astro'
import Icon from '@/components/shared/Icon.astro'
import TranslationDisclaimer from '@/components/shared/TranslationDisclaimer.astro'
import Paragraph from '@/components/blocks/Paragraph.astro'
import SplitLayout from '@/components/blocks/SplitLayout.astro'
import BlockquoteBlock from '@/components/blocks/BlockquoteBlock.astro'
import CalloutTextBlock from '@/components/blocks/CalloutTextBlock.astro'
import VideoEmbedBlock from '@/components/blocks/VideoEmbedBlock.astro'
import ImageBlock from '@/components/blocks/ImageBlock.astro'
import CtaLink from '@/components/blocks/CtaLink.astro'

interface Props {
  slug: string
  contentLocale: Locale
  isFallback?: boolean
}

const { slug, contentLocale, isFallback = false } = Astro.props
const pages = await getCollection('grant-pages')

const mdxPage = pages.find(
  (page) => page.data.pathSlug === slug && page.data.locale === contentLocale
)

if (!mdxPage) return Astro.redirect('/404')

const { Content: MdxContent } = await render(mdxPage)
const {
  title,
  description,
  heroTitle,
  heroDescription,
  heroImage,
  heroImageAlt,
  heroImageMobile,
  heroImageMobileAlt,
  heroCtas,
  metaImage,
  canonicalUrl,
  primaryCta,
  faqSection,
  ctaStrip,
  infoCards,
  programOverview
} = mdxPage.data

const programOverviewHtml = programOverview
  ? await parseMarkdown(programOverview, {
      pathname: Astro.url.pathname,
      lang: contentLocale
    })
  : null
const t = useTranslations(contentLocale)

const resolvedHeroTitle = heroTitle?.trim() || title

const breadcrumbs = [
  { name: t('nav.home'), href: localizeRoute('', contentLocale) },
  { name: t('nav.grants'), href: localizeRoute('grant', contentLocale) },
  {
    name: resolvedHeroTitle,
    href: localizeRoute(`grant/${slug}`, contentLocale)
  }
]
---

<FoundationPageLayout
  title={title}
  description={description}
  ogImageUrl={metaImage}
  canonicalURL={canonicalUrl}
>
  <main class="pb-3xl">
    <TranslationDisclaimer isVisible={isFallback} />

    <PageHero
      title={resolvedHeroTitle}
      description={heroDescription ?? description}
      image={heroImage}
      imageAlt={heroImageAlt}
      imageMobile={heroImageMobile}
      imageMobileAlt={heroImageMobileAlt}
      cta={heroCtas?.[0]}
      breadcrumbs={breadcrumbs}
    />
    {
      programOverviewHtml && (
        <section class="pt-4xl">
          <div class="mx-auto max-w-content px-4 min-w-90 tablet:px-xl desktop:max-w-content">
            <div data-prose set:html={programOverviewHtml} />
          </div>
        </section>
      )
    }

    {
      primaryCta && (
        <section class="">
          <div class="mx-auto max-w-content px-4 min-w-90 tablet:px-xl desktop:max-w-content">
            <LinkButton
              href={primaryCta.link}
              variant="primary"
              external={primaryCta.external}
            >
              {primaryCta.text}
              <Icon name="arrow-right" slot="icon-right" />
            </LinkButton>
          </div>
        </section>
      )
    }

    {
      infoCards && (
        <section class="py-4xl">
          <InfoCards heading={infoCards.heading} cards={infoCards.cards} />
        </section>
      )
    }

    <section class="tablet:py-4xl">
      <div
        class="mx-auto max-w-content px-4 min-w-90 tablet:px-xl desktop:max-w-content"
      >
        <div data-prose>
          <MdxContent
            components={{
              Paragraph,
              SplitLayout,
              Blockquote: BlockquoteBlock,
              CalloutText: CalloutTextBlock,
              VideoEmbed: VideoEmbedBlock,
              ImageBlock,
              CtaStrip,
              ProfileGrid,
              LogoCarousel,
              CtaLink
            }}
          />
        </div>
      </div>
    </section>

    {
      faqSection && (
        <section class="pt-0 pb-4xl px-lg tablet:py-4xl tablet:px-xl">
          <GrantFaqSection {...faqSection} />
        </section>
      )
    }

    <section class="tablet:py-4xl">
      <div
        class="mx-auto px-lg max-w-content min-w-90 tablet:px-xl desktop:px-0 desktop:max-w-content"
      >
        <CtaStrip
          heading={ctaStrip.heading}
          description={ctaStrip.description}
          primaryButtonText={ctaStrip.buttonText}
          primaryButtonLink={ctaStrip.buttonLink}
          color={ctaStrip.color}
          secondaryButtonText={ctaStrip.secondaryButtonText}
          secondaryButtonLink={ctaStrip.secondaryButtonLink}
        />
      </div>
    </section>
  </main>
</FoundationPageLayout>
