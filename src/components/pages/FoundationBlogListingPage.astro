---
import type { Page } from 'astro'
import { getCollection } from 'astro:content'
import FoundationPageLayout from '@/layouts/FoundationPageLayout.astro'
import BlogIndexFoundation from '@/components/blog/BlogIndexFoundation.astro'
import {
  stripPagination,
  COLLECTION_INDEX_SLUG,
  translatePath,
  translateTerm,
  getFeaturedPosts,
  useTranslations,
  localizeRoute
} from '@/utils'
import type { Locale } from '@/utils'
import FeaturedPosts from '@/components/blog/FeaturedPosts.astro'
import Pagination from '@/components/shared/Pagination.astro'
import Breadcrumbs from '@/components/shared/Breadcrumbs.astro'
import CtaStrip from '@/components/blocks/CtaStrip.astro'

interface Props {
  page: Page
  totalEntries: number
  allTerms: string[]
  enabledTerms: string[]
  selectedTerm?: string
  contentLang: Locale
  isTermFallback?: boolean
}

const {
  page,
  totalEntries,
  allTerms,
  enabledTerms,
  selectedTerm,
  contentLang,
  isTermFallback
} = Astro.props
const { routeLocale } = Astro.locals
const t = useTranslations(routeLocale)
const basePath = stripPagination(Astro.url.pathname)
const blogPath = translatePath(
  'foundation-blog',
  routeLocale,
  COLLECTION_INDEX_SLUG
)
const subscribePath = translatePath(
  'foundation-pages',
  routeLocale,
  'subscribe'
)
const breadcrumbs = [
  { name: t('nav.home'), href: localizeRoute('', routeLocale) },
  { name: t('blog.foundation.title'), href: blogPath }
]
const translatedTerm = selectedTerm
  ? translateTerm('blog.categories', selectedTerm, t)
  : undefined
const title = translatedTerm
  ? t('blog.foundation.tag_title', { tag: translatedTerm })
  : t('blog.foundation.title')
const description = translatedTerm
  ? t('blog.foundation.tag_description', { tag: translatedTerm })
  : t('blog.foundation.description')

// Featured posts only show on the bare blog index (first page, no filters).
// Suppressed by any active category/tag filter (including /category/all) or explicit lang filter.
const hasLangFilter = Astro.url.pathname.includes('/lang/')
const hasTermFilter =
  Astro.url.pathname.includes('/category/') ||
  Astro.url.pathname.includes('/tag/')
const showFeatured =
  !selectedTerm && !hasTermFilter && !hasLangFilter && page.currentPage === 1
const featuredPosts = showFeatured
  ? getFeaturedPosts(
      await getCollection(
        'foundation-blog',
        ({ data }) => data.locale === routeLocale
      )
    )
  : []
---

<FoundationPageLayout
  title={title}
  description={description}
  ogImageUrl={new URL('/img/og-blog.png', Astro.site).href}
>
  <main
    class="flex flex-col px-lg pt-[calc(var(--spacing-5xl)-var(--site-header-height))] pb-5xl tablet:px-xl tablet:pt-[calc(var(--spacing-6xl)-var(--site-header-height))] tablet:pb-6xl desktop:px-5xl desktop:pt-[calc(var(--spacing-7xl)-var(--site-header-height-desktop))] desktop:pb-7xl"
  >
    <div class="w-full max-w-content m-auto">
      <Breadcrumbs breadcrumbs={breadcrumbs} />
      <BlogIndexFoundation
        posts={page.data || []}
        totalEntries={totalEntries}
        allTerms={allTerms}
        selectedTerm={selectedTerm}
        enabledTerms={enabledTerms}
        blogIndexHref={blogPath}
        contentLang={contentLang}
        isTermFallback={isTermFallback}
      >
        {
          featuredPosts.length > 0 && (
            <div class="flex flex-col gap-4xl desktop:gap-5xl" slot="featured">
              <FeaturedPosts posts={featuredPosts} />
              <CtaStrip
                heading={t('blog.cta.heading')}
                description={t('blog.cta.description')}
                primaryButtonText={t('blog.cta.link_text')}
                primaryButtonLink={subscribePath}
              />
            </div>
          )
        }
      </BlogIndexFoundation>
      <Pagination
        baseUrl={basePath}
        length={page.lastPage}
        currentPage={page.currentPage}
        prevUrl={page.url.prev}
        nextUrl={page.url.next}
        label={title}
        class="mt-3xl tablet:mt-4xl desktop:mt-5xl"
      />
    </div>
  </main>
</FoundationPageLayout>
