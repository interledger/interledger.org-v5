---
import { COLLECTION_INDEX_SLUG, translatePath, type Locale } from '@/utils'
import { getCollection, render } from 'astro:content'
import CommunityLinksFoundation from '@/components/blog/CommunityLinksFoundation.astro'
import ArticleTags from '@/components/blog/ArticleTags.astro'
import ArticleBio from '@/components/blog/ArticleBio.astro'
import FoundationBlogLayout from '@/layouts/FoundationBlogLayout.astro'
import Ambassador from '@/components/shared/Ambassador.astro'
import AmbassadorGrid from '@/components/shared/AmbassadorGrid.astro'
import Blockquote from '@/components/shared/Blockquote.astro'
import CalloutText from '@/components/shared/CalloutText.astro'
import Paragraph from '@/components/blocks/Paragraph.astro'
import PdfEmbed from '@/components/shared/PdfEmbed.astro'
import VideoEmbed from '@/components/shared/VideoEmbed.astro'
import TranslationDisclaimer from '@/components/shared/TranslationDisclaimer.astro'
import OptimizedImage from '@/components/shared/OptimizedImage.astro'

interface Props {
  slug: string
  contentLocale: Locale
  isFallback?: boolean
}

const { slug, contentLocale, isFallback = false } = Astro.props
const { routeLocale } = Astro.locals
const posts = await getCollection('foundation-blog')

const mdxPost = posts.find(
  (post) => post.data.pathSlug === slug && post.data.locale === contentLocale
)

if (!mdxPost) return Astro.redirect('/404')

const { Content: MdxContent } = await render(mdxPost)
const mdxData = mdxPost.data
const blogPath = translatePath(
  'foundation-blog',
  routeLocale,
  COLLECTION_INDEX_SLUG
)
---

<FoundationBlogLayout frontmatter={mdxData}>
  <Fragment slot="disclaimer">
    <TranslationDisclaimer isVisible={isFallback} />
  </Fragment>
  <MdxContent
    components={{
      img: OptimizedImage,
      Ambassador,
      AmbassadorGrid,
      Blockquote,
      CalloutText,
      Paragraph,
      PdfEmbed,
      VideoEmbed
    }}
  />

  <CommunityLinksFoundation />

  {
    mdxData?.articleBios?.map((bio) => {
      if (!bio.text) return
      return (
        <ArticleBio
          text={bio.text}
          imageUrl={bio.image}
          imageAlt={bio.imageAlt ?? bio.author}
        />
      )
    })
  }

  {
    mdxData?.tags?.length > 0 && (
      <ArticleTags tags={mdxData.tags} path={blogPath} />
    )
  }
</FoundationBlogLayout>
