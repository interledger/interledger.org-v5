---
import { getCollection, render } from 'astro:content'
import FoundationPageLayout from '@/layouts/FoundationPageLayout.astro'
import Breadcrumbs from '@/components/shared/Breadcrumbs.astro'
import TranslationDisclaimer from '@/components/shared/TranslationDisclaimer.astro'
import Paragraph from '@/components/blocks/Paragraph.astro'
import {
  type Locale,
  useTranslations,
  buildSectionEntryBreadcrumbs
} from '@/utils'

interface Props {
  slug: string
  contentLocale: Locale
  isFallback?: boolean
}

const { slug, contentLocale, isFallback = false } = Astro.props
const { routeLocale } = Astro.locals
const t = useTranslations(routeLocale)

const pages = await getCollection('hackathon-pages')
const entry = pages.find(
  (page) => page.data.pathSlug === slug && page.data.locale === contentLocale
)

if (!entry) return Astro.redirect('/404')

const { Content: MdxContent } = await render(entry)
const { title, description } = entry.data

// hackathon-pages is a fixed-section collection (no `section` frontmatter
// field, unlike the cross-section faq/report/profile collections) — every
// entry belongs to the hackathon microsite, so the section is hardcoded here.
const breadcrumbs = buildSectionEntryBreadcrumbs(
  entry.data.pathSlug,
  'hackathon',
  title,
  routeLocale,
  t('nav.home')
)
---

<FoundationPageLayout
  title={title}
  description={description}
  headerTheme="light"
>
  <main
    class="flex flex-col px-lg pt-[calc(var(--spacing-5xl)-var(--site-header-height))] pb-5xl tablet:px-xl tablet:pt-[calc(var(--spacing-6xl)-var(--site-header-height))] tablet:pb-6xl desktop:px-5xl desktop:pt-[calc(var(--spacing-7xl)-var(--site-header-height-desktop))] desktop:pb-7xl"
  >
    <TranslationDisclaimer isVisible={isFallback} />
    <div class="mx-auto max-w-content">
      <Breadcrumbs breadcrumbs={breadcrumbs} />
      <h1
        class="mt-2xl text-h2 text-neutral-900 tablet:text-h2-md desktop:text-h2-lg"
      >
        {title}
      </h1>
      <section
        data-prose
        class="mt-2xl [&_h2]:mt-3xl [&_h2]:mb-xl [&_h2]:text-[1.75rem] [&_h2]:font-semibold [&_h3]:mt-2xl [&_h3]:mb-lg [&_h3]:text-[1.25rem] [&_h3]:font-semibold [&_p]:mb-xl [&_p]:leading-[1.6] [&_ul]:mb-xl [&_ul]:ps-2xl [&_li]:mb-lg [&_a]:underline [&_a:hover]:no-underline"
      >
        <MdxContent components={{ Paragraph }} />
      </section>
    </div>
  </main>
</FoundationPageLayout>
