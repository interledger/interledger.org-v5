---
import { useTranslations, defaultLocale } from '@/utils'
import FoundationPageLayout from '@/layouts/FoundationPageLayout.astro'

const { routeLocale } = Astro.locals
const langPrefix = routeLocale === defaultLocale ? '' : `/${routeLocale}`
const t = useTranslations(routeLocale)
---

<FoundationPageLayout
  title={t('contact.title')}
  description={t('contact.description')}
>
  <main class="pt-2xl pb-4xl">
    <div class="mx-auto max-w-[1440px] min-w-[360px] px-[5%] min-[1600px]:px-0">
      <header class="pt-xl pb-2xl">
        <h1 class="text-h2 font-bold">{t('contact.title')}</h1>
      </header>
      <div class="max-w-[640px]">
        <!-- Success message (shown via JS when ?success=true) -->
        <div
          id="success-message"
          class="hidden mb-3xl p-2xl rounded border border-green-400 bg-green-50 text-green-800"
        >
          <p class="font-semibold mb-s">
            {t('contact.success_message')}
          </p>
          <p>
            {t('contact.success_thanks')}
          </p>
        </div>

        <!-- Contact form -->
        <form
          id="contact-form"
          name="contact"
          method="POST"
          action={`${langPrefix}/contact?success=true`}
          data-netlify="true"
          data-netlify-honeypot="bot-field"
          data-netlify-recaptcha="true"
          class="flex flex-col gap-2xl"
        >
          <input type="hidden" name="form-name" value="contact" />

          <!-- Honeypot field (hidden from real users) -->
          <p class="hidden">
            <label>Don't fill this out: <input name="bot-field" /></label>
          </p>

          <div class="flex flex-col gap-s">
            <label for="name" class="font-semibold text-[0.95rem]"
              >{t('contact.name')}</label
            >
            <input
              id="name"
              type="text"
              name="name"
              required
              placeholder={t('contact.name.placeholder')}
              class="w-full rounded border border-[var(--sl-color-neutral-75-4)] bg-white px-lg py-s text-[1rem] outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors"
            />
          </div>

          <div class="flex flex-col gap-s">
            <label for="email" class="font-semibold text-[0.95rem]"
              >{t('contact.email')}</label
            >
            <input
              id="email"
              type="email"
              name="email"
              required
              placeholder={t('contact.email.placeholder')}
              class="w-full rounded border border-[var(--sl-color-neutral-75-4)] bg-white px-lg py-s text-[1rem] outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors"
            />
          </div>

          <div class="flex flex-col gap-s">
            <label for="topic" class="font-semibold text-[0.95rem]"
              >{t('contact.topic')}</label
            >
            <select
              id="topic"
              name="topic"
              required
              class="w-full rounded border border-[var(--sl-color-neutral-75-4)] px-lg py-s text-[1rem] outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors bg-white"
            >
              <option value="" disabled selected
                >{t('contact.topic.placeholder')}</option
              >
              <option value="Grants">{t('contact.topic.grants')}</option>
              <option value="Media">{t('contact.topic.media')}</option>
              <option value="Technology">{t('contact.topic.technology')}</option
              >
              <option value="Other">{t('contact.topic.other')}</option>
            </select>
          </div>

          <div class="flex flex-col gap-s">
            <label for="message" class="font-semibold text-[0.95rem]"
              >{t('contact.message')}</label
            >
            <textarea
              id="message"
              name="message"
              required
              rows="6"
              maxlength="3000"
              placeholder={t('contact.message.placeholder')}
              class="w-full rounded border border-[var(--sl-color-neutral-75-4)] bg-white px-lg py-s text-[1rem] outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors resize-y"
            ></textarea>
          </div>

          <div class="flex flex-col gap-s">
            <div data-netlify-recaptcha="true"></div>
            <p
              id="recaptcha-error"
              class="hidden text-red-600 text-sm"
              role="alert"
            >
              {t('contact.error.captcha')}
            </p>
          </div>

          <div class="flex flex-col gap-s">
            <p
              id="submit-error"
              class="hidden text-red-600 text-sm"
              role="alert"
            >
              {t('contact.error.submit')}
            </p>
            <div>
              <button
                type="submit"
                class="rounded-full bg-primary px-xl py-lg text-white font-semibold cursor-pointer hover:opacity-90 transition-opacity border-0"
              >
                {t('contact.submit')}
              </button>
            </div>
          </div>
        </form>
      </div>
    </div>
  </main>
</FoundationPageLayout>

<script>
  const params = new URLSearchParams(window.location.search)
  if (params.get('success') === 'true') {
    document.getElementById('success-message')?.classList.remove('hidden')
    document.getElementById('contact-form')?.classList.add('hidden')
  }

  document
    .getElementById('contact-form')
    ?.addEventListener('submit', async (e) => {
      e.preventDefault()
      const form = e.target as HTMLFormElement
      const recaptchaError = document.getElementById('recaptcha-error')
      const submitError = document.getElementById('submit-error')

      recaptchaError?.classList.add('hidden')
      submitError?.classList.add('hidden')

      if (!form.checkValidity()) {
        form.reportValidity()
        return
      }

      const recaptchaDone = !!(
        document.querySelector(
          'textarea[name="g-recaptcha-response"]'
        ) as HTMLTextAreaElement | null
      )?.value?.trim()
      if (!recaptchaDone) {
        recaptchaError?.classList.remove('hidden')
        recaptchaError?.scrollIntoView({ behavior: 'smooth', block: 'center' })
        return
      }

      try {
        const body = new URLSearchParams(
          new FormData(form) as unknown as Record<string, string>
        ).toString()
        const res = await fetch(form.action, {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body
        })
        if (!res.ok) throw new Error(`Submission failed: ${res.status}`)
        window.location.href = form.action
      } catch (err) {
        console.error(err)
        submitError?.classList.remove('hidden')
        submitError?.scrollIntoView({ behavior: 'smooth', block: 'center' })
      }
    })
</script>
