---
import FoundationPageLayout from '@/layouts/FoundationPageLayout.astro'
import OptimizedImage from '@/components/OptimizedImage.astro'
import LinkButton from '@/components/shared/LinkButton.astro'
import Icon from '@/components/shared/Icon.astro'
import {
  translatePath,
  useTranslations,
  buildUmamiAttrs,
  type Locale
} from '@/utils'

interface Props {
  pageLang: Locale
}

const { pageLang } = Astro.props
const t = useTranslations(pageLang)

const exploreTechHref = translatePath(
  'foundation-pages',
  pageLang,
  'developers'
)
const getInvolvedHref = translatePath(
  'foundation-pages',
  pageLang,
  'get-involved'
)

const heroUmami = (href: string, linkText: string) =>
  buildUmamiAttrs({
    pathname: Astro.url.pathname,
    lang: pageLang,
    section: 'hero',
    href,
    linkText
  })
---

<FoundationPageLayout
  title={t('site.title')}
  description={t('site.description')}
>
  <main>
    <section
      data-component="HomeHero"
      class="relative overflow-hidden bg-[#0a0a0a] text-white isolate"
      aria-labelledby="home-hero-title"
    >
      <div class="absolute inset-0 -z-10" aria-hidden="true">
        <OptimizedImage
          src="/img/homepage/stefan-thomas.webp"
          alt=""
          loading="eager"
          fetchpriority="high"
          sizes="(min-width: 1024px) 60vw, (min-width: 768px) 70vw, 100vw"
          class="absolute inset-0 h-full w-full object-cover object-[70%_center] opacity-40 md:opacity-100 md:object-right"
        />
        <div
          class="absolute inset-0 bg-linear-to-r from-[#0a0a0a] via-[#0a0a0a]/85 md:via-[#0a0a0a]/70 to-transparent"
        >
        </div>
      </div>

      <div
        class="mx-auto w-full max-w-wide px-space-m py-space-2xl md:py-space-3xl min-h-[80vh] flex items-center"
      >
        <div class="max-w-136 md:max-w-144 lg:max-w-160">
          <h1
            id="home-hero-title"
            class="font-semibold leading-[1.1] tracking-tight text-[clamp(2.25rem,1.4rem+3.2vw,4rem)]"
          >
            <span class="block">{t('home.hero.title_lead')}</span>
            <span class="block text-aqua-mint-100">
              {t('home.hero.title_accent')}
            </span>
          </h1>

          <p
            class="mt-space-m text-[1rem] md:text-[1.125rem] leading-relaxed text-white/85 max-w-136"
          >
            {t('home.hero.description')}
          </p>

          <div class="mt-space-l flex flex-wrap gap-space-s">
            <LinkButton
              href={exploreTechHref}
              {...heroUmami(exploreTechHref, t('home.cta.explore_tech'))}
            >
              {t('home.cta.explore_tech')}
              <Icon slot="icon-right" name="arrow-right" />
            </LinkButton>
            <LinkButton
              href={getInvolvedHref}
              variant="secondary"
              mode="dark"
              {...heroUmami(getInvolvedHref, t('home.cta.get_involved'))}
            >
              {t('home.cta.get_involved')}
            </LinkButton>
          </div>
        </div>
      </div>
    </section>
  </main>
</FoundationPageLayout>
