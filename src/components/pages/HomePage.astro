---
import FoundationPageLayout from '@/layouts/FoundationPageLayout.astro'
import HomepageHero from '@/components/pages/HomepageHero.astro'
import StatsSection, {
  type StatItem
} from '@/components/shared/StatsSection.astro'
import TextMediaSection from '@/components/shared/TextMediaSection.astro'
import VideoEmbed from '@/components/shared/VideoEmbed.astro'
import LinkButton from '@/components/shared/LinkButton.astro'
import OptimizedImage from '@/components/shared/OptimizedImage.astro'
import SmoothScroll from '@/components/shared/SmoothScroll.astro'
import { useTranslations, type Locale } from '@/utils'
import PillarsSection from '@/components/shared/PillarsSection.astro'
import LogoCarousel from '@/components/shared/LogoCarousel.astro'

interface Props {
  pageLang: Locale
}

const { pageLang } = Astro.props
const t = useTranslations(pageLang)

const stats: StatItem[] = [
  {
    value: 21,
    suffix: 'M+',
    label: t('home.stats.grants_label'),
    ariaLabel: t('home.stats.grants_aria')
  },
  {
    value: 300,
    suffix: '+',
    label: t('home.stats.projects_label'),
    ariaLabel: t('home.stats.projects_aria')
  },
  {
    value: 130,
    suffix: '+',
    label: t('home.stats.countries_label'),
    ariaLabel: t('home.stats.countries_aria')
  },
  {
    value: 1000,
    suffix: '+',
    label: t('home.stats.students_label'),
    ariaLabel: t('home.stats.students_aria')
  }
]
---

<FoundationPageLayout
  title={t('site.title')}
  description={t('site.description')}
>
  <SmoothScroll />
  <main>
    <HomepageHero pageLang={pageLang} pathname={Astro.url.pathname} />
    <TextMediaSection
      mediaSide="right"
      theme="dark"
      ariaLabel={t('home.problem.heading')}
      class="bg-royal-purple-100 tablet:bg-neutral-900 tablet:px-3xl-tight tablet:py-5xl"
      data-nav-dark
    >
      <h2 slot="heading">{t('home.problem.heading')}</h2>
      <p>{t('home.problem.body_1')}</p>
      <div
        slot="media"
        class="mx-auto flex w-full items-center overflow-hidden rounded-3xl bg-black tablet:w-[80%] desktop:mx-0 desktop:w-[512px]"
      >
        <VideoEmbed
          url="https://www.youtube.com/watch?v=oJNFsO3k7LM"
          title={t('home.problem.video_title')}
        />
      </div>
    </TextMediaSection>
    <PillarsSection />
    <TextMediaSection
      mediaSide="left"
      theme="light"
      ariaLabel={t('home.making_money_move.heading')}
      class="py-5xl tablet:py-3xl-tight"
    >
      <h2 slot="heading">{t('home.making_money_move.heading')}</h2>
      <p>{t('home.making_money_move.body_1')}</p>
      <p>{t('home.making_money_move.body_2')}</p>
      <LinkButton
        slot="cta"
        href="/about-us"
        variant="secondary"
        mode="light"
        size="lg"
        class="w-full tablet:w-auto tablet:mx-auto desktop:mx-0"
      >
        {t('home.making_money_move.cta_label')}
      </LinkButton>
      <img
        slot="media"
        src="/img/home/animated-path-vector.svg"
        width="426"
        height="431"
        alt={t('home.making_money_move.image_alt')}
        class="mx-auto h-auto w-full max-w-[426px] desktop:mx-0"
      />
    </TextMediaSection>
    <StatsSection ariaLabel={t('home.stats.heading')} stats={stats}>
      <Fragment slot="heading">{t('home.stats.heading')}</Fragment>
      <p>{t('home.stats.body')}</p>
    </StatsSection>
    <TextMediaSection
      mediaSide="right"
      theme="light"
      ariaLabel={t('home.independent_by_design.heading')}
    >
      <h2 slot="heading">{t('home.independent_by_design.heading')}</h2>
      <p>{t('home.independent_by_design.body_1')}</p>
      <p>{t('home.independent_by_design.body_2')}</p>
      <LinkButton
        slot="cta"
        href="/interledger"
        variant="secondary"
        mode="light"
        size="lg"
        class="w-full tablet:w-auto tablet:mx-auto desktop:mx-0"
      >
        {t('home.independent_by_design.cta_label')}
      </LinkButton>
      <OptimizedImage
        slot="media"
        src="/img/home/independent-by-design.png"
        width={426}
        height={427}
        alt={t('home.independent_by_design.image_alt')}
        sizes="(min-width: 1280px) 426px, (min-width: 768px) 40vw, 100vw"
        pictureClass="mx-auto block w-full max-w-[426px] tablet:w-[40%] desktop:w-auto desktop:mx-0"
        class="h-auto max-w-full"
      />
    </TextMediaSection>
    <LogoCarousel />
  </main>
</FoundationPageLayout>
