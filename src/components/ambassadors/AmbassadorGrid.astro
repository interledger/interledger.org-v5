---
/**
 * Ambassador Grid component
 *
 * Accepts one of three mutually exclusive props (checked in priority order):
 * 1. With ambassadors data: <AmbassadorGrid ambassadors={data} />
 * 2. With pathSlugs (fetches from collection): <AmbassadorGrid pathSlugs={["slug1", "slug2"]} />
 * 3. With category (fetches from collection): <AmbassadorGrid category="some-category" />
 *
 * Order is preserved from the input (pathSlugs array order or ambassadors array order).
 * This allows per-grid ordering via Strapi's relation field arrangement.
 */

import { getCollection } from 'astro:content'
import Ambassador from './Ambassador.astro'
import type { AmbassadorData } from './types'
import { useTranslations, toAmbassadorData } from '@/utils'

interface Props {
  ambassadors?: AmbassadorData[]
  pathSlugs?: string[]
  heading?: string
  category?: string
}

const {
  ambassadors: propAmbassadors,
  pathSlugs,
  heading,
  category
} = Astro.props
const { routeLocale } = Astro.locals
const t = useTranslations(routeLocale)

let ambassadors: AmbassadorData[] = []

if (propAmbassadors) {
  // Use provided ambassador data directly
  ambassadors = propAmbassadors
} else if (pathSlugs && pathSlugs.length > 0) {
  // Fetch ambassadors by pathSlugs from the content collection
  const allAmbassadors = await getCollection('ambassadors')
  const filtered = allAmbassadors.filter((entry) =>
    pathSlugs.includes(entry.data.pathSlug)
  )

  // Maintain the order from the pathSlugs array (reflects Strapi relation order)
  ambassadors = pathSlugs
    .map((pathSlug) =>
      filtered.find((entry) => entry.data.pathSlug === pathSlug)
    )
    .filter((entry): entry is NonNullable<typeof entry> => entry !== undefined)
    .map((entry) => toAmbassadorData(entry.data))
} else if (category) {
  // Fetch ambassadors by category from the content collection
  const allAmbassadors = await getCollection('ambassadors')
  ambassadors = allAmbassadors
    .filter(
      (entry) =>
        entry.data.category === category && entry.data.locale === routeLocale
    )
    .map((entry) => toAmbassadorData(entry.data))
}
---

{
  ambassadors.length > 0 ? (
    <section aria-label={t('ambassadors.ambassadors')}>
      {heading && <h2 class="mb-space-s">{heading}</h2>}
      <div class="ambassadors-wrapper grid grid-cols-[repeat(auto-fill,minmax(8em,1fr))] gap-space-s">
        {ambassadors.map((ambassador) => (
          <Ambassador
            name={ambassador.name}
            pathSlug={ambassador.pathSlug}
            photo={ambassador.photo || undefined}
            photoAlt={ambassador.photoAlt ?? ambassador.name}
            quote={ambassador.quote || undefined}
          />
        ))}
      </div>
    </section>
  ) : (
    <p class="text-gray">{t('ambassadors.no_ambassadors')}</p>
  )
}

<style>
  /* Additional styles for non-last ambassadors in mobile view */
  @media screen and (max-width: 1139px) {
    .ambassadors-wrapper > :global(article:not(:last-of-type)) {
      margin-block-end: var(--spacing-space-s, 1.125rem);
    }
  }
</style>
