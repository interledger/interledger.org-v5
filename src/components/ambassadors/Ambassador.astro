---
import OptimizedImage from '../OptimizedImage.astro'
import { defaultLocale, buildUmamiAttrs } from '@/utils'

interface Props {
  name: string
  pathSlug: string
  photo?: string
  photoAlt?: string
  quote?: string
  umamiContext?: string
}

const { name, pathSlug, photo, photoAlt, quote, umamiContext } = Astro.props
const { routeLocale } = Astro.locals
const langPrefix = routeLocale === defaultLocale ? '' : `/${routeLocale}`
const fellowLink = `${langPrefix}/grant/fellowship/${pathSlug}`

const umamiBase = {
  page: umamiContext,
  pathname: Astro.url.pathname,
  lang: routeLocale,
  section: 'card' as const
}
---

<article>
  <a
    href={fellowLink}
    class="text-black no-underline"
    {...buildUmamiAttrs({
      ...umamiBase,
      href: fellowLink,
      linkText: `${name} Fellow profile`
    })}
  >
    {
      photo && (
        <OptimizedImage
          src={photo}
          alt={photoAlt ?? name}
          width={240}
          height={240}
          loading="lazy"
          sizes="240px"
          class="ambassador__img rounded-none w-full sm:w-auto max-w-[150px]"
        />
      )
    }
    <div class="max-w-100">
      <h3
        class="text-step-0 font-bold underline decoration-inherit text-primary transition-colors duration-300 hover:decoration-transparent"
      >
        {name}
      </h3>
      {quote && <p class="text-step--1 italic">{quote}</p>}
    </div>
  </a>
</article>
