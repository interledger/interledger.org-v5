---
import { useTranslations } from '@/utils'
import { buildUmamiAttrs } from '@/utils/umami'

const {
  baseUrl,
  length,
  currentPage,
  firstUrl,
  prevUrl,
  nextUrl,
  lastUrl,
  label
} = Astro.props
const { routeLocale } = Astro.locals
const t = useTranslations(routeLocale)
const paginationList = Array.from({ length }, (_, i) => i + 1)

const pageAttrs = (action: string, ariaLabel: string) =>
  buildUmamiAttrs({
    pathname: Astro.url.pathname,
    lang: routeLocale,
    section: 'cta',
    ariaLabel,
    action
  })
---

<nav
  aria-label={t('pagination.pages', { label })}
  class="flex justify-center my-space-m"
>
  {
    firstUrl ? (
      <a
        href={`${firstUrl}`}
        aria-label={t('pagination.first')}
        class="px-space-s py-space-xs"
        {...pageAttrs('pagination_first', t('pagination.first'))}
      >
        &#171;
      </a>
    ) : (
      <span class="px-space-s py-space-xs opacity-50 cursor-not-allowed">
        &#171;
      </span>
    )
  }

  {
    prevUrl ? (
      <a
        href={`${prevUrl}`}
        aria-label={t('pagination.previous')}
        class="px-space-s py-space-xs"
        {...pageAttrs('pagination_prev', t('pagination.previous'))}
      >
        &#8249;
      </a>
    ) : (
      <span class="px-space-s py-space-xs opacity-50 cursor-not-allowed">
        &#8249;
      </span>
    )
  }

  {
    paginationList.map((num) => (
      <a
        href={`${baseUrl}${num == 1 ? '' : '/' + num}`}
        class={`px-space-s py-space-xs ${currentPage == num ? 'text-primary-fallback pointer-events-none' : ''}`}
        {...pageAttrs(`pagination_${num}`, `${t('pagination.pages', { label })} ${num}`)}
      >
        {num}
      </a>
    ))
  }

  {
    !nextUrl ? (
      <span class="px-space-s py-space-xs opacity-50 cursor-not-allowed">
        &#8250;
      </span>
    ) : (
      <a
        href={`${nextUrl}`}
        aria-label={t('pagination.next')}
        class="px-space-s py-space-xs"
        {...pageAttrs('pagination_next', t('pagination.next'))}
      >
        &#8250;
      </a>
    )
  }

  {
    lastUrl ? (
      <a
        href={`${lastUrl}`}
        aria-label={t('pagination.last')}
        class="px-space-s py-space-xs"
        {...pageAttrs('pagination_last', t('pagination.last'))}
      >
        &#187;
      </a>
    ) : (
      <span class="px-space-s py-space-xs opacity-50 cursor-not-allowed">
        &#187;
      </span>
    )
  }
</nav>
