---
import {
  useTranslations,
  buildUmamiAttrs,
  twMerge,
  getVisiblePages
} from '@/utils'
import Icon from './Icon.astro'

interface Props {
  baseUrl: string
  length: number
  currentPage: number
  prevUrl?: string
  nextUrl?: string
  label: string
  class?: string
}
const {
  baseUrl,
  length,
  currentPage,
  prevUrl,
  nextUrl,
  label,
  class: className
} = Astro.props
const { routeLocale } = Astro.locals
const t = useTranslations(routeLocale)

const pages = getVisiblePages(currentPage, length)

const pageAttrs = (action: string, ariaLabel: string) =>
  buildUmamiAttrs({
    pathname: Astro.url.pathname,
    lang: routeLocale,
    section: 'cta',
    ariaLabel,
    action
  })
const paginationClasses = twMerge('flex justify-center', className)
const linkClasses = `px-space-s py-space-xs 
[&[aria-current='page']]:border [&[aria-current='page']]:border-primary [&[aria-current='page']]:pointer-events-none
[&[aria-disabled='true']]:cursor-not-allowed [&[aria-disabled='true']]:opacity-50
`
---

<nav aria-label={t('pagination.pages', { label })} class={paginationClasses}>
  <ul>
    <li>
      <a
        href={prevUrl}
        aria-disabled={!prevUrl || undefined}
        aria-label={t('pagination.previous')}
        class={linkClasses}
        {...pageAttrs('pagination_prev', t('pagination.previous'))}
      >
        <Icon name="arrow-right-keyboard" class="rotate-180" />
      </a>
    </li>
    {
      pages.map((page) =>
        page === '...' ? (
          <li>
            <span class="px-space-s py-space-xs" aria-hidden="true">
              &hellip;
            </span>
          </li>
        ) : (
          <li>
            <a
              href={`${baseUrl}${page === 1 ? '' : '/' + page}`}
              aria-current={currentPage === page ? 'page' : undefined}
              aria-label={t('pagination.page', { number: page })}
              class={linkClasses}
              {...pageAttrs(
                `pagination_${page}`,
                `${t('pagination.pages', { label })} ${page}`
              )}
            >
              {page}
            </a>
          </li>
        )
      )
    }
    <li>
      <a
        href={nextUrl}
        aria-disabled={!nextUrl || undefined}
        aria-label={t('pagination.next')}
        class={linkClasses}
        {...pageAttrs('pagination_next', t('pagination.next'))}
      >
        <Icon name="arrow-right-keyboard" />
      </a>
    </li>
  </ul>
</nav>
