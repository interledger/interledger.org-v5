---
import OptimizedImage from '@/components/shared/OptimizedImage.astro'
import LinkButton from '@/components/shared/LinkButton.astro'
import Icon from '@/components/shared/Icon.astro'
import Breadcrumbs from '@/components/shared/Breadcrumbs.astro'

interface HeroCta {
  text: string
  link: string
  style?: 'primary' | 'secondary'
  external?: boolean
}

interface BreadcrumbItem {
  name: string
  href: string
}

interface Props {
  title: string
  description?: string | null
  /** Desktop hero image URL. Recommended: 1440×600px. */
  image?: string | null
  imageAlt?: string | null
  /** Optional mobile hero image. Recommended: 768×480px. Falls back to desktop image. */
  imageMobile?: string | null
  imageMobileAlt?: string | null
  cta?: HeroCta | null
  breadcrumbs?: BreadcrumbItem[]
}

const {
  title,
  description,
  image,
  imageAlt,
  imageMobile,
  imageMobileAlt,
  cta,
  breadcrumbs
} = Astro.props
---

<!-- White content section -->
<div
  class="bg-white px-lg pt-[calc(var(--spacing-5xl)-var(--site-header-height))] pb-3xl tablet:px-xl tablet:pt-[calc(var(--spacing-6xl)-var(--site-header-height))] tablet:pb-5xl desktop:px-5xl desktop:pt-[calc(var(--spacing-7xl)-var(--site-header-height-desktop))]"
>
  <div class="mx-auto max-w-wide">
    {
      breadcrumbs && breadcrumbs.length > 0 && (
        <div class="mb-2xl tablet:mb-3xl">
          <Breadcrumbs breadcrumbs={breadcrumbs} />
        </div>
      )
    }

    <h1
      class="text-h2 tablet:text-h2-md desktop:text-h2-lg text-neutral-900 mb-2xl max-w-[14em] tablet:mb-3xl"
    >
      {title}
    </h1>

    {
      description && (
        <p class="text-h4 tablet:text-h4-md desktop:text-h4-lg text-neutral-700 font-normal max-w-[42em] mb-xl tablet:mb-lg">
          {description}
        </p>
      )
    }
    {
      cta && (
        <LinkButton
          href={cta.link}
          variant={cta.style === 'secondary' ? 'secondary' : 'primary'}
          external={cta.external}
          class="w-full tablet:w-auto"
        >
          {cta.text}
          <Icon name="arrow-right" slot="icon-right" />
        </LinkButton>
      )
    }
  </div>
</div>

<!-- Full-width parallax image strip -->
{
  (image || imageMobile) && (
    <div class="parallax-wrapper relative overflow-hidden h-[30vh] tablet:h-[70vh]">
      {imageMobile ? (
        <>
          <OptimizedImage
            src={imageMobile}
            alt={imageMobileAlt ?? ''}
            width={768}
            height={480}
            loading="eager"
            fetchpriority="high"
            class="parallax-img block tablet:hidden absolute inset-x-0 top-[-15%] h-[130%] w-full object-cover"
          />
          <OptimizedImage
            src={image ?? imageMobile!}
            alt={imageAlt ?? imageMobileAlt ?? ''}
            width={1440}
            height={640}
            loading="eager"
            fetchpriority="high"
            class="parallax-img hidden tablet:block absolute inset-x-0 top-[-15%] h-[130%] w-full object-cover"
          />
        </>
      ) : (
        <OptimizedImage
          src={image}
          alt={imageAlt ?? ''}
          width={1440}
          height={640}
          loading="eager"
          fetchpriority="high"
          class="parallax-img absolute inset-x-0 top-[-15%] h-[130%] w-full object-cover"
        />
      )}
    </div>
  )
}

<script>
  // Custom scroll-linked parallax: the frame scrolls at normal (page) speed,
  // the image trails behind at PARALLAX_SPEED of that — e.g. 0.75 means the
  // image moves 75% as far as the page scrolls, so it visually lags behind
  // the frame. The image is rendered 130% of the frame's height (see markup
  // above) so the 30%-of-frame-height slack (15% top, 15% bottom) never runs
  // out mid-scroll. Tune PARALLAX_SPEED against the live site (target 0.7–0.8).
  const PARALLAX_SPEED = 0.75

  // Only ever one hero per page.
  const wrapper = document.querySelector<HTMLElement>('.parallax-wrapper')
  const prefersReducedMotion = window.matchMedia(
    '(prefers-reduced-motion: reduce)'
  ).matches

  if (wrapper && !prefersReducedMotion) {
    const images = wrapper.querySelectorAll<HTMLElement>('.parallax-img')
    let ticking = false

    const updateParallax = () => {
      const rect = wrapper.getBoundingClientRect()
      const frameCenter = rect.top + rect.height / 2
      const viewportCenter = window.innerHeight / 2
      // Frame's slack is 30% of its own height (image is 130% tall),
      // split evenly above/below — this is the max the image can trail.
      const maxOffset = (rect.height * 0.3) / 2
      const offset = Math.max(
        -maxOffset,
        Math.min(
          maxOffset,
          (viewportCenter - frameCenter) * (1 - PARALLAX_SPEED)
        )
      )

      images.forEach((img) => {
        img.style.transform = `translateY(${offset}px)`
      })
      ticking = false
    }

    const onScrollOrResize = () => {
      if (ticking) return
      ticking = true
      window.requestAnimationFrame(updateParallax)
    }

    window.addEventListener('scroll', onScrollOrResize, { passive: true })
    window.addEventListener('resize', onScrollOrResize)
    updateParallax()
  }
</script>
