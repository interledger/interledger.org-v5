---
import OptimizedImage from '@/components/shared/OptimizedImage.astro'
import LinkButton from '@/components/shared/LinkButton.astro'
import Icon from '@/components/shared/Icon.astro'
import Breadcrumbs from '@/components/shared/Breadcrumbs.astro'

interface HeroCta {
  text: string
  link: string
  style?: string
  external?: boolean
}

interface BreadcrumbItem {
  name: string
  href: string
}

interface Props {
  title: string
  description?: string | null
  /** Desktop hero image URL. Recommended: 1440×600px. */
  image?: string | null
  imageAlt?: string | null
  /** Optional mobile hero image. Recommended: 768×480px. Falls back to desktop image. */
  imageMobile?: string | null
  imageMobileAlt?: string | null
  cta?: HeroCta | null
  breadcrumbs?: BreadcrumbItem[]
}

const {
  title,
  description,
  image,
  imageAlt,
  imageMobile,
  imageMobileAlt,
  cta,
  breadcrumbs
} = Astro.props
---

<!-- White content section -->
<div class="bg-white px-space-m py-space-xl">
  <div class="mx-auto max-w-wide">
    {
      breadcrumbs && breadcrumbs.length > 0 && (
        <div class="mb-space-m">
          <Breadcrumbs breadcrumbs={breadcrumbs} />
        </div>
      )
    }

    <h1
      class="text-h1 tablet:text-h1-md desktop:text-h1-lg text-neutral-900 font-semibold leading-[1.2] mb-space-m max-w-[14em]"
    >
      {title}
    </h1>

    {
      description && (
        <p class="text-h4 tablet:text-h4-md desktop:text-h4-lg text-neutral-700 font-normal max-w-[42em] mb-space-m">
          {description}
        </p>
      )
    }
    {
      cta && (
        <LinkButton
          href={cta.link}
          variant={cta.style === 'secondary' ? 'secondary' : 'primary'}
          external={cta.external}
        >
          {cta.text}
          <Icon name="arrow-right" slot="icon-right" />
        </LinkButton>
      )
    }
  </div>
</div>

<!-- Full-width parallax image strip -->
{
  (image || imageMobile) && (
    <div class="relative overflow-hidden h-[480px] tablet:h-[560px] desktop:h-[640px]">
      <div
        class="parallax-img absolute inset-0 will-change-transform scale-110"
        aria-hidden="true"
      >
        {imageMobile ? (
          <>
            <OptimizedImage
              src={imageMobile}
              alt={imageMobileAlt ?? ''}
              width={768}
              height={480}
              loading="eager"
              fetchpriority="high"
              class="block tablet:hidden w-full h-full object-cover"
            />
            <OptimizedImage
              src={image}
              alt={imageAlt ?? ''}
              width={1440}
              height={640}
              loading="eager"
              fetchpriority="high"
              class="hidden tablet:block w-full h-full object-cover"
            />
          </>
        ) : (
          <OptimizedImage
            src={image}
            alt={imageAlt ?? ''}
            width={1440}
            height={640}
            loading="eager"
            fetchpriority="high"
            class="w-full h-full object-cover"
          />
        )}
      </div>
    </div>
  )
}

<script>
  const prefersReducedMotion = window.matchMedia(
    '(prefers-reduced-motion: reduce)'
  ).matches

  if (!prefersReducedMotion) {
    const img = document.querySelector<HTMLElement>('.parallax-img')
    if (img) {
      const container = img.parentElement!
      // Max translateY shift as scroll progresses through the strip.
      const PARALLAX_STRENGTH = 40
      // Trailing-lerp factor: lower = more drift/fluidity, higher = snappier.
      const EASE = 0.08

      let currentY = 0
      let rafId = 0

      function tick() {
        const progress =
          (window.scrollY - container.offsetTop) / window.innerHeight
        const targetY = progress * -PARALLAX_STRENGTH
        currentY += (targetY - currentY) * EASE
        img.style.transform = `translateY(${currentY}%)`
        rafId = requestAnimationFrame(tick)
      }

      // Only run the loop while the strip is near the viewport.
      const observer = new IntersectionObserver(
        ([entry]) => {
          if (entry.isIntersecting) {
            if (!rafId) tick()
          } else {
            cancelAnimationFrame(rafId)
            rafId = 0
          }
        },
        { rootMargin: '20% 0px' }
      )
      observer.observe(container)
    }
  }
</script>
