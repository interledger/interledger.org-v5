---
import OptimizedImage from '@/components/shared/OptimizedImage.astro'
import LinkButton from '@/components/shared/LinkButton.astro'
import Icon from '@/components/shared/Icon.astro'
import Breadcrumbs from '@/components/shared/Breadcrumbs.astro'

interface HeroCta {
  text: string
  link: string
  style?: 'primary' | 'secondary'
  external?: boolean
}

interface BreadcrumbItem {
  name: string
  href: string
}

interface Props {
  title: string
  description?: string | null
  /** Desktop hero image URL, used in a scrolling parallax panel — upload larger than the display size so it can pan without pixelating. Recommended: ~4000×2500px, under 2MB, AVIF format. */
  image?: string | null
  imageAlt?: string | null
  /** Optional mobile image. Recommended: 768×480px. */
  imageMobile?: string | null
  imageMobileAlt?: string | null
  cta?: HeroCta | null
  breadcrumbs?: BreadcrumbItem[]
  /**
   * `wide` uses a shorter ~21:9 band on tablet+ so landscape heroes show more
   * horizontal content with object-cover. Default keeps the tall 70vh parallax band.
   */
  imageBand?: 'default' | 'wide'
}

const {
  title,
  description,
  image,
  imageAlt,
  imageMobile,
  imageMobileAlt,
  cta,
  breadcrumbs,
  imageBand = 'default'
} = Astro.props

const isWideBand = imageBand === 'wide'
const bandClass = isWideBand
  ? 'w-full h-[28vh] tablet:h-[min(55vh,calc(100vw*9/21))]'
  : 'w-full h-[30vh] tablet:h-[70vh]'
const parallaxPictureClass =
  'absolute inset-0 block h-full w-full overflow-hidden'
const parallaxImgClass = isWideBand
  ? 'parallax-img absolute inset-x-0 top-[-25%] h-[150%] w-full min-w-full object-cover object-center'
  : 'parallax-img absolute inset-x-0 top-[-40%] h-[180%] w-full object-cover'
---

<!-- White content section -->
<div
  class="mx-auto bg-white px-lg pt-[calc(var(--spacing-6xl)-var(--site-header-height))] pb-3xl tablet:px-xl tablet:pt-[calc(var(--spacing-6xl)-var(--site-header-height))] tablet:pb-5xl desktop:pt-[calc(var(--spacing-6xl)-var(--site-header-height-desktop))] desktop:max-w-content"
>
  <div class="mx-auto max-w-content">
    {
      breadcrumbs && breadcrumbs.length > 0 && (
        <div class="mb-xl tablet:mb-2xl">
          <Breadcrumbs
            breadcrumbs={breadcrumbs}
            class="[&_a]:text-body-sm-standard"
          />
        </div>
      )
    }

    <h1
      class="text-h1 tablet:text-h1-md desktop:text-h1-lg text-neutral-900 mb-2xl tablet:mb-3xl desktop:max-w-content"
    >
      {title}
    </h1>

    {
      description && (
        <p class="text-h4 tablet:text-h4-md desktop:text-h4-lg text-neutral-700 font-normal max-w-[42em] mb-xl tablet:mb-lg">
          {description}
        </p>
      )
    }
    {
      cta && (
        <LinkButton
          href={cta.link}
          variant={cta.style === 'secondary' ? 'secondary' : 'primary'}
          external={cta.external}
          class="w-full tablet:w-auto"
        >
          {cta.text}
          <Icon name="arrow-right" slot="icon-right" />
        </LinkButton>
      )
    }
  </div>
</div>

<!-- Parallax image: image is taller than the frame so we can pan as you scroll -->
{
  (image || imageMobile) && (
    <div
      class:list={[
        'parallax-wrapper relative w-full overflow-hidden bg-neutral-900',
        bandClass
      ]}
      data-image-band={imageBand}
    >
      {imageMobile ? (
        <>
          <OptimizedImage
            src={imageMobile}
            alt={imageMobileAlt ?? ''}
            width={768}
            height={480}
            loading="eager"
            fetchpriority="high"
            pictureClass={parallaxPictureClass}
            class:list={[parallaxImgClass, 'block tablet:hidden']}
          />
          <OptimizedImage
            src={image ?? imageMobile!}
            alt={imageAlt ?? imageMobileAlt ?? ''}
            width={1920}
            height={940}
            loading="eager"
            fetchpriority="high"
            pictureClass={parallaxPictureClass}
            class:list={[parallaxImgClass, 'hidden tablet:block']}
          />
        </>
      ) : (
        <OptimizedImage
          src={image}
          alt={imageAlt ?? ''}
          width={1920}
          height={940}
          loading="eager"
          fetchpriority="high"
          pictureClass={parallaxPictureClass}
          class={parallaxImgClass}
        />
      )}
    </div>
  )
}

<script>
  // Image is 180% of the frame height — extra height gives room to pan on scroll.
  // Progress tracks how far the hero has moved through the viewport (0 → 1).
  const wrapper = document.querySelector<HTMLElement>('.parallax-wrapper')
  const prefersReducedMotion = window.matchMedia(
    '(prefers-reduced-motion: reduce)'
  ).matches

  if (wrapper && !prefersReducedMotion) {
    const isWideBand = wrapper.dataset.imageBand === 'wide'
    const images = wrapper.querySelectorAll<HTMLElement>('.parallax-img')
    let ticking = false

    const updateParallax = () => {
      const rect = wrapper.getBoundingClientRect()
      const totalTransit = window.innerHeight + rect.height
      const progress = Math.max(
        0,
        Math.min(1, (window.innerHeight - rect.top) / totalTransit)
      )
      // Pan from neutral crop toward the top as the hero scrolls up the page.
      const maxOffset = isWideBand
        ? rect.height * 0.25
        : (rect.height * 0.8) / 2
      const offset = maxOffset * progress

      images.forEach((img) => {
        img.style.transform = `translateY(${offset}px)`
      })
      ticking = false
    }

    const onScrollOrResize = () => {
      if (ticking) return
      ticking = true
      window.requestAnimationFrame(updateParallax)
    }

    window.addEventListener('scroll', onScrollOrResize, { passive: true })
    window.addEventListener('resize', onScrollOrResize)
    updateParallax()
  }
</script>
