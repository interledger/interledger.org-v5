---
import type { Locale } from '@/utils/i18'

interface Props {
  locale: Locale
  isVisible?: boolean
  style?: 'foundation' | 'summit'
}

const { locale, isVisible = false, style = 'foundation' } = Astro.props

const disclaimerByLocale: Partial<Record<Locale, string>> = {
  es: 'Esta página aún no está disponible en español.'
}

const copy = disclaimerByLocale[locale]
const styleClass = {
  foundation: 'text-primary',
  summit: 'text-white/80'
}[style]
---

{
  isVisible && copy && (
    <section class="py-space-s" aria-label="Translation disclaimer">
      <div class="mx-auto w-full max-w-wide px-space-m">
        <p
          class={`translation-disclaimer max-w-fit px-space-s py-space-2xs text-step--1 ${styleClass}`}
        >
          {copy}
        </p>
      </div>
    </section>
  )
}
