---
import { useTranslations } from '@/utils/i18'

interface Props {
  isVisible?: boolean
  style?: 'foundation' | 'summit'
}

const { routeLocale } = Astro.locals
const t = useTranslations(routeLocale)
const { isVisible = false, style = 'foundation' } = Astro.props

const styleClass = {
  foundation: 'text-primary',
  summit: 'text-white/80'
}[style]
---

{
  isVisible && routeLocale === 'es' && (
    <section class="py-space-s" aria-label={t('translation.disclaimer_label')}>
      <div class="mx-auto w-full max-w-wide px-space-m">
        <p
          class={`translation-disclaimer max-w-fit px-space-s py-space-2xs text-step--1 ${styleClass}`}
        >
          {t('translation.disclaimer')}
        </p>
      </div>
    </section>
  )
}
