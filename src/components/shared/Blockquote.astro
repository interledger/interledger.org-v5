---
import { parseMarkdownInline } from '@/utils'

interface Props {
  source?: string
  /** Plain-text quote. If omitted, slot content is used (MDX usage). */
  quote?: string
  umamiContext?: string
}

const { source, quote, umamiContext } = Astro.props
const { routeLocale } = Astro.locals
const htmlSource = parseMarkdownInline(source, {
  page: umamiContext,
  pathname: Astro.url.pathname,
  lang: routeLocale
})
---

<div
  class="px-xl py-0 border-l-2 border-r-2 border-primary mb-xl [&_blockquote]:m-0 [&_blockquote]:border-0 [&_blockquote]:p-0 [&>p]:my-0"
>
  <blockquote class="text-h5 tablet:text-h5-md desktop:text-h5-lg">
    {quote ?? <slot />}
  </blockquote>
  {
    htmlSource && (
      <p class="my-0">
        — <cite class="text-body-lg-standard" set:html={htmlSource} />
      </p>
    )
  }
</div>

<!--
  Styling rendered HTML from set:html

  Since set:html injects raw HTML that doesn't receive Astro's scoped data
  attributes, we use :global() to target injected child elements while keeping
  the parent selector scoped to this component.
-->
<style>
  /* Reset inherited prose styles for rendered HTML inside cite */
  cite {
    font-weight: 200;
    font-style: normal;
  }

  cite :global(strong) {
    color: inherit;
    font-weight: 400;
    font-style: italic;
  }

  cite :global(em) {
    font-style: italic;
  }
</style>
