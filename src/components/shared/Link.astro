---
import { cva } from 'class-variance-authority'
import { buildUmamiAttrs, type UmamiSection } from '@/utils'

interface Props {
  href?: string
  text?: string
  /** `primary`: filled CTA + arrow. `secondary`: outline button. */
  style?: string
  /** `hero` switches secondary to the dark-background treatment. */
  variant?: 'hero' | 'default'
  external?: boolean
  /** Umami section context. Defaults to `cta` since this is a CTA-style button. */
  section?: UmamiSection
}

const {
  href,
  style,
  external,
  text,
  variant,
  section = 'cta'
} = Astro.props as Props
const { routeLocale } = Astro.locals

const isSecondary = style === 'secondary'

const linkVariants = cva(
  [
    'font-poppins text-body-sm-standard md:text-body-lg-standard font-medium',
    'inline-flex w-fit shrink-0 items-center justify-center gap-spacing-md rounded-cta border px-spacing-lg py-spacing-md no-underline transition-colors',
    'focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2'
  ],
  {
    variants: {
      style: {
        primary:
          'border-transparent bg-cta-primary text-white hover:bg-cta-primary-hover',
        secondary: ''
      },
      variant: {
        hero: '',
        default: ''
      }
    },
    compoundVariants: [
      {
        style: 'primary',
        variant: 'hero',
        class: 'focus-visible:ring-white focus-visible:ring-offset-transparent'
      },
      {
        style: 'primary',
        variant: 'default',
        class:
          'focus-visible:ring-neutral-900 focus-visible:ring-offset-neutral-0'
      },
      {
        style: 'secondary',
        variant: 'hero',
        class:
          'border-neutral-50 bg-transparent text-neutral-0 hover:border-neutral-0 hover:bg-white/[0.08] focus-visible:ring-neutral-0 focus-visible:ring-offset-transparent'
      },
      {
        style: 'secondary',
        variant: 'default',
        class:
          'border-neutral-900 bg-transparent text-neutral-900 hover:bg-neutral-900/[0.06] focus-visible:ring-neutral-900 focus-visible:ring-offset-neutral-0'
      }
    ],
    defaultVariants: {
      style: 'primary',
      variant: 'default'
    }
  }
)

const className = linkVariants({
  style: isSecondary ? 'secondary' : 'primary',
  variant: variant ?? 'default'
})

const umamiAttrs = buildUmamiAttrs({
  pathname: Astro.url.pathname,
  lang: routeLocale,
  section,
  linkText: text,
  href
})
---

<a
  href={href ?? ''}
  class={className}
  {...umamiAttrs}
  {...external && {
    target: '_blank',
    rel: 'noopener noreferrer'
  }}
>
  <span>{text ?? 'Click'}</span>
  {external ? <span class="sr-only"> (opens in a new tab)</span> : null}
  {
    !isSecondary && (
      <svg
        class="size-5 shrink-0"
        aria-hidden="true"
        width="20"
        height="20"
        viewBox="0 0 20 20"
        fill="none"
      >
        <path
          d="M4 10h12M11 5l5 5-5 5"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
      </svg>
    )
  }
</a>
