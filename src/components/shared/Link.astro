---
import { buildUmamiAttrs, type UmamiSection } from '@/utils'

interface Props {
  href?: string
  text?: string
  /** `primary`: filled CTA + arrow. `secondary`: outline button. */
  style?: string
  /** `hero` switches secondary to the dark-background treatment. */
  variant?: 'hero' | 'default'
  external?: boolean
  /** Umami section context. Defaults to `cta` since this is a CTA-style button. */
  section?: UmamiSection
}

const {
  href,
  style,
  external,
  text,
  variant,
  section = 'cta'
} = Astro.props as Props
const { routeLocale } = Astro.locals

const isSecondary = style === 'secondary'
const isHero = variant === 'hero'

const fontClasses =
  'font-poppins text-body-sm-standard md:text-body-lg-standard font-medium'

/* Padding tuned to Figma button assets: ~16px horizontal, ~10px vertical, with
   a 12px gap between label and trailing icon. Keep these in sync with
   CtaBanner.astro and HomePage.astro hero buttons. */
const buttonBase =
  'inline-flex w-fit shrink-0 items-center justify-center gap-spacing-md rounded-cta border px-spacing-lg py-spacing-md no-underline transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2'

const primaryLayout = `${buttonBase} border-transparent bg-cta-primary text-white hover:bg-cta-primary-hover`

const heroPrimaryClasses = `${primaryLayout} focus-visible:ring-white focus-visible:ring-offset-transparent`

const defaultPrimaryClasses = `${primaryLayout} focus-visible:ring-neutral-900 focus-visible:ring-offset-neutral-0`

const heroSecondaryLayout = `${buttonBase} border-neutral-50 bg-transparent text-neutral-0 hover:border-neutral-0 hover:bg-white/[0.08] focus-visible:ring-neutral-0 focus-visible:ring-offset-transparent`

const defaultSecondaryLayout = `${buttonBase} border-neutral-900 bg-transparent text-neutral-900 hover:bg-neutral-900/[0.06] focus-visible:ring-neutral-900 focus-visible:ring-offset-neutral-0`

function primaryClassesForVariant(): string {
  return `${fontClasses} ${isHero ? heroPrimaryClasses : defaultPrimaryClasses}`
}

function secondaryClassesForVariant(): string {
  return `${fontClasses} ${isHero ? heroSecondaryLayout : defaultSecondaryLayout}`
}

const className = isSecondary
  ? secondaryClassesForVariant()
  : primaryClassesForVariant()

const umamiAttrs = buildUmamiAttrs({
  pathname: Astro.url.pathname,
  lang: routeLocale,
  section,
  linkText: text,
  href
})
---

<a
  href={href ?? ''}
  class={className}
  {...umamiAttrs}
  {...external && {
    target: '_blank',
    rel: 'noopener noreferrer'
  }}
>
  <span>{text ?? 'Click'}</span>
  {external ? <span class="sr-only"> (opens in a new tab)</span> : null}
  {
    !isSecondary && (
      <svg
        class="size-5 shrink-0"
        aria-hidden="true"
        width="20"
        height="20"
        viewBox="0 0 20 20"
        fill="none"
      >
        <path
          d="M4 10h12M11 5l5 5-5 5"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
      </svg>
    )
  }
</a>
