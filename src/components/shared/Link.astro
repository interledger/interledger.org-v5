---
import { buildUmamiAttrs, type UmamiSection } from '@/utils/main/umami'

interface Props {
  href?: string
  text?: string
  style?: string
  variant?: 'hero' | 'default'
  external?: boolean
  /** Umami section context. Defaults to `cta` since this is a CTA-style button. */
  section?: UmamiSection
}

const {
  href,
  style,
  external,
  text,
  variant,
  section = 'cta'
} = Astro.props as Props
const { routeLocale } = Astro.locals

const classes: Record<string, string> = {
  'hero-primary':
    'inline-block w-fit rounded-pill bg-white text-primary font-semibold no-underline transition-colors hover:bg-white/90',
  'hero-secondary':
    'inline-block w-fit rounded-pill border-2 border-white text-white font-semibold no-underline transition-colors hover:bg-white/15',
  secondary:
    'inline-block w-fit rounded-pill bg-white/70 text-primary no-underline transition-colors hover:bg-white/90',
  primary:
    'inline-block w-fit rounded-pill bg-primary text-white no-underline transition-colors hover:bg-primary-hover'
}

const key =
  variant === 'hero'
    ? style === 'secondary'
      ? 'hero-secondary'
      : 'hero-primary'
    : style === 'secondary'
      ? 'secondary'
      : 'primary'

const umamiAttrs = buildUmamiAttrs({
  pathname: Astro.url.pathname,
  lang: routeLocale,
  section,
  linkText: text,
  href
})
---

<a
  href={href ?? ''}
  class={classes[key]}
  style={`padding: clamp(0.625rem, 0.56rem + 0.29vi, 0.8rem) clamp(1.25rem, 1.1rem + 0.65vi, 1.6rem);`}
  {...umamiAttrs}
  {...external && {
    target: '_blank',
    rel: 'noopener noreferrer'
  }}
  >{text ?? 'Click'}
  {
    external && (
      <svg
        class="inline-block h-[0.75em] w-[0.75em]"
        fill="none"
        viewBox="0 0 18 18"
      >
        <path
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M7 3H3a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-4M11 1h6m0 0v6m0-6L7 11"
        />
      </svg>
    )
  }
</a>
