---
import type { Podcast } from '@/types/podcast'

interface Props {
  podcast: Podcast
}
const {
  podcast: { title, description, href }
} = Astro.props
---

<li>
  <h3>{title}</h3>
  <p>{description}</p>
  <iframe title="Podcast player" class="w-full h-28" loading="lazy" src={href}
  ></iframe>
</li>
