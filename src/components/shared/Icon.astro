  name:
    | 'swap'
    | 'arrow-right-keyboard'
    | 'arrow-right'
    | 'arrow-down'
    | 'link-rounded'
    | 'external-link'
    | 'mastodon'
    | 'slack'
    | 'instagram'
    | 'linkedin'
    | 'x'
    | 'github'
    | 'youtube'
    | 'interledger'
    | 'close'
    | 'menu'
    | 'check'
  class?: string
}

type IconDefinition = {
  viewBox: string
  body: string
}

