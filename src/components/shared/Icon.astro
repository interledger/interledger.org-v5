---
/**
 * Tiny inline-SVG icon component.
 *
 * Each entry in ICONS pairs a viewBox with the path data exported from
 * Figma. New icons go here. Sizing is via the standard Tailwind size-*
 * utilities passed through `class`, defaulting to size-5 (20px) to match
 * the Figma design system. Colour follows currentColor so it inherits
 * from the parent (e.g. button text).
 */
import { twMerge } from '@/utils'

interface Props {
  name: 'swap' | 'arrow-right'
  class?: string
}

