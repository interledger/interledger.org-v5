---
/**
 * Tiny inline-SVG icon component.
 *
 * Each entry in ICONS pairs a viewBox with the path data. New icons go here.
 * Sizing is via the standard Tailwind size-* utilities passed through `class`,
 * defaulting to size-4 (16px). Colour follows currentColor so it inherits
 * from the parent (e.g. button text colour).
 */
import { twMerge } from '@/utils'

interface Props {
  name: 'chevron-left' | 'chevron-right'
  class?: string
}

const ICONS: Record<Props['name'], { viewBox: string; path: string }> = {
  'chevron-left': {
    viewBox: '0 0 16 16',
    path: 'M10 4 6 8l4 4'
  },
  'chevron-right': {
    viewBox: '0 0 16 16',
    path: 'm6 4 4 4-4 4'
  }
}

const { name, class: className } = Astro.props
const { viewBox, path } = ICONS[name]
---

<svg
  class={twMerge('size-4', className)}
  viewBox={viewBox}
  fill="none"
  aria-hidden="true"
>
  <path
    d={path}
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"></path>
</svg>
