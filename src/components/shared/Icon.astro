const { name, class: className } = Astro.props
const { viewBox, path } = ICONS[name]
---

<svg
  class={twMerge('size-5', className)}
  viewBox={viewBox}
  fill="currentColor"
  aria-hidden="true"
>
  <path d={path}></path>
</svg>
