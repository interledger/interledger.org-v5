---
import { buildImageSrcset, getOptimizedImage } from '@/utils'

export interface OptimizedImageAlternateSource {
  src: string
  media: string
  sizes: string
}

interface Props {
  src: string
  alt: string
  width?: number
  height?: number
  class?: string
  /** Applies to wrapping `<picture>` when responsive sources exist. */
  pictureClass?: string
  loading?: 'lazy' | 'eager'
  sizes?: string
  fetchpriority?: 'high' | 'low' | 'auto'
  media?: string
  /** Optional art-directed sources (most specific `media` first). */
  alternateSources?: OptimizedImageAlternateSource[]
}

const {
  src,
  alt,
  width,
  height,
  class: className,
  pictureClass: pictureClassName,
  loading = 'lazy',
  sizes = '100vw',
  fetchpriority,
  media,
  alternateSources = []
} = Astro.props

const { variants, fullSrc, avifVariants, avifFullSrc } = src
  ? getOptimizedImage(src)
  : { variants: [], fullSrc: null, avifVariants: [], avifFullSrc: null }

const alternatePictureSources = alternateSources.flatMap(
  ({ src: alternateSrc, media: alternateMedia, sizes: alternateSizes }) => {
    const alternate = getOptimizedImage(alternateSrc)
    const sources: Array<{
      type: string
      media: string
      srcset: string
      sizes: string
    }> = []

    if (alternate.avifVariants.length > 0) {
      sources.push({
        type: 'image/avif',
        media: alternateMedia,
        srcset: buildImageSrcset(alternate.avifVariants),
        sizes: alternateSizes
      })
    }

    if (alternate.variants.length > 0) {
      sources.push({
        type: 'image/webp',
        media: alternateMedia,
        srcset: buildImageSrcset(alternate.variants),
        sizes: alternateSizes
      })
    }

    return sources
  }
)

const hasResponsive = variants.length > 0 || alternatePictureSources.length > 0
const webpSrcset = variants.map((v) => `${v.src} ${v.width}w`).join(', ')
const avifSrcset = avifVariants.map((v) => `${v.src} ${v.width}w`).join(', ')
const decoding: 'async' | 'sync' | 'auto' = 'async'
// When a media query is provided, omit <img> src so browsers that don't match
// the <source> media condition don't fetch the image at all.
const imgSrc = media ? undefined : src
---

{
  hasResponsive ? (
    <picture class={pictureClassName}>
      {alternatePictureSources.map((source) => (
        <source
          type={source.type}
          media={source.media}
          srcset={source.srcset}
          sizes={source.sizes}
        />
      ))}
      {avifVariants.length > 0 && (
        <source
          type="image/avif"
          srcset={avifSrcset}
          sizes={sizes}
          media={media}
        />
      )}
      {variants.length > 0 && (
        <source
          type="image/webp"
          srcset={webpSrcset}
          sizes={sizes}
          media={media}
        />
      )}
      <img
        src={imgSrc}
        alt={alt}
        width={width}
        height={height}
        class={className}
        loading={loading}
        decoding={decoding}
        fetchpriority={fetchpriority}
      />
    </picture>
  ) : fullSrc ? (
    <picture class={pictureClassName}>
      {avifFullSrc && (
        <source type="image/avif" srcset={avifFullSrc} media={media} />
      )}
      <source type="image/webp" srcset={fullSrc} media={media} />
      <img
        src={imgSrc}
        alt={alt}
        width={width}
        height={height}
        class={className}
        loading={loading}
        decoding={decoding}
        fetchpriority={fetchpriority}
      />
    </picture>
  ) : (
    <img
      src={src}
      alt={alt}
      width={width}
      height={height}
      class={className}
      loading={loading}
      decoding={decoding}
      fetchpriority={fetchpriority}
    />
  )
}
