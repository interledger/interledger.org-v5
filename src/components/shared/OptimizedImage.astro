---
import { getOptimizedImage } from '@/utils'

interface Props {
  src: string
  alt: string
  width?: number
  height?: number
  class?: string
  loading?: 'lazy' | 'eager'
  sizes?: string
  fetchpriority?: 'high' | 'low' | 'auto'
  media?: string
}

const {
  src,
  alt,
  width,
  height,
  class: className,
  loading = 'lazy',
  sizes = '100vw',
  fetchpriority,
  media
} = Astro.props

const { variants, fullSrc } = src
  ? getOptimizedImage(src)
  : { variants: [], fullSrc: null }

const hasResponsive = variants.length > 0
const srcset = variants.map((v) => `${v.src} ${v.width}w`).join(', ')
const decoding = loading === 'lazy' ? 'async' : undefined
// When a media query is provided, omit <img> src so browsers that don't match
// the <source> media condition don't fetch the image at all.
const imgSrc = media ? undefined : src
---

{
  hasResponsive ? (
    <picture>
      <source type="image/webp" srcset={srcset} sizes={sizes} media={media} />
      <img
        src={imgSrc}
        alt={alt}
        width={width}
        height={height}
        class={className}
        loading={loading}
        decoding={decoding}
        fetchpriority={fetchpriority}
      />
    </picture>
  ) : fullSrc ? (
    <picture>
      <source type="image/webp" srcset={fullSrc} media={media} />
      <img
        src={imgSrc}
        alt={alt}
        width={width}
        height={height}
        class={className}
        loading={loading}
        decoding={decoding}
        fetchpriority={fetchpriority}
      />
    </picture>
  ) : (
    <img
      src={src}
      alt={alt}
      width={width}
      height={height}
      class={className}
      loading={loading}
      decoding={decoding}
      fetchpriority={fetchpriority}
    />
  )
}
