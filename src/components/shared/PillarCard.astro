---
import { twMerge, type UmamiAttrs } from '@/utils'
import LinkButton from '@/components/shared/LinkButton.astro'
import Icon from '@/components/shared/Icon.astro'
interface Props {
  title: string
  description: string
  href: string
  umamiAttr: UmamiAttrs
  external?: boolean
  class?: string
}

const {
  title,
  description,
  href,
  umamiAttr,
  external = false,
  class: className
} = Astro.props

const articleClasses = twMerge(
  'flex-1 rounded-3xl p-lg flex flex-col gap-lg',
  'tablet:flex-row tablet:justify-between tablet:gap-xl',
  'desktop:flex-col desktop:p-xl',
  className
)
const textContentClasses = `
flex flex-col gap-lg 
[&>p]:text-body-lg-standard tablet:[&>p]:text-body-lg-standard-md
`
const doubleRowHeader = `flex flex-row
[&>h3]:text-h2 tablet:[&>h3]:text-h3-md desktop:[&>h3]:text-h3-lg desktop:[&>h3]:h-[2lh]
`
---

<article class={articleClasses}>
  <div class={textContentClasses}>
    <div class={doubleRowHeader}>
      <h3>
        {title}
      </h3>
    </div>
    <p>{description}</p>
  </div>

  <LinkButton
    variant="fab"
    href={href}
    aria-label={title}
    external={external}
    {...umamiAttr}
  >
    <Icon name="arrow-right" />
  </LinkButton>
</article>
