---
import { YouTube } from '@astro-community/astro-embed-youtube'
import { Vimeo } from '@astro-community/astro-embed-vimeo'
import { detectVideoProvider, buildUmamiAttrs } from '@/utils'

interface Props {
  url: string
  title: string
  poster?: string
}

const { url, title, poster } = Astro.props
const { routeLocale } = Astro.locals
const provider = detectVideoProvider(url)

const videoAttrs = buildUmamiAttrs({
  pathname: Astro.url.pathname,
  lang: routeLocale,
  section: 'link',
  href: url,
  linkText: title,
  label: 'video'
})
---

{
  provider === 'youtube' ? (
    <div class="video-embed w-full">
      <YouTube id={url} playlabel={title} poster={poster} />
    </div>
  ) : provider === 'vimeo' ? (
    <div class="video-embed w-full">
      <Vimeo id={url} playlabel={title} />
    </div>
  ) : provider === 'file' ? (
    <div class="video-embed w-full">
      <video
        src={url}
        poster={poster}
        controls
        loop
        muted
        autoplay
        playsinline
        aria-label={title}
        class="w-full"
      >
        <a href={url} target="_blank" rel="noopener noreferrer" {...videoAttrs}>
          {title}
        </a>
      </video>
    </div>
  ) : (
    <a href={url} target="_blank" rel="noopener noreferrer" {...videoAttrs}>
      {title}
    </a>
  )
}

<style>
  lite-youtube {
    max-width: unset;
  }
</style>
