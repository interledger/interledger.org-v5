---
import Icon from '@/components/shared/Icon.astro'
import { buildUmamiAttrs, useTranslations } from '@/utils'

interface Props {
  href: string
  label: string
  theme?: 'light' | 'dark'
  variant?: 'flat' | 'mega'
  openInNewTab?: boolean
}

const {
  href,
  label,
  theme = 'light',
  variant = 'flat',
  openInNewTab = false
} = Astro.props

const isDark = theme === 'dark'
const { routeLocale } = Astro.locals
const t = useTranslations(routeLocale)

const umamiAttrs = buildUmamiAttrs({
  pathname: Astro.url.pathname,
  lang: routeLocale,
  section: 'nav',
  href,
  linkText: label
})

const itemTextClass = isDark ? 'text-neutral-25' : 'text-black'

const externalLinkIconClass = 'size-4 shrink-0 translate-y-[-1px]'

const navLinkClass =
  'nav-link relative no-underline focus-visible:outline-none after:absolute after:inset-x-0 after:bottom-0 after:h-px ' +
  'after:origin-left after:bg-current after:scale-x-0 after:transition-transform after:content-[""] ' +
  'after:hidden desktop:after:block desktop:hover:after:scale-x-100 desktop:focus-visible:after:scale-x-100 ' +
  'motion-reduce:after:transition-none'

const activeClass =
  'desktop:data-[active=true]:underline desktop:data-[active=true]:decoration-current desktop:data-[active=true]:decoration-2 desktop:data-[active=true]:underline-offset-8'

const className = [
  navLinkClass,
  itemTextClass,
  openInNewTab ? 'inline-flex items-center gap-xs' : 'block',
  'max-desktop:-mr-lg max-desktop:pr-lg max-desktop:py-lg',
  'px-0 desktop:py-md desktop:pe-md',
  activeClass,
  variant === 'mega' && 'whitespace-nowrap'
]
  .filter(Boolean)
  .join(' ')
---

<a
  href={href}
  class={className}
  data-component="NavMenuLink"
  {...umamiAttrs}
  {...openInNewTab ? { target: '_blank', rel: 'noopener noreferrer' } : {}}
>
  {label}
  {
    openInNewTab && (
      <>
        <Icon name="external-link" class={externalLinkIconClass} aria-hidden="true" />
        <span class="sr-only">{t('aria.opens_new_tab')}</span>
      </>
    )
  }
</a>
