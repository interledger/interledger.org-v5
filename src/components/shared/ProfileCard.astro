---
import OptimizedImage from '@/components/shared/OptimizedImage.astro'
import ProfileAvatarFallback from '@/components/shared/ProfileAvatarFallback.astro'
import { defaultLocale, buildUmamiAttrs } from '@/utils'
import { getProfileAvatarColorClass } from '@/components/shared/profileColors'

interface Props {
  name: string
  /** Full site path for foundation profiles, or section-relative path for summit/hackathon. */
  pathSlug: string
  /** Site section — controls the URL prefix (/summit, /hackathon, or none for foundation). */
  section?: string | null
  photo?: string
  photoAlt?: string
  tagline?: string
  umamiContext?: string
  colorIndex?: number
}

const {
  name,
  pathSlug,
  section,
  photo,
  photoAlt,
  tagline,
  umamiContext,
  colorIndex = 0
} = Astro.props
const colorClass = getProfileAvatarColorClass(colorIndex)
const { routeLocale } = Astro.locals
const langPrefix = routeLocale === defaultLocale ? '' : `/${routeLocale}`
const sectionPrefix = section && section !== 'foundation' ? `/${section}` : ''
const profileLink = `${langPrefix}${sectionPrefix}/${pathSlug}`

const umamiBase = {
  page: umamiContext,
  pathname: Astro.url.pathname,
  lang: routeLocale,
  section: 'card' as const
}
---

<article class="text-center">
  <a
    href={profileLink}
    class="text-black no-underline"
    {...buildUmamiAttrs({
      ...umamiBase,
      href: profileLink,
      linkText: `${name} profile`
    })}
  >
    <div
      class={`mx-auto aspect-square w-full max-w-[220px] overflow-hidden rounded-full ${colorClass}`}
    >
      {
        photo ? (
          <OptimizedImage
            src={photo}
            alt={photoAlt ?? name}
            width={240}
            height={240}
            loading="lazy"
            sizes="150px"
            class="h-full w-full object-contain object-bottom"
          />
        ) : (
          <ProfileAvatarFallback />
        )
      }
    </div>
    <div class="max-w-100 mx-auto mt-xl">
      <h3 class="text-h4 md:text-h4-md lg:text-h4-lg text-neutral-900 mb-sm">
        {name}
      </h3>
      {
        tagline && (
          <p class="text-body-lg-standard md:text-body-lg-standard-md mb-xl">
            {tagline}
          </p>
        )
      }
    </div>
  </a>
</article>
