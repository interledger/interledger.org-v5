---
import {
  getLanguageSwitcherHrefs,
  switcherLocales,
  useTranslations
} from '@/utils'

/**
 * Segmented-pill language switcher. Renders one anchor per supported locale
 * inside a bordered, rounded container. The anchor for the active locale gets
 * a filled background + orchid accent; inactive locales stay transparent.
 *
 * Anchors (not buttons) so navigation works without JS, middle-click opens in
 * a new tab, and search engines see locale alternates.
 */
interface Props {
  class?: string
}

const { routeLocale, currentSlug, currentBasePath } = Astro.locals
const { class: className } = Astro.props
const t = useTranslations(routeLocale)

const hrefs = getLanguageSwitcherHrefs(currentSlug, currentBasePath)
---

<div
  role="group"
  aria-label={t('nav.language')}
  data-component="LanguageSwitcher"
  class:list={[
    'inline-flex items-stretch gap-0 rounded-lg border border-neutral-100 bg-neutral-150 p-[2px]',
    'motion-safe:transition-colors motion-safe:duration-500',
    className
  ]}
>
  {
    switcherLocales.map((locale) => {
      const isActive = routeLocale === locale
      return (
        <a
          href={hrefs[locale]}
          hreflang={locale}
          aria-current={isActive ? 'true' : undefined}
          class:list={[
            'inline-flex h-[38px] w-10 items-center justify-center rounded-md',
            'text-caption font-normal leading-none no-underline',
            'motion-safe:transition-colors motion-safe:duration-500',
            'focus-visible:z-10 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-orchid-100',
            isActive
              ? 'bg-neutral-100 text-orchid-50'
              : 'text-neutral-50'
          ]}
        >
          {locale.toUpperCase()}
        </a>
      )
    })
  }
</div>
