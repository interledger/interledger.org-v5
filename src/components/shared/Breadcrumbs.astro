---
import {
  buildUmamiAttrs,
  useTranslations,
  stripTrailingSlash,
  twMerge
} from '@/utils'
import Icon from '@/components/shared/Icon.astro'

interface BreadcrumbItem {
  name: string
  href: string
}
interface Props {
  breadcrumbs: BreadcrumbItem[]
  class?: string
  /** On narrow viewports, put the current (last) crumb on its own row. */
  breakBeforeLastItem?: boolean
}

const {
  breadcrumbs,
  class: className,
  breakBeforeLastItem = false
} = Astro.props
const { routeLocale } = Astro.locals
const currentPath = stripTrailingSlash(Astro.url.pathname)
const t = useTranslations(routeLocale)
const breadcrumbClasses = twMerge(
  'flex flex-wrap items-center list-none m-0 p-0 [&_a]:no-underline text-neutral-75 [&_a]:text-neutral-75 [&_a[aria-current="page"]]:text-orchid-100 [&_svg]:text-current',
  breakBeforeLastItem ? 'gap-x-xs gap-y-2xs tablet:gap-xs' : 'gap-xs',
  className
)
const linkPaddingClass = breakBeforeLastItem ? 'px-xs py-0 tablet:p-xs' : 'p-xs'
const chevronMarginClass = breakBeforeLastItem
  ? 'shrink-0 tablet:my-xs'
  : 'my-xs shrink-0'
---

<nav aria-label={t('nav.breadcrumb')}>
  <ol
    class={breadcrumbClasses}
    itemscope
    itemtype="https://schema.org/BreadcrumbList"
  >
    {
      breadcrumbs.map((crumb, index) => {
        const isCurrent = crumb.href === currentPath
        const isLast = index === breadcrumbs.length - 1
        return (
          <>
            {breakBeforeLastItem && isLast && (
              <li
                class="basis-full h-0 p-0 m-0 tablet:hidden"
                aria-hidden="true"
              />
            )}
            <li
              itemprop="itemListElement"
              itemscope
              itemtype="https://schema.org/ListItem"
              class:list={['flex shrink-0 m-0']}
            >
              {index !== 0 && (
                <Icon
                  name="arrow-right-keyboard"
                  class:list={['size-6', chevronMarginClass]}
                />
              )}
              <a
                itemprop="item"
                href={crumb.href}
                class={`inline-block ${linkPaddingClass} text-body-lg-standard rounded-lg border border-transparent focus-visible:outline-none focus-visible:border-orchid-100 hover:text-neutral-900 `}
                aria-current={isCurrent ? 'page' : undefined}
                {...buildUmamiAttrs({
                  pathname: Astro.url.pathname,
                  lang: routeLocale,
                  section: 'nav',
                  href: crumb.href,
                  linkText: crumb.name
                })}
              >
                <span
                  itemprop="name"
                  class="whitespace-nowrap"
                  title={crumb.name}
                >
                  {crumb.name}
                </span>
              </a>
              <meta itemprop="position" content={String(index + 1)} />
            </li>
          </>
        )
      })
    }
  </ol>
</nav>
