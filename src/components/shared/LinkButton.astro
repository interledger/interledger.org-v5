---
import { buttonVariants } from './buttonVariants'
import { twMerge, useTranslations, buildUmamiAttrs } from '@/utils'
import type { HTMLAttributes } from 'astro/types'

type ButtonOpts = NonNullable<Parameters<typeof buttonVariants>[0]>
type ButtonVariant = ButtonOpts['variant']
type ButtonMode = ButtonOpts['mode']
type ButtonSize = ButtonOpts['size']
type ButtonIconOnly = ButtonOpts['iconOnly']
type ButtonIconSide = ButtonOpts['iconSide']

interface Props extends Omit<HTMLAttributes<'a'>, 'class' | 'href'> {
  href: string
  variant?: ButtonVariant
  mode?: ButtonMode
  size?: ButtonSize
  iconOnly?: ButtonIconOnly
  iconSide?: ButtonIconSide
  external?: boolean
  ariaDisabled?: boolean
  class?: string
}

const {
  href,
  external = false,
  ariaDisabled = false,
  variant,
  mode,
  size,
  iconOnly,
  iconSide,
  class: className,
  ...rest
} = Astro.props

const { routeLocale } = Astro.locals
const t = useTranslations(routeLocale)

const resolvedIconSide: ButtonIconSide =
  iconSide ??
  (Astro.slots.has('icon-left')
    ? 'left'
    : Astro.slots.has('icon-right')
      ? 'right'
      : 'none')

if (iconOnly && !rest['aria-label']) {
  // eslint-disable-next-line no-console
  console.warn('[LinkButton] iconOnly={true} requires aria-label')
}

const targetAttrs = external
  ? { target: '_blank', rel: 'noopener noreferrer' }
  : {}
// Anchors can't be natively disabled. Strip href so Enter activation does
// nothing, add tabindex="-1" so the element drops out of tab order, and
// expose aria-disabled to screen readers. aria-disabled alone is advisory:
// without stripping href, keyboard users can still navigate to and activate
// the link.
const resolvedHref = ariaDisabled ? undefined : href

const slotHtml = Astro.slots.has('default')
  ? await Astro.slots.render('default')
  : ''
// Strip nested markup (e.g. <Icon/>) and collapse whitespace to get plain link
// text; fall back to aria-label for icon-only buttons with no text slot.
const ariaLabel =
  typeof rest['aria-label'] === 'string' ? rest['aria-label'] : ''
const linkText =
  slotHtml
    .replace(/<[^>]*>/g, '')
    .replace(/\s+/g, ' ')
    .trim() || ariaLabel

const umamiAttrs = buildUmamiAttrs({
  pathname: Astro.url.pathname,
  lang: routeLocale,
  section: 'link',
  href: resolvedHref,
  linkText
})
---

<a
  {...rest}
  href={resolvedHref}
  class={twMerge(
    buttonVariants({
      variant,
      mode,
      size,
      iconOnly,
      iconSide: resolvedIconSide,
      class: className
    })
  )}
  data-component="LinkButton"
  {...targetAttrs}
  aria-disabled={ariaDisabled ? true : undefined}
  tabindex={ariaDisabled ? -1 : undefined}
  {...umamiAttrs}
>
  <slot name="icon-left" />
  <slot />
  <slot name="icon-right" />
  {external && <span class="sr-only">{t('aria.opens_new_tab')}</span>}
</a>
