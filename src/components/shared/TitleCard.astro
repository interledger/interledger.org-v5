---
import LinkButton from './LinkButton.astro'
import { buildUmamiAttrs, ensureLeadingSlash } from '@/utils'

interface Props {
  heading: string
  subheading?: string
  buttonUrl: string
  buttonText: string
  buttonExternal?: boolean
}

const {
  heading,
  subheading,
  buttonUrl,
  buttonText,
  buttonExternal = false
} = Astro.props

const { routeLocale } = Astro.locals

const href = buttonExternal ? buttonUrl : ensureLeadingSlash(buttonUrl)

// Mouse-only "whole card is clickable"
const overlayTargetAttrs = buttonExternal
  ? ({ target: '_blank', rel: 'noopener noreferrer' } as const)
  : {}
const overlayUmamiAttrs = buildUmamiAttrs({
  pathname: Astro.url.pathname,
  lang: routeLocale,
  section: 'card',
  href,
  linkText: buttonText
})

const bgClasses = `
nth-[6n+1]:[--card-bg:var(--color-deep-teal-50)] 
nth-[6n+2]:[--card-bg:var(--color-coral-red-50)] 
nth-[6n+3]:[--card-bg:var(--color-tangerine-50)] 
nth-[6n+4]:[--card-bg:var(--color-periwinkle-50)] 
nth-[6n+5]:[--card-bg:var(--color-lagoon-50)] 
nth-[6n+6]:[--card-bg:var(--color-pistachio-50)]
`
---

<article
  class=`relative flex flex-col justify-between gap-xl p-xl rounded-3xl border border-neutral-50 bg-[var(--card-bg)] tablet:bg-white tablet:hover:bg-[var(--card-bg)] transition-colors duration-200 ${bgClasses}`
>
  <div class="flex flex-col gap-lg">
    <h3
      class="m-0 text-neutral-900 text-h3 tablet:text-h3-md desktop:text-h3-lg"
    >
      {heading}
    </h3>
    {
      subheading && (
        <p class="m-0 text-neutral-100 text-h4 tablet:text-h4-md desktop:text-h4-lg">
          {subheading}
        </p>
      )
    }
    <div
      class="text-body-lg-standard text-neutral-100 [&_p]:m-0 [&_p]:text-body-lg-standard [&_p]:tablet:text-body-lg-standard-md"
    >
      <slot />
    </div>
  </div>
  <LinkButton
    href={href}
    variant="secondary"
    size="lg"
    external={buttonExternal}
    class="tablet:self-start z-[1]"
  >
    {buttonText}
  </LinkButton>
  <a
    href={href}
    aria-hidden="true"
    tabindex="-1"
    class="absolute inset-0 z-0"
    {...overlayTargetAttrs}
    {...overlayUmamiAttrs}></a>
</article>
