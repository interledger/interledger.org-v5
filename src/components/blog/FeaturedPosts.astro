---
import type { CollectionEntry } from 'astro:content'
import { useTranslations, buildUmamiAttrs, getBlogThumbnail } from '@/utils'

interface Props {
  posts: CollectionEntry<'foundation-blog'>[]
  blogIndexHref: string
}

const { posts, blogIndexHref } = Astro.props
const { routeLocale } = Astro.locals
const t = useTranslations(routeLocale)

const postAttrs = (href: string, linkText: string) =>
  buildUmamiAttrs({
    pathname: Astro.url.pathname,
    lang: routeLocale,
    section: 'featured_content',
    href,
    linkText,
    action: 'featured_post'
  })
---

{/* Unstyled featured section — visual design lands in INTORG-768. */}
<section aria-labelledby="featured-posts-heading" class="mb-space-m">
  <h2 id="featured-posts-heading" class="text-step-1 mb-space-2xs">
    {t('blog.featured.title')}
  </h2>
  <ul class="list-none p-0">
    {
      posts.map((post) => {
        const postPath = `${blogIndexHref}/${post.data.pathSlug}`
        const thumbnail = getBlogThumbnail(post)
        return (
          <li class="mb-space-2xs">
            {thumbnail && (
              <img
                loading="lazy"
                src={thumbnail}
                width="260"
                height="160"
                alt={post.data.thumbnailImageAlt ?? ''}
              />
            )}
            <a href={postPath} {...postAttrs(postPath, post.data.title)}>
              {post.data.title}
            </a>
          </li>
        )
      })
    }
  </ul>
</section>
