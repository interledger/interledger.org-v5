---
import type { CollectionEntry } from 'astro:content'
import { buildUmamiAttrs, getBlogThumbnail } from '@/utils'

interface Props {
  posts: CollectionEntry<'foundation-blog'>[]
  blogIndexHref: string
  heading: string
}

const { posts, blogIndexHref, heading } = Astro.props
const { routeLocale } = Astro.locals

const linkAttrs = (href: string, linkText: string) =>
  buildUmamiAttrs({
    pathname: Astro.url.pathname,
    lang: routeLocale,
    section: 'card',
    href,
    linkText,
    action: 'related_post'
  })
---

{/* Unstyled related-articles section — visual design lands in INTORG-768. */}
<section aria-labelledby="related-articles-heading" class="mt-space-l">
  <h2 id="related-articles-heading" class="text-step-1 mb-space-2xs">
    {heading}
  </h2>
  <ul class="list-none p-0">
    {
      posts.map((post) => {
        const postPath = `${blogIndexHref}/${post.data.pathSlug}`
        const thumbnail = getBlogThumbnail(post)
        return (
          <li class="mb-space-2xs">
            {thumbnail && (
              <img
                loading="lazy"
                src={thumbnail}
                width="260"
                height="160"
                alt={post.data.thumbnailImageAlt ?? ''}
              />
            )}
            <a href={postPath} {...linkAttrs(postPath, post.data.title)}>
              {post.data.title}
            </a>
          </li>
        )
      })
    }
  </ul>
</section>
