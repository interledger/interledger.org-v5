---
import {
  createExcerpt,
  useTranslations,
  buildUmamiAttrs,
  getBlogThumbnail,
  getReadingTime
} from '@/utils'
import type { Locale } from '@/utils'
import type { CollectionEntry } from 'astro:content'
import TaxonomyFilter from './TaxonomyFilter.astro'
import ContentLangFilter from './ContentLangFilter.astro'
import ContentLangNotice from './ContentLangNotice.astro'
import BlogCard from './BlogCard.astro'

interface Props {
  posts: CollectionEntry<'foundation-blog'>[]
  allTerms?: string[]
  enabledTerms?: string[]
  selectedTerm?: string
  blogIndexHref: string
  contentLang: Locale
  isTermFallback?: boolean
}
const {
  posts,
  allTerms = [],
  enabledTerms,
  selectedTerm,
  blogIndexHref,
  contentLang,
  isTermFallback
} = Astro.props
const { routeLocale } = Astro.locals
const t = useTranslations(routeLocale)
const contentLangOverride =
  Astro.url.pathname.includes('/lang/') || contentLang !== routeLocale
    ? contentLang
    : undefined

const postAttrs = (href: string, linkText: string) =>
  buildUmamiAttrs({
    pathname: Astro.url.pathname,
    lang: routeLocale,
    section: 'card',
    href,
    linkText,
    action: `post_title`
  })
---

<h1
  class="my-xl text-neutral-900 text-h2 tablet:text-h2-md desktop:my-3xl desktop:text-h2-lg"
>
  {t('blog.foundation.title')}
</h1>

<slot name="featured" />

<section
  aria-label={t('aria.blog.filters_label')}
  class="mt-4xl mb-3xl tablet:my-4xl desktop:my-5xl"
>
  <ContentLangFilter routeLocale={routeLocale} contentLang={contentLang} />

  <TaxonomyFilter
    collection="foundation-blog"
    terms={allTerms}
    enabledTerms={enabledTerms}
    selectedTerm={selectedTerm}
    href={blogIndexHref}
    contentLangOverride={contentLangOverride}
  />

  <ContentLangNotice routeLocale={routeLocale} contentLang={contentLang} />

  {
    isTermFallback && (
      <p class="mb-space-s text-step--1 text-gray-600 italic">
        {t('blog.empty_tag_lang.message')}
      </p>
    )
  }
</section>

<ol class="list-none p-0 m-0 flex flex-col gap-2xl">
  {
    posts.map((blogPostEntry) => {
      const excerpt = `${createExcerpt(blogPostEntry.body).substring(0, 300)}...`
      const postPath = `${blogIndexHref}/${blogPostEntry.data.pathSlug}`
      const thumbnail = getBlogThumbnail(blogPostEntry)
      return (
        <BlogCard
          blogData={blogPostEntry.data}
          umamiAttrs={postAttrs}
          excerpt={excerpt}
          postPath={postPath}
          thumbnail={thumbnail}
          readingTime={getReadingTime(blogPostEntry.body)}
        />
      )
    })
  }
</ol>
