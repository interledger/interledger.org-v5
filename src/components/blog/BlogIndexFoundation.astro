---
import {
  createExcerpt,
  COLLECTION_INDEX_SLUG,
  translatePath,
  useTranslations,
  buildUmamiAttrs,
  getBlogThumbnail
} from '@/utils'
import type { CollectionEntry } from 'astro:content'
import TaxonomyFilter from './TaxonomyFilter.astro'
import BlogIndexHeader from './BlogIndexHeader.astro'
import BlogCard from './BlogCard.astro'

interface Props {
  posts: CollectionEntry<'foundation-blog'>[]
  allTerms?: string[]
  selectedTerm?: string
  showTagFilter?: boolean
  blogIndexHref: string
}
const { posts, allTerms = [], selectedTerm, blogIndexHref } = Astro.props
const { routeLocale } = Astro.locals
const t = useTranslations(routeLocale)
const developersHref = translatePath(
  'developers-blog',
  routeLocale,
  COLLECTION_INDEX_SLUG
)

const postAttrs = (
  href: string,
  linkText: string,
  variant: 'title' | 'read_more'
) =>
  buildUmamiAttrs({
    pathname: Astro.url.pathname,
    lang: routeLocale,
    section: 'card',
    href,
    linkText,
    action: `post_${variant}`
  })
---

<BlogIndexHeader
  title={t('blog.foundation.title')}
  href={developersHref}
  message={t('blog.foundation.cta')}
  imgHref="/img/ernie-teal.svg"
  imgAlt={t('blog.header.image_alt')}
/>

<TaxonomyFilter
  collection="foundation-blog"
  terms={allTerms}
  selectedTerm={selectedTerm}
  href={blogIndexHref}
/>

<ol class="list-none p-0">
  {
    posts.map((blogPostEntry) => {
      const excerpt = `${createExcerpt(blogPostEntry.body).substring(0, 300)}...`
      const postPath = `${blogIndexHref}/${blogPostEntry.data.pathSlug}`
      const thumbnail = getBlogThumbnail(blogPostEntry)
      return (
        <BlogCard
          blogData={blogPostEntry.data}
          umamiAttrs={postAttrs}
          excerpt={excerpt}
          postPath={postPath}
          thumbnail={thumbnail}
        />
      )
    })
  }
</ol>
