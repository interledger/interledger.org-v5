---
import Icon from '@/components/shared/Icon.astro'
import { useTranslations, translatePath, COLLECTION_INDEX_SLUG } from '@/utils'

const { routeLocale } = Astro.locals
const t = useTranslations(routeLocale)
const searchInputId = 'foundation-blog-search'
const blogPath = translatePath('foundation-blog', routeLocale, COLLECTION_INDEX_SLUG)
const searchAction = `${blogPath}/search`
---

<form
  role="search"
  aria-labelledby={`${searchInputId}-label`}
  action={searchAction}
  method="get"
  class="mb-space-m"
>
  <label id={`${searchInputId}-label`} for={searchInputId} class="sr-only">
    {t('blog.search.label')}
  </label>
  <div class="relative">
    <Icon
      name="search"
      class="pointer-events-none absolute top-1/2 left-3 size-5 -translate-y-1/2 text-neutral-75"
    />
    <input
      id={searchInputId}
      type="search"
      name="q"
      placeholder={t('blog.search.placeholder')}
      class="w-full rounded-lg border border-neutral-25 bg-neutral-0 py-3 pr-4 pl-10 text-step--1 text-neutral-100 placeholder:text-neutral-75 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-orchid-100"
    />
    <button type="submit" class="sr-only">{t('blog.search.label')}</button>
  </div>
</form>
