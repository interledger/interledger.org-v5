---
import type { BlogCollectionType } from '@/content.config'
import {
  getBlogTaxonomy,
  getTermUrl,
  translateTerm,
  useTranslations,
  buildUmamiAttrs
} from '@/utils'
import type { Locale } from '@/utils'
interface Props {
  collection: BlogCollectionType
  terms: string[]
  enabledTerms?: string[]
  selectedTerm?: string
  href: string
  contentLangOverride?: Locale
}
const {
  collection,
  terms,
  enabledTerms,
  selectedTerm,
  href,
  contentLangOverride
} = Astro.props
const { routeLocale } = Astro.locals
const t = useTranslations(routeLocale)

const taxonomy = getBlogTaxonomy(collection)
const enabledSet = enabledTerms ? new Set(enabledTerms) : null
// Cross-lang routes always use "tag" as the URL segment (see tagFilter.ts).
const allHref = contentLangOverride
  ? `${href}/${taxonomy.segment}/all/lang/${contentLangOverride}`
  : `${href}/${taxonomy.segment}/all`

const linkClasses = `
  inline-block py-xs px-sm text-body-sm-standard text-neutral-100 
  rounded-full no-underline border border-neutral-50 transition-all duration-200
  hover:text-neutral-150 hover:border-neutral-75 
  focus-visible:outline-none focus-visible:border-primary 
  [&[aria-current='page']]:text-primary [&[aria-current='page']]:border-2 [&[aria-current='page']]:border-primary
  [&[aria-disabled='true']]:text-neutral-50 [&[aria-disabled='true']]:cursor-not-allowed 
  [&[aria-disabled='true']]:hover:border-neutral-50 [&[aria-disabled='true']]:hover:text-neutral-50
`

const filterAttrs = (action: string, label: string) =>
  buildUmamiAttrs({
    pathname: Astro.url.pathname,
    lang: routeLocale,
    section: 'cta',
    linkText: label,
    action
  })
---

<ul
  role="list"
  aria-label={t(taxonomy.filterLabelKey)}
  class="flex flex-wrap gap-x-xs gap-y-md list-none m-0 p-0 [&_li]:m-0 [&_li]:bg-neutral-0"
>
  <li>
    <a
      href={allHref}
      class={linkClasses}
      aria-current={!selectedTerm ? 'page' : undefined}
      {...filterAttrs('filter_all', t('blog.filter.all'))}
    >
      {t('blog.filter.all')}
    </a>
  </li>
  {
    terms.map((term) => {
      const label = translateTerm(taxonomy.i18nPrefix, term, t)
      const isEnabled = enabledSet === null || enabledSet.has(term)
      const isActive = selectedTerm === term
      const termHref = isEnabled
        ? getTermUrl(href, taxonomy.segment, term, contentLangOverride)
        : undefined

      return (
        <li>
          <a
            href={termHref}
            class={linkClasses}
            aria-current={isActive ? 'page' : undefined}
            aria-disabled={!isEnabled ? 'true' : undefined}
            {...(isEnabled
              ? filterAttrs(`filter_${taxonomy.segment}`, label)
              : {})}
          >
            {label}
          </a>
        </li>
      )
    })
  }
</ul>
