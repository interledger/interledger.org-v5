---
import { useTranslations, type UmamiAttrs } from '@/utils'
import type { FoundationBlogFrontmatterType } from '@/schemas/content'

interface Props {
  blogData: FoundationBlogFrontmatterType
  umamiAttrs: (
    href: string,
    linkText: string,
    variant: 'title' | 'read_more'
  ) => UmamiAttrs
  excerpt: string
  postPath: string
  thumbnail: string | null
}

const { blogData, umamiAttrs, excerpt, postPath, thumbnail } = Astro.props
const { routeLocale } = Astro.locals
const t = useTranslations(routeLocale)
---

<li
  class="flex flex-col gap-space-s pb-space-m mb-space-m rounded shadow-[0_10px_6px_-10px_rgba(0,0,0,0.25)] md:flex-row"
>
  <div class="shrink-0">
    {
      thumbnail && (
        <img
          loading="lazy"
          src={thumbnail}
          width="250"
          height="250"
          alt={blogData.thumbnailImageAlt ?? ''}
          class="w-62.5 h-62.5 object-cover"
        />
      )
    }
  </div>
  <div class="flex flex-col flex-1">
    <h2 class="text-step-1 mb-space-3xs">
      <a
        href={postPath}
        class="text-black font-bold underline decoration-transparent transition-all duration-300 hover:underline hover:decoration-inherit"
        {...umamiAttrs(postPath, blogData.title, 'title')}
      >
        {blogData.title}
      </a>
    </h2>
    <time
      class="block text-step--1 mb-space-2xs"
      datetime={blogData.date.toISOString()}
    >
      {blogData.date.toDateString().substring(4)}
    </time>
    <p class="leading-snug mb-space-2xs grow">
      {blogData.description ? blogData.description : excerpt}
    </p>
    <a
      href={postPath}
      class="group self-start flex gap-space-2xs text-step--1 underline decoration-transparent transition-all duration-300 hover:underline hover:text-inherit hover:decoration-inherit"
      {...umamiAttrs(postPath, t('blog.read_more'), 'read_more')}
    >
      {t('blog.read_more')}
      <svg
        viewBox="0 0 12 12"
        class="w-[0.75em] group-hover:translate-x-[0.25em] transition-all duration-300"
      >
        <path
          d="M11.92 5.62a1.001 1.001 0 0 0-.21-.33l-5-5a1.004 1.004 0 0 0-1.42 1.42L8.59 5H1a1 1 0 0 0 0 2h7.59l-3.3 3.29a1.002 1.002 0 0 0 .325 1.639 1 1 0 0 0 1.095-.219l5-5a1 1 0 0 0 .21-.33 1 1 0 0 0 0-.76Z"
          fill="currentColor"></path>
      </svg>
    </a>
  </div>
</li>
