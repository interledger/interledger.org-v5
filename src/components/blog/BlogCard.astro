---
import type { FoundationBlogFrontmatterType } from '@/schemas/content'
import {
  type UmamiAttrs,
  translatePath,
  COLLECTION_INDEX_SLUG,
  twMerge
} from '@/utils'
import OptimizedImage from '@/components/shared/OptimizedImage.astro'
import ArticleCategories from './ArticleCategories.astro'
import BlogCardByline from './BlogCardByline.astro'

interface Props {
  blogData: FoundationBlogFrontmatterType
  umamiAttrs: (href: string, linkText: string) => UmamiAttrs
  excerpt: string
  postPath: string
  thumbnail: string | null
  readingTime: number
  featured?: boolean
}

const {
  blogData,
  umamiAttrs,
  excerpt,
  postPath,
  thumbnail,
  readingTime,
  featured = false
} = Astro.props
const { routeLocale } = Astro.locals
const blogPath = translatePath(
  'foundation-blog',
  routeLocale,
  COLLECTION_INDEX_SLUG
)

const cardClasses = twMerge(
  'flex flex-col-reverse gap-xl m-0 desktop:flex-1',
  !featured &&
    'pb-2xl border-b border-neutral-25 tablet:flex-row tablet:justify-between desktop:gap-3xl'
)
const cardHeaderClasses = twMerge(
  'text-h3 text-neutral-150 underline decoration-transparent transition-all duration-200 hover:decoration-inherit desktop:text-h4-lg',
  featured ? 'tablet:text-h3-md' : 'tablet:text-h4-md'
)
const cardImageClasses = twMerge(
  'object-cover rounded-3xl',
  featured
    ? 'w-full max-h-[220px] aspect-2/1'
    : 'aspect-240/140 max-w-[220px] tablet:max-w-full'
)
---

<li class={cardClasses}>
  <div class="flex flex-col gap-lg tablet:basis-[70%]">
    <h3 class="m-0">
      <a
        href={postPath}
        class={cardHeaderClasses}
        {...umamiAttrs(postPath, blogData.title)}
      >
        {blogData.title}
      </a>
    </h3>
    <p
      class="m-0 text-body-lg-standard text-neutral-75 tablet:text-body-lg-standard-md"
    >
      {blogData.description ? blogData.description : excerpt}
    </p>
    {
      blogData.categories.length > 0 && (
        <ArticleCategories categories={blogData.categories} path={blogPath} />
      )
    }
    <BlogCardByline
      bio={blogData.articleBios[0] ?? null}
      date={blogData.date}
      readingTime={readingTime}
      featured={featured}
      bylineClasses={featured ? 'flex-row' : ''}
    />
  </div>
  <div class="tablet:basis-[30%]">
    {
      thumbnail && (
        <OptimizedImage
          loading={featured ? 'eager' : 'lazy'}
          fetchpriority={featured ? 'high' : 'auto'}
          src={thumbnail}
          width={1100}
          height={600}
          alt={blogData.thumbnailImageAlt ?? ''}
          class={cardImageClasses}
        />
      )
    }
  </div>
</li>
