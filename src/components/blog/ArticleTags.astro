---
import type { FoundationTag } from '@/schemas/content'
import { getTagUrl } from '@/utils/tag-url'
interface Props {
  tags: FoundationTag[]
  path: string
}
const { tags, path } = Astro.props
---

<footer>
  <ul class="flex gap-space-xs mb-space-s list-none! ps-0!">
    {
      tags.map((tag) => (
        <li class="mb-space-xs">
          <a href={getTagUrl(path, tag)}>#{tag}</a>
        </li>
      ))
    }
  </ul>
</footer>
