---
const { text, imageUrl, imageAlt = '' } = Astro.props
---

<div
  class="flex flex-col mb-space-s xs:gap-space-xs xs:flex-row xs:items-center"
>
  {
    imageUrl && (
      <img
        loading="lazy"
        src={imageUrl}
        alt={imageAlt}
        class="mb-space-s aspect-150/150 object-cover"
      />
    )
  }
  <p class="italic">{text}</p>
</div>
