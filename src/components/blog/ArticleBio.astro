---
const { text, imageUrl, imageAlt = '' } = Astro.props
---

<hr class="mt-space-l mb-space-s" />
<div class="flex flex-col xs:gap-space-xs xs:flex-row xs:items-center">
  <img
    loading="lazy"
    src={imageUrl}
    alt={imageAlt}
    class="mb-space-s aspect-150/150 object-cover"
  />
  <p class="italic">{text}</p>
</div>
