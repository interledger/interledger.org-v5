---
import { COLLECTION_INDEX_SLUG, translatePath, type Locale } from '@/utils'
import { getCollection, render } from 'astro:content'
import CommunityLinksDevelopers from '@/components/blog/CommunityLinksDevelopers.astro'
import DevelopersBlogLayout from '@/layouts/DevelopersBlogLayout.astro'
import TranslationDisclaimer from '@/components/shared/TranslationDisclaimer.astro'
import OptimizedImage from '@/components/OptimizedImage.astro'

interface Props {
  slug: string
  contentLocale: Locale
  isFallback?: boolean
}

const { slug, contentLocale, isFallback = false } = Astro.props
const { routeLocale } = Astro.locals
const posts = await getCollection('developers-blog')

const mdxPost = posts.find(
  (post) => post.data.pathSlug === slug && post.data.locale === contentLocale
)

if (!mdxPost) return Astro.redirect('/404')

const { Content: MdxContent } = await render(mdxPost)
const mdxData = mdxPost.data
const developersHomePath = translatePath(
  'foundation-pages',
  routeLocale,
  'developers'
)
const blogPath = translatePath(
  'developers-blog',
  routeLocale,
  COLLECTION_INDEX_SLUG
)
---

<DevelopersBlogLayout
  frontmatter={mdxData}
  developersHomePath={developersHomePath}
  blogPath={blogPath}
>
  <Fragment slot="disclaimer">
    <TranslationDisclaimer isVisible={isFallback} />
  </Fragment>
  <MdxContent components={{ img: OptimizedImage }} />
  <CommunityLinksDevelopers />
</DevelopersBlogLayout>
