---
import { buildUmamiAttrs } from '@/utils'

interface Props {
  title: string
  href: string
  message: string
  imgHref: string
  imgAlt: string
}
const { title, href, message, imgHref, imgAlt } = Astro.props
const { routeLocale } = Astro.locals

const ctaAttrs = buildUmamiAttrs({
  pathname: Astro.url.pathname,
  lang: routeLocale,
  section: 'cta',
  href,
  linkText: message
})
---

<header
  class="pt-xl pb-2xl flex flex-col justify-between items-start gap-lg min-[730px]:flex-row min-[730px]:items-center"
>
  <h1 class="text-h2 font-bold">{title}</h1>
  <a
    class="group flex items-center gap-xl rounded bg-white px-s py-xs shadow text-body-sm-standard no-underline"
    href={href}
    {...ctaAttrs}
  >
    <p
      class="underline decoration-transparent transition-[text-decoration-color] duration-300 group-hover:decoration-current"
    >
      {message}
    </p>
    <img src={imgHref} alt={imgAlt} aria-hidden="true" class="w-[4em]" />
  </a>
</header>
