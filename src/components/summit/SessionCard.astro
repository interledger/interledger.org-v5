---
import type { TalkPreview } from '@/types/summit'
import {
  generateSlug,
  truncateText,
  type Locale,
  getTranslation
} from '@/utils'
import { buildUmamiAttrs } from '@/utils/umami'
import SessionSubheader from './SessionSubheader.astro'

interface Props {
  talkPreview: TalkPreview
  basePath: string
  lang: Locale
  year: string
}

const { talkPreview, basePath, lang, year } = Astro.props
const href = `${basePath}/${generateSlug(talkPreview.title)}`
const translation = getTranslation(talkPreview, lang)
const description = translation?.description ?? talkPreview.description
const title = translation?.title ?? talkPreview.title

const attrs = buildUmamiAttrs({
  pathname: Astro.url.pathname,
  lang,
  section: 'card',
  href,
  linkText: title,
  action: `${year}_session_${generateSlug(talkPreview.title)}`
})
---

<li class="flex flex-col gap-space-m mb-6 md:flex-row">
  <img
    class="w-[200px] h-[200px] rounded-full border-2 border-[var(--color-primary)]"
    src={talkPreview.speakerImage}
    alt={talkPreview.speakerName}
    width="200"
    height="200"
    loading="lazy"
  />
  <div class="[&_p]:text-step--1">
    <h2 class="text-[var(--color-primary)]">
      <a href={href} {...attrs}>{title}</a>
    </h2>
    <SessionSubheader
      talk={talkPreview}
      showRecordingLabel={true}
      lang={lang}
    />
    {description && <p>{truncateText(description)}</p>}
  </div>
</li>
