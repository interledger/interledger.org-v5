---
import SummitPageLayout from '@/layouts/SummitPageLayout.astro'
import type { Speaker } from '@/types/summit'
import { getTalks } from '@/utils/extractSessionize'
import { truncateText } from '@/utils/text'

interface Props {
  entry: Speaker
  year: string
}

const { entry, year } = Astro.props
const sessions = getTalks(year, entry.id)
---

<SummitPageLayout title={entry.name}>
  <main class="max-w-250 p-4 m-auto">
    <header class="flex justify-between mb-4">
      <div>
        <h1>{entry.name}</h1>
        <p>{entry.tagLine}</p>
      </div>
      <figure>Image here</figure>
    </header>
    <section aria-label="Biography" class="mb-8">
      <p>{entry.bio}</p>
    </section>
    <section aria-label="Sessions" class="border border-teal-300 p-8">
      <ul>
        {
          sessions.map((session) => (
            <li>
              <article>
                <h2 class="text-teal-300">{session.title}</h2>
                <p>{truncateText(session.description)}</p>
              </article>
            </li>
          ))
        }
      </ul>
    </section>
  </main>
</SummitPageLayout>
