---
import type { Talk, TalkPreview } from '@/types/summit'
import type { Locale } from '@/utils/i18'
import { formatDate, getDurationInMinutes } from '@/utils/time'

interface Props {
  talk: TalkPreview | Talk
  lang: Locale
  showRecordingLabel?: boolean
}

const { talk, showRecordingLabel = false, lang } = Astro.props
---

<>
  <p class="mb-4">
    <time datetime={talk.startsAt}
      >{formatDate(talk.startsAt, lang)}
    </time><span>
      - {getDurationInMinutes(talk.startsAt, talk.endsAt)} min</span
    >
    {
      talk.recordingUrl && showRecordingLabel && (
        <span> (recording available)</span>
      )
    }
  </p>
  {
    talk.translations.length > 0 && (
      <p class="flex flex-row gap-2 mb-3 [&_span]:bg-white/20 [&_span]:py-0.5 [&_span]:px-1 [&_span]:rounded-sm [&_span]:text-step--2 [&_span]:font-bold">
        {talk.translations.map((language) => (
          <span>{language}</span>
        ))}
      </p>
    )
  }
</>
