---
import { type Talk } from '@/types/summit'
import { type Locale, generateSlug, truncateText, getTranslation } from '@/utils'

interface Props {
  sessions: Talk[]
  sessionBaseHref: string
  lang: Locale
  year: string
}
const { sessions, sessionBaseHref, lang, year } = Astro.props

const sessionsWithLinks = sessions.map((session) => {
  const translation = getTranslation(session, lang)
  const title = translation?.title ?? session.title
  const description = translation?.description ?? session.description
  return {
    ...session,
    title,
    description,
    href: `${sessionBaseHref}/${generateSlug(session.title)}`
  }
})
---

<ul>
  {
    sessionsWithLinks.map((session) => (
      <li>
        <article>
          <h2 class="text-teal-300">
            <a
              href={session.href}
              data-umami-event={`${year} Speaker page - Session: ${session.title}`}
            >
              {session.title}
            </a>
          </h2>
          {session.description && <p>{truncateText(session.description)}</p>}
        </article>
      </li>
    ))
  }
</ul>
