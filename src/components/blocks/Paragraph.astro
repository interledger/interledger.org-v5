---
import { parseMarkdown } from '@/utils'

interface Props {
  content?: string
  alignment?: 'left' | 'center' | 'right'
  umamiContext?: string
}

const { content, alignment = 'left', umamiContext } = Astro.props

const alignmentClass =
  alignment === 'center'
    ? 'text-center'
    : alignment === 'right'
      ? 'text-right'
      : ''

const hasContent = content != null && content !== ''
const className = alignmentClass || undefined
const htmlContent = hasContent
  ? await parseMarkdown(content, {
      pageLabel: umamiContext,
      pathname: Astro.url.pathname
    })
  : null
---

{
  hasContent ? (
    <div class={className} set:html={htmlContent} />
  ) : (
    <div class={className}>
      <slot />
    </div>
  )
}
