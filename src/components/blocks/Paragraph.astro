---
import MarkdownIt from 'markdown-it'

interface Props {
  content?: string
  alignment?: 'left' | 'center' | 'right'
}

const { content, alignment = 'left' } = Astro.props

const md = new MarkdownIt({
  html: true,
  linkify: true,
  typographer: true
})

const alignmentClass =
  alignment === 'center'
    ? 'text-center'
    : alignment === 'right'
      ? 'text-right'
      : ''

const hasContent = content != null && content !== ''
const className = alignmentClass || undefined
---

{
  hasContent ? (
    <div class={className} set:html={md.render(content)} />
  ) : (
    <div class={className}>
      <slot />
    </div>
  )
}
