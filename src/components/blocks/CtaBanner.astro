---
import { buildUmamiAttrs } from '@/utils'

interface Props {
  heading: string
  text?: string
  primaryButtonText?: string
  primaryButtonLink?: string
  secondaryButtonText?: string
  secondaryButtonLink?: string
  backgroundColor?: 'primary' | 'secondary' | 'light' | 'dark'
  umamiContext?: string
}

const {
  heading,
  text,
  primaryButtonText,
  primaryButtonLink,
  secondaryButtonText,
  secondaryButtonLink,
  backgroundColor = 'primary',
  umamiContext
} = Astro.props

const { routeLocale } = Astro.locals
const umamiBase = {
  page: umamiContext,
  pathname: Astro.url.pathname,
  lang: routeLocale,
  section: 'cta' as const
}

const bgClasses = {
  primary: 'bg-gradient-primary text-white',
  secondary: 'bg-gray-100',
  light: 'bg-gray-50',
  dark: 'bg-black text-white'
}

const headingClasses = {
  primary: 'text-white',
  secondary: 'text-primary-fallback',
  light: 'text-primary-fallback',
  dark: 'text-white'
}

const baseButtonClasses =
  'inline-flex w-fit shrink-0 items-center justify-center gap-spacing-md rounded-cta border px-spacing-lg py-spacing-md font-poppins text-body-sm-standard md:text-body-lg-standard font-medium no-underline transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2'

const primaryButtonClasses = `${baseButtonClasses} border-transparent bg-cta-primary text-white hover:bg-cta-primary-hover`

const secondaryButtonClasses = {
  primary: `${baseButtonClasses} border-neutral-50 bg-transparent text-white hover:border-white hover:bg-white/[0.08] focus-visible:ring-white focus-visible:ring-offset-transparent`,
  secondary: `${baseButtonClasses} border-neutral-900 bg-transparent text-neutral-900 hover:bg-neutral-900/[0.06] focus-visible:ring-neutral-900 focus-visible:ring-offset-neutral-0`,
  light: `${baseButtonClasses} border-neutral-900 bg-transparent text-neutral-900 hover:bg-neutral-900/[0.06] focus-visible:ring-neutral-900 focus-visible:ring-offset-neutral-0`,
  dark: `${baseButtonClasses} border-neutral-50 bg-transparent text-white hover:border-white hover:bg-white/[0.08] focus-visible:ring-white focus-visible:ring-offset-transparent`
}
---

<section
  class={`py-space-xl px-space-m text-center ${bgClasses[backgroundColor]}`}
>
  <div class="max-w-narrow mx-auto">
    <h2
      class={`text-[2rem] font-semibold mb-space-s ${headingClasses[backgroundColor]}`}
    >
      {heading}
    </h2>
    {text && <p class="text-[1.125rem] mb-space-m opacity-90">{text}</p>}
    {
      (primaryButtonText || secondaryButtonText) && (
        <div class="flex flex-wrap justify-center gap-space-s">
          {primaryButtonText && primaryButtonLink && (
            <a
              href={primaryButtonLink}
              class={primaryButtonClasses}
              {...buildUmamiAttrs({
                ...umamiBase,
                href: primaryButtonLink,
                linkText: primaryButtonText
              })}
            >
              <span>{primaryButtonText}</span>
              <svg
                class="size-5 shrink-0"
                aria-hidden="true"
                width="20"
                height="20"
                viewBox="0 0 20 20"
                fill="none"
              >
                <path
                  d="M4 10h12M11 5l5 5-5 5"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            </a>
          )}
          {secondaryButtonText && secondaryButtonLink && (
            <a
              href={secondaryButtonLink}
              class={secondaryButtonClasses[backgroundColor]}
              {...buildUmamiAttrs({
                ...umamiBase,
                href: secondaryButtonLink,
                linkText: secondaryButtonText
              })}
            >
              {secondaryButtonText}
            </a>
          )}
        </div>
      )
    }
  </div>
</section>
