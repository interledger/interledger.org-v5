---
import { buildUmamiAttrs } from '@/utils'

interface CardLink {
  title: string
  description?: string
  href: string
  openInNewTab?: boolean
}

interface Props {
  heading?: string
  subheading?: string
  cards: CardLink[]
  columns?: '2' | '3' | '4'
  umamiContext?: string
}

const { heading, subheading, cards, columns = '3', umamiContext } = Astro.props
const { routeLocale } = Astro.locals
const umamiBase = {
  page: umamiContext,
  pathname: Astro.url.pathname,
  lang: routeLocale,
  section: 'card' as const
}

const gridClass =
  columns === '2'
    ? 'grid-cols-[repeat(auto-fit,minmax(280px,1fr))]'
    : columns === '4'
      ? 'grid-cols-[repeat(auto-fit,minmax(220px,1fr))]'
      : 'grid-cols-[repeat(auto-fit,minmax(250px,1fr))]'
---

<div class="max-w-wide mx-auto">
  {
    heading && (
      <div class="text-center mb-3xl">
        <h2 class="text-[2rem] font-semibold text-primary mb-lg">{heading}</h2>
        {subheading && (
          <p class="text-[1.125rem] text-neutral-75 max-w-[600px] mx-auto">
            {subheading}
          </p>
        )}
      </div>
    )
  }
  <div class={`grid gap-2xl ${gridClass}`}>
    {
      cards.map((card) => (
        <a
          href={card.href}
          class="group flex items-center justify-between rounded-card border border-neutral-75-200 bg-white p-2xl text-inherit no-underline transition-all duration-200 hover:border-primary hover:shadow-card"
          {...buildUmamiAttrs({
            ...umamiBase,
            href: card.href,
            linkText: card.title
          })}
          {...(card.openInNewTab
            ? { target: '_blank', rel: 'noopener noreferrer' }
            : {})}
        >
          <span class="flex flex-col gap-s">
            <span class="text-[1.125rem] font-semibold text-primary">
              {card.title}
            </span>
            {card.description && (
              <span class="text-sm text-neutral-75">{card.description}</span>
            )}
          </span>
          <span class="text-2xl text-primary transition-transform duration-200 group-hover:translate-x-1">
            &rarr;
          </span>
        </a>
      ))
    }
  </div>
</div>
