---
interface Props {
  heading?: string
  accessibilityLabel: string
  logos: { name: string; src: string }[]
}

const { heading, accessibilityLabel, logos } = Astro.props

// Single source of truth for the carousel geometry, piped into the CSS vars
// below instead of duplicating numbers in <style>. Must be exact: repeatCount
// assumes these match what's rendered, or the wrap point runs out of content.
// logo-carousel-gap: var(--spacing-4xl) = 60px
const LOGO_ITEM_WIDTH_PX = 120
const LOGO_GAP_PX = 60
// Widest the carousel can render at — must match Tailwind's max-w-content.
const MAX_CAROUSEL_WIDTH_PX = 1440

// The track wraps its scroll offset every `period` px (one pass through
// `logos`). It needs enough duplicate copies to never run out of content at
// the widest viewport, or the wrap point shows a gap. Solving
// `MAX_CAROUSEL_WIDTH_PX <= (copies - 1) * period - LOGO_GAP_PX` for the
// smallest integer `copies` gives the formula below.
const period = logos.length * (LOGO_ITEM_WIDTH_PX + LOGO_GAP_PX)
const repeatCount =
  period > 0
    ? Math.max(2, Math.ceil((MAX_CAROUSEL_WIDTH_PX + LOGO_GAP_PX) / period) + 1)
    : 2
const duplicateBatches = Array.from({ length: repeatCount - 1 })

const carouselStyle = `
  --logo-count: ${logos.length};
  --logo-carousel-repeat-count: ${repeatCount};
  --logo-carousel-item-width: ${LOGO_ITEM_WIDTH_PX}px;
  --logo-carousel-gap: ${LOGO_GAP_PX}px;
`

const sectionClasses = `
  px-lg pb-3xl-tight
  bg-neutral-0 text-neutral-900
  tablet:px-xl
  desktop:px-5xl desktop:pb-3xl
`
const containerClasses = `
  max-w-content py-3xl m-auto
  border-t border-neutral-50
`
const headerClasses = `
  mb-xl text-center text-h3
  tablet:text-h3-md
  desktop:text-h3-lg
`
const viewportClasses = `
  logo-carousel
  overflow-x-hidden
  cursor-grab touch-pan-y select-none
  [--mask-fade-width:20%]
  tablet:[--mask-fade-width:25%]
`
const trackClasses = `
  flex items-center gap-[var(--logo-carousel-gap)]
  list-none p-0 m-0
  w-max
  animate-[scroll-left_var(--logo-carousel-cycle)_linear_infinite]
  motion-reduce:animate-none
`
const logoClasses = `
  h-[40px] w-[var(--logo-carousel-item-width)] shrink-0
`
---

<section aria-labelledby="logo-carousel-heading" class={sectionClasses}>
  <div class={containerClasses}>
    <h2 id="logo-carousel-heading" class={headerClasses}>
      {heading}
    </h2>

    <div
      class={viewportClasses}
      style={carouselStyle}
      role="group"
      aria-label={accessibilityLabel}
    >
      {
        /* loading="eager": this track loops forever, so lazy-loading only
        risks a late pop-in when a logo scrolls back into view. */
      }
      <ul class={trackClasses} role="list">
        {
          logos.map((logo) => (
            <li class="m-0">
              <img
                src={logo.src}
                alt={logo.name}
                class={logoClasses}
                width="120"
                height="40"
                loading="eager"
                decoding="async"
                draggable={false}
              />
            </li>
          ))
        }
        {
          /* Duplicate batches for a seamless loop — hidden from AT and
          keyboard via aria-hidden/inert, but kept in layout even under
          reduced motion: dragging is user-initiated. `repeatCount` (computed above)
          ensures there are always enough copies that the track never runs out
          of content mid-wrap, even with very few logos. */
          duplicateBatches.map(() =>
            logos.map((logo) => (
              <li class="m-0" aria-hidden="true" inert>
                <img
                  src={logo.src}
                  alt=""
                  class={logoClasses}
                  width="120"
                  height="40"
                  loading="eager"
                  decoding="async"
                  draggable={false}
                />
              </li>
            ))
          )
        }
      </ul>
    </div>
  </div>
</section>

<style>
  .logo-carousel {
    /* --logo-count, --logo-carousel-repeat-count, --logo-carousel-item-width,
      and --logo-carousel-gap all come from the inline `carouselStyle` set
      per instance (see frontmatter) — kept there, not here, so the numbers
      driving this calc can never drift from the numbers used to decide how
      many duplicate batches got rendered. */
    --logo-carousel-speed: 96px; /* target scroll speed: px per second */
    --logo-carousel-cycle: calc(
      (
          var(--logo-count, 1) *
            (var(--logo-carousel-item-width) + var(--logo-carousel-gap))
        ) /
        var(--logo-carousel-speed) * 1s
    );

    mask-image: linear-gradient(
      to right,
      transparent 0%,
      black var(--mask-fade-width),
      black calc(100% - var(--mask-fade-width)),
      transparent 100%
    );
  }

  @keyframes scroll-left {
    from {
      transform: translateX(0);
    }
    to {
      /* One period's worth of the track, generalized from the exact
        -50% - gap/2 for 2 copies to -100%/copies - gap/copies for N. */
      transform: translateX(
        calc(
          (-100% - var(--logo-carousel-gap)) /
            var(--logo-carousel-repeat-count, 2)
        )
      );
    }
  }
</style>

<script>
  /* Drag + auto-scroll for the logo carousel.
     We take over from the CSS @keyframes, but keep them defined above as a 
     fallback if this script fails to load */

  const carousels = document.querySelectorAll<HTMLElement>('.logo-carousel')
  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)')

  carousels.forEach((carousel) => {
    const track = carousel.querySelector<HTMLUListElement>('ul')
    if (!track) return

    const state = {
      offset: 0,
      wrapDistance: 0,
      speedPxPerSec: 0,
      gap: 0,
      repeatCount: 2,
      cycleSeconds: 30,
      isDragging: false,
      dragStart: { x: 0, offset: 0 },
      lastTime: 0,
      rafId: 0,
      measureRafId: 0
    }

    const updateMeasurements = (): void => {
      // Track contains `repeatCount`x the visual logo set. Wrap point is the
      // distance after which the visual pattern repeats: one copy's worth of
      // the track (mirrors the CSS `(-100% - gap) / repeatCount` end keyframe).
      state.wrapDistance = (track.scrollWidth + state.gap) / state.repeatCount
      state.speedPxPerSec = state.wrapDistance / state.cycleSeconds
    }

    const scheduleMeasurements = (): void => {
      if (state.measureRafId !== 0) return
      state.measureRafId = requestAnimationFrame(() => {
        state.measureRafId = 0
        updateMeasurements()
      })
    }

    const wrapOffset = (value: number): number => {
      if (state.wrapDistance <= 0) return value

      let wrappedOffset = value % state.wrapDistance

      // Keep offsets negative so scrolling direction remains consistent.
      if (wrappedOffset > 0) wrappedOffset -= state.wrapDistance

      return wrappedOffset
    }

    const render = (): void => {
      track.style.transform = `translateX(${state.offset}px)`
    }

    const updateOffset = (value: number): void => {
      state.offset = wrapOffset(value)
      render()
    }

    const tick = (now: number): void => {
      if (!state.isDragging && !reducedMotion.matches) {
        const dt = (now - state.lastTime) / 1000
        updateOffset(state.offset - state.speedPxPerSec * dt)
      }
      state.lastTime = now
      state.rafId = requestAnimationFrame(tick)
    }

    // Clear only animation-name (not the whole shorthand), so
    // animation-duration stays readable below as a resolved number.
    track.style.animationName = 'none'

    // Measured synchronously (not via rAF) so it's ready before the pointer
    // listeners below — otherwise a drag could start against a stale/zero
    // wrapDistance and snap once it lands.
    state.gap = parseFloat(getComputedStyle(track).columnGap) || 0
    state.cycleSeconds =
      parseFloat(getComputedStyle(track).animationDuration) || 30
    state.repeatCount =
      parseFloat(
        getComputedStyle(carousel).getPropertyValue(
          '--logo-carousel-repeat-count'
        )
      ) || 2
    updateMeasurements()
    state.lastTime = performance.now()
    state.rafId = requestAnimationFrame(tick)

    // Recompute wrap distance when the track resizes (images loading, viewport
    // resize, font swaps — anything that changes scrollWidth).
    const resizeObserver = new ResizeObserver(scheduleMeasurements)
    resizeObserver.observe(track)

    carousel.addEventListener('pointerdown', (event) => {
      // Ignore non-primary mouse buttons (right/middle/back/forward) and
      // secondary touch points on multi-touch devices.
      if (event.button !== 0 || !event.isPrimary) return
      state.isDragging = true
      state.dragStart.x = event.clientX
      state.dragStart.offset = state.offset
      carousel.setPointerCapture(event.pointerId)
      carousel.style.cursor = 'grabbing'
    })

    carousel.addEventListener('pointermove', (event) => {
      if (!state.isDragging) return
      updateOffset(state.dragStart.offset + (event.clientX - state.dragStart.x))
    })

    const endDrag = (event: PointerEvent): void => {
      if (!state.isDragging) return

      state.isDragging = false

      if (carousel.hasPointerCapture(event.pointerId)) {
        carousel.releasePointerCapture(event.pointerId)
      }
      carousel.style.cursor = ''
      // Reset lastTime so the resumed auto-scroll doesn't jump by the drag duration.
      state.lastTime = performance.now()
    }
    carousel.addEventListener('pointerup', endDrag)
    carousel.addEventListener('pointercancel', endDrag)

    // Cleanup when the page is unloaded
    const cleanup = (): void => {
      cancelAnimationFrame(state.rafId)
      if (state.measureRafId !== 0) cancelAnimationFrame(state.measureRafId)
      resizeObserver.disconnect()
    }

    window.addEventListener('pagehide', cleanup, { once: true })
  })
</script>
