---
/**
 * Profile Grid Block for Dynamic Zones (SSR Preview)
 * Renders the profiles selected (or category-filtered) by content authors in Strapi
 * Converts markdown descriptions to HTML for preview rendering
 */

import ProfileGrid from '@/components/shared/ProfileGrid.astro'
import { toProfileData } from '@/utils'
import type {
  StrapiProfile,
  ProfileData
} from '@/components/shared/profile.types'

interface Props {
  heading?: string
  profiles?: StrapiProfile[]
  category?: string
}

const { heading, profiles: strapiProfiles, category } = Astro.props

// Transform Strapi profile data to the format expected by ProfileGrid.
// Manually picked relations take priority; ProfileGrid falls back to its own
// category-based collection lookup when no profiles are provided.
const profiles: ProfileData[] | undefined = strapiProfiles?.length
  ? strapiProfiles.map((profile) => toProfileData(profile))
  : undefined
---

<ProfileGrid profiles={profiles} heading={heading} category={category} />
