---
import OptimizedImage from '@/components/shared/OptimizedImage.astro'
import VideoEmbed from '@/components/shared/VideoEmbed.astro'
import LinkButton from '@/components/shared/LinkButton.astro'
import Icon from '@/components/shared/Icon.astro'
import Blockquote from '@/components/shared/Blockquote.astro'

/** Content-to-media column ratio (admin labels). Astro maps these to grid `fr` tracks. */
export type SplitLayoutDisplayRatio = '1:1' | '1:2' | '2:1'

interface Props {
  layoutType?: 'image-text' | 'image-quote' | 'video-text' | 'video-quote'
  /** Which side the image or video column appears on. Default: right. */
  imagePosition?: 'left' | 'right'
  /**
   * Content : media width ratio. Default: 1:1.
   * Uses CSS grid `fr` units with the design-system 120px (`gap-6xl`) gutter.
   */
  displayRatio?: SplitLayoutDisplayRatio
  imageSrc?: string
  imageAlt?: string
  videoUrl?: string
  quote?: string
  quoteSource?: string
  ctaText?: string
  ctaLink?: string
  ctaStyle?: string
  ctaExternal?: boolean
}

const DISPLAY_RATIOS = ['1:1', '1:2', '2:1'] as const

/** Full class strings so Tailwind can detect them at build time. */
const GRID_COLS_BY_ORDER_AND_RATIO = {
  // media column first in the DOM (imagePosition=left)
  left: {
    '1:1': 'tablet:grid-cols-2',
    // content:media 2:1 → media 1fr, content 2fr
    '2:1': 'tablet:grid-cols-[1fr_2fr]',
    // content:media 1:2 → media 2fr, content 1fr
    '1:2': 'tablet:grid-cols-[2fr_1fr]'
  },
  // content column first in the DOM (imagePosition=right)
  right: {
    '1:1': 'tablet:grid-cols-2',
    '2:1': 'tablet:grid-cols-[2fr_1fr]',
    '1:2': 'tablet:grid-cols-[1fr_2fr]'
  }
} as const satisfies Record<
  'left' | 'right',
  Record<SplitLayoutDisplayRatio, string>
>

const {
  layoutType,
  imagePosition = 'right',
  displayRatio: displayRatioProp,
  imageSrc,
  imageAlt,
  videoUrl,
  quote,
  quoteSource,
  ctaText,
  ctaLink,
  ctaStyle,
  ctaExternal
} = Astro.props

// Unknown ratios fall back to 1:1 here; sync handler/serializer hard-fail instead.
const displayRatio: SplitLayoutDisplayRatio =
  displayRatioProp &&
  (DISPLAY_RATIOS as readonly string[]).includes(displayRatioProp)
    ? displayRatioProp
    : '1:1'

const isVideoLayout = layoutType
  ? layoutType.startsWith('video')
  : Boolean(videoUrl)
const isQuoteLayout = layoutType
  ? layoutType.endsWith('-quote')
  : Boolean(quote)
const hasMedia = isVideoLayout ? Boolean(videoUrl) : Boolean(imageSrc)
const mediaFirst = imagePosition === 'left'

const gridColsClass = hasMedia
  ? GRID_COLS_BY_ORDER_AND_RATIO[mediaFirst ? 'left' : 'right'][displayRatio]
  : 'tablet:grid-cols-1'

const columnClass = 'w-full min-w-0'
const contentColumnClass = `${columnClass} flex flex-col gap-2xl`
---

<div
  class:list={[
    'mt-0 mb-5xl flex flex-col gap-3xl tablet:my-5xl tablet:grid tablet:items-center tablet:gap-6xl',
    gridColsClass
  ]}
>
  {
    mediaFirst && hasMedia && (
      <div class={columnClass}>
        {isVideoLayout && videoUrl ? (
          <VideoEmbed url={videoUrl} title="Video" />
        ) : imageSrc ? (
          <OptimizedImage
            src={imageSrc}
            alt={imageAlt ?? ''}
            width={640}
            height={480}
            loading="lazy"
            class="w-full h-auto rounded-lg object-cover"
          />
        ) : null}
      </div>
    )
  }

  <div class={contentColumnClass}>
    {
      isQuoteLayout && quote ? (
        <Blockquote quote={quote} source={quoteSource} />
      ) : (
        <>
          <div class="[&>*:last-child]:mb-0">
            <slot />
          </div>
          {ctaText && ctaLink && (
            <div>
              <LinkButton
                href={ctaLink}
                variant={ctaStyle === 'secondary' ? 'secondary' : 'primary'}
                external={ctaExternal}
              >
                {ctaText}
                {ctaExternal && <Icon name="arrow-right" slot="icon-right" />}
              </LinkButton>
            </div>
          )}
        </>
      )
    }
  </div>

  {
    !mediaFirst && hasMedia && (
      <div class={columnClass}>
        {isVideoLayout && videoUrl ? (
          <VideoEmbed url={videoUrl} title="Video" />
        ) : imageSrc ? (
          <OptimizedImage
            src={imageSrc}
            alt={imageAlt ?? ''}
            width={640}
            height={480}
            loading="lazy"
            class="w-full h-auto rounded-lg object-cover"
          />
        ) : null}
      </div>
    )
  }
</div>
