---
import { buildUmamiAttrs } from '@/utils'
import Icon from '../shared/Icon.astro'
import LinkButton from '../shared/LinkButton.astro'

interface Props {
  heading: string
  description?: string
  primaryButtonText?: string
  primaryButtonLink?: string
  secondaryButtonText?: string
  secondaryButtonLink?: string
  color?: 'purple' | 'green'
  /** Optional Umami page-segment override (e.g. set per page). */
  umamiContext?: string
}

const {
  heading,
  description,
  primaryButtonText,
  primaryButtonLink,
  secondaryButtonText,
  secondaryButtonLink,
  color = 'purple',
  umamiContext
} = Astro.props

const { routeLocale } = Astro.locals

// Analytics: every CTA click is labelled `cta_button` (see INTORG-789), so both
// buttons share the action segment and are distinguished by their link text.
const umamiBase = {
  page: umamiContext,
  pathname: Astro.url.pathname,
  lang: routeLocale,
  section: 'cta' as const,
  action: 'cta_button'
}

const bgClasses: Record<NonNullable<Props['color']>, string> = {
  purple: 'bg-soft-indigo-50',
  green: 'bg-pistachio-100'
}

// Decorative network motif per colour: the green strip uses a variant whose
// largest node is recoloured green (the shared purple node reads muddy on green).
const gridSrc: Record<NonNullable<Props['color']>, string> = {
  purple: '/img/blocks/cta-strip-network.svg',
  green: '/img/blocks/cta-strip-network-green.svg'
}

// `description` arrives as a prop from the Strapi dynamic-zone renderer, but as
// slot children when the component is used in exported MDX. Support both.
const hasDescription = Boolean(description) || Astro.slots.has('default')

const hasPrimary = Boolean(primaryButtonText && primaryButtonLink)
const hasSecondary = Boolean(secondaryButtonText && secondaryButtonLink)

const isExternal = (href: string) => /^https?:\/\//i.test(href)
---

<section
  class:list={[
    'relative isolate overflow-clip rounded-3xl',
    'px-lg py-xl tablet:p-2xl desktop:p-3xl-tight',
    bgClasses[color] ?? bgClasses.purple
  ]}
>
  {
    /* Decorative Interledger network motif bleeding off the left edge.
      Absolutely positioned so it never affects layout (no CLS); hidden from
      the a11y tree. Low opacity so the nodes read as muted over the card. */
  }
  <img
    src={gridSrc[color] ?? gridSrc.purple}
    alt=""
    aria-hidden="true"
    width="450"
    height="450"
    loading="lazy"
    class="pointer-events-none absolute left-0 top-1/2 -z-10 h-[135%] w-auto max-w-none aspect-square -translate-x-1/4 -translate-y-1/2 rotate-90 opacity-40"
  />

  <div class="flex flex-col items-center gap-lg text-center">
    <h2
      class="font-poppins text-h3 tablet:text-h3-md desktop:text-h3-lg my-0 text-neutral-900"
    >
      {heading}
    </h2>

    {
      hasDescription && (
        <div class="font-poppins text-h4 tablet:text-h4-md desktop:text-h4-lg text-neutral-100 [&_p]:my-0">
          <slot>{description}</slot>
        </div>
      )
    }

    {
      (hasPrimary || hasSecondary) && (
        <div class="flex w-full flex-col items-stretch gap-sm tablet:w-fit">
          {hasPrimary && (
            <LinkButton
              href={primaryButtonLink!}
              variant="primary"
              external={isExternal(primaryButtonLink!)}
              class="w-full"
              {...buildUmamiAttrs({
                ...umamiBase,
                href: primaryButtonLink,
                linkText: primaryButtonText
              })}
            >
              {primaryButtonText}
              <Icon name="arrow-right" slot="icon-right" />
            </LinkButton>
          )}

          {hasSecondary && (
            <LinkButton
              href={secondaryButtonLink!}
              variant="secondary"
              external={isExternal(secondaryButtonLink!)}
              class="w-full"
              {...buildUmamiAttrs({
                ...umamiBase,
                href: secondaryButtonLink,
                linkText: secondaryButtonText
              })}
            >
              {secondaryButtonText}
            </LinkButton>
          )}
        </div>
      )
    }
  </div>
</section>
