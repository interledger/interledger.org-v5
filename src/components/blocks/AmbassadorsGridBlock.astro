---
/**
 * Ambassadors Grid Block for Dynamic Zones (SSR Preview)
 * Renders the ambassadors selected by content authors in Strapi
 * Converts markdown descriptions to HTML for preview rendering
 */

import AmbassadorGrid from '@/components/ambassadors/AmbassadorGrid.astro'
import { useTranslations, toAmbassadorData } from '@/utils'
import type {
  StrapiAmbassador,
  AmbassadorData
} from '@/components/ambassadors/types'

interface Props {
  heading?: string
  ambassadors?: StrapiAmbassador[]
  category?: string
}

const { heading, ambassadors: strapiAmbassadors = [], category } = Astro.props
const { routeLocale } = Astro.locals
const t = useTranslations(routeLocale)

// Transform Strapi ambassador data to the format expected by AmbassadorGrid
// Convert markdown description to HTML for preview rendering
const ambassadors: AmbassadorData[] = strapiAmbassadors.map((amb) =>
  toAmbassadorData(amb)
)
---

{
  ambassadors.length > 0 ? (
    <AmbassadorGrid
      ambassadors={ambassadors}
      heading={heading}
      category={category}
    />
  ) : (
    <p class="text-gray">{t('ambassadors.no_grid')}</p>
  )
}
