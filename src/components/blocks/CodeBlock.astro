---
import { codeToHtml } from 'shiki'
import { useTranslations } from '@/utils'

interface Props {
  code: string
  language: string
  title?: string
}

const { code, language, title } = Astro.props
const { routeLocale } = Astro.locals
const t = useTranslations(routeLocale)

const highlighted = await codeToHtml(code, {
  lang: language,
  theme: 'github-dark-dimmed'
})
---

<figure
  class="my-0 rounded-lg overflow-hidden shadow-lg text-step--1"
  data-component="code-block"
>
  {/* Title bar */}
  <div
    class="flex items-center gap-space-xs px-space-s py-space-2xs bg-[#1e2127] border-b border-white/10"
  >
    {/* Decorative window dots */}
    <div class="flex items-center gap-[6px] shrink-0" aria-hidden="true">
      <span class="block h-3 w-3 rounded-full bg-[#ff5f57]"></span>
      <span class="block h-3 w-3 rounded-full bg-[#febc2e]"></span>
      <span class="block h-3 w-3 rounded-full bg-[#28c840]"></span>
    </div>

    {/* Filename / title */}
    <span class="flex-1 text-center font-mono text-neutral-75 text-step--2 truncate">
      {title ?? language}
    </span>

    {/* Copy button */}
    <button
      type="button"
      class="copy-btn shrink-0 rounded px-space-2xs py-[2px] text-step--2 font-mono
             text-neutral-75 hover:text-white bg-white/5 hover:bg-white/15
             transition-colors focus-visible:outline focus-visible:outline-2
             focus-visible:outline-offset-2 focus-visible:outline-white/60"
      data-code={code}
      data-copy-label={t('codeBlock.copy')}
      data-copied-label={t('codeBlock.copied')}
      data-umami-event="button"
      aria-label={t('codeBlock.copy')}
    >
      {t('codeBlock.copy')}
    </button>
  </div>

  {/* Highlighted code */}
  <div
    class="overflow-x-auto
           [&_pre]:m-0 [&_pre]:p-space-s [&_pre]:leading-relaxed
           [&_code]:font-mono [&_code]:text-step--1
           [&_.line]:min-h-[1.5em]"
    set:html={highlighted}
  />
</figure>

<script>
  document.addEventListener('click', (e) => {
    const btn = (e.target as Element)?.closest<HTMLButtonElement>('.copy-btn')
    if (!btn) return

    const code = btn.dataset.code ?? ''
    const copyLabel = btn.dataset.copyLabel ?? 'Copy'
    const copiedLabel = btn.dataset.copiedLabel ?? 'Copied!'

    navigator.clipboard.writeText(code).then(() => {
      btn.textContent = copiedLabel
      btn.setAttribute('aria-label', copiedLabel)
      setTimeout(() => {
        btn.textContent = copyLabel
        btn.setAttribute('aria-label', copyLabel)
      }, 2000)
    })
  })
</script>
