---
import { codeToHtml } from 'shiki'
import { useTranslations } from '@/utils'

interface Props {
  code: string
  language: string
  title?: string
}

const { code, language, title } = Astro.props
const { routeLocale } = Astro.locals
const t = useTranslations(routeLocale)

const highlighted = await codeToHtml(code, {
  lang: language,
  theme: 'github-light'
})
---

<figure
  class="my-0 rounded-lg overflow-hidden border border-neutral-25 text-step--1"
  data-component="code-block"
>
  {/* Title bar */}
  <div
    class="flex items-center gap-space-xs px-space-s py-space-2xs bg-[#f6f8fa] border-b border-neutral-25"
  >
    {/* Decorative window dots */}
    <div class="flex items-center gap-[6px] shrink-0" aria-hidden="true">
      <span class="block h-3 w-3 rounded-full bg-[#ff5f57]"></span>
      <span class="block h-3 w-3 rounded-full bg-[#febc2e]"></span>
      <span class="block h-3 w-3 rounded-full bg-[#28c840]"></span>
    </div>

    {/* Filename / title */}
    <span class="flex-1 text-neutral-900 text-step--2 truncate">
      {title ?? language}
    </span>

    {/* Copy button */}
    <button
      type="button"
      class="copy-btn shrink-0 inline-flex items-center gap-[5px] cursor-pointer
             text-step--2 text-neutral-900/40 hover:text-neutral-900
             transition-colors focus-visible:outline focus-visible:outline-2
             focus-visible:outline-offset-2 focus-visible:outline-neutral-900/40"
      data-code={code}
      data-copy-label={t('codeBlock.copy')}
      data-copied-label={t('codeBlock.copied')}
      data-umami-event="button"
      aria-label={t('codeBlock.copy')}
    >
      {t('codeBlock.copy')}
      <svg
        aria-hidden="true"
        viewBox="0 0 16 16"
        class="h-3.5 w-3.5 shrink-0"
        fill="none"
      >
        <rect
          x="5.5"
          y="1.5"
          width="9"
          height="11"
          rx="1.5"
          stroke="currentColor"
          stroke-width="1.25"></rect>
        <path
          d="M3.5 4.5H2a1 1 0 0 0-1 1V14a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1v-1.5"
          stroke="currentColor"
          stroke-width="1.25"
          stroke-linecap="round"></path>
      </svg>
    </button>
  </div>

  {/* Highlighted code */}
  <div
    class="overflow-x-auto
           [&_pre]:m-0 [&_pre]:p-space-s [&_pre]:leading-relaxed [&_pre]:bg-white!
           [&_code]:font-mono [&_code]:text-step--1
           [&_.line]:min-h-[1.5em]"
    set:html={highlighted}
  />
</figure>

<script>
  document.addEventListener('click', (e) => {
    const btn = (e.target as Element)?.closest<HTMLButtonElement>('.copy-btn')
    if (!btn) return

    const code = btn.dataset.code ?? ''
    const copyLabel = btn.dataset.copyLabel ?? 'Copy'
    const copiedLabel = btn.dataset.copiedLabel ?? 'Copied!'

    navigator.clipboard.writeText(code).then(() => {
      btn.textContent = copiedLabel
      btn.setAttribute('aria-label', copiedLabel)
      setTimeout(() => {
        btn.textContent = copyLabel
        btn.setAttribute('aria-label', copyLabel)
      }, 2000)
    })
  })
</script>
