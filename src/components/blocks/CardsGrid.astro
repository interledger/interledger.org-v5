---
import { buildUmamiAttrs } from '@/utils'

interface Card {
  title: string
  description?: string
  link?: string
  linkText?: string
  icon?: string
  openInNewTab?: boolean
}

interface Props {
  heading?: string
  subheading?: string
  cards: Card[]
  columns?: '2' | '3' | '4'
  umamiContext?: string
}

const { heading, subheading, cards, columns = '3', umamiContext } = Astro.props
const { routeLocale } = Astro.locals
const umamiBase = {
  page: umamiContext,
  pathname: Astro.url.pathname,
  lang: routeLocale,
  section: 'card' as const
}

const gridClass =
  columns === '2'
    ? 'grid-cols-[repeat(auto-fit,minmax(280px,1fr))]'
    : columns === '4'
      ? 'grid-cols-[repeat(auto-fit,minmax(220px,1fr))]'
      : 'grid-cols-[repeat(auto-fit,minmax(250px,1fr))]'
---

<div class="max-w-wide mx-auto">
  {
    heading && (
      <div class="text-center mb-3xl">
        <h2 class="text-[2rem] font-semibold text-primary mb-lg">{heading}</h2>
        {subheading && (
          <p class="text-[1.125rem] text-neutral-75 max-w-[600px] mx-auto">
            {subheading}
          </p>
        )}
      </div>
    )
  }
  <div class={`grid gap-3xl mx-auto ${gridClass}`}>
    {
      cards.map((card) => (
        <article class="rounded-lg border border-neutral-75-200 bg-white p-3xl text-black shadow-[0_2px_10px_rgba(0,0,0,0.08)] transition-shadow duration-200 hover:shadow-[0_4px_12px_rgba(0,0,0,0.1)]">
          {card.icon && <div class="w-12 h-12 mb-xl" set:html={card.icon} />}
          <h3 class="text-[1.5rem] font-normal leading-snug mb-lg text-black">
            {card.title}
          </h3>
          {card.description && (
            <p class="text-neutral-75 leading-normal mb-xl">
              {card.description}
            </p>
          )}
          {card.link && (
            <a
              href={card.link}
              class="text-primary no-underline font-medium hover:underline"
              {...buildUmamiAttrs({
                ...umamiBase,
                href: card.link,
                linkText: card.title
              })}
              {...(card.openInNewTab
                ? { target: '_blank', rel: 'noopener noreferrer' }
                : {})}
            >
              {card.linkText || 'Learn more'} &rarr;
            </a>
          )}
        </article>
      ))
    }
  </div>
</div>
