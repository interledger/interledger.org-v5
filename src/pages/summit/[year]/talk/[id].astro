---
import type { GetStaticPaths } from 'astro'
import { getSessionPages } from '@/utils'
import SessionDetailPage from '@/components/summit/SessionDetailPage.astro'
import type { Talk } from '@/types/summit'

interface Props {
  entry: Talk
}

export const getStaticPaths: GetStaticPaths = async () => {
  const entries = await getSessionPages()
  return entries
}

const { year } = Astro.params
const { entry } = Astro.props
if (!year) {
  throw new Error('Year param is required')
}
if (!entry) {
  return Astro.redirect('/404')
}
---

<SessionDetailPage entry={entry} year={year} />
