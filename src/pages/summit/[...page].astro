---
import SummitContentPage from '@/components/pages/SummitContentPage.astro'
import { getLocalizedPaths } from '@/utils/main/static-paths'
import { HOME_CONTENT_SLUG } from '@/utils/main/routes'

export async function getStaticPaths() {
  return getLocalizedPaths('summit-pages', 'en', 'page', {
    excludeSlug: HOME_CONTENT_SLUG
  })
}

const { slug, locale: contentLocale } = Astro.props
---

<SummitContentPage slug={slug} contentLocale={contentLocale} />
