---
import SummitContentPage from '@/components/pages/SummitContentPage.astro'
import ProfileDetailPage from '@/components/pages/ProfileDetailPage.astro'
import { getLocalizedPaths, getProfilePaths, HOME_CONTENT_SLUG } from '@/utils'

export async function getStaticPaths() {
  const pages = (
    await getLocalizedPaths('summit-pages', 'en', 'page', {
      excludeSlug: HOME_CONTENT_SLUG
    })
  ).map((p) => ({ ...p, props: { ...p.props, kind: 'page' as const } }))
  const profiles = await getProfilePaths('summit', 'en', 'page')
  return [...pages, ...profiles]
}

const { slug, locale: contentLocale, kind, isFallback } = Astro.props
---

{
  kind === 'profile' ? (
    <ProfileDetailPage
      slug={slug}
      contentLocale={contentLocale}
      isFallback={isFallback}
    />
  ) : (
    <SummitContentPage slug={slug} contentLocale={contentLocale} />
  )
}
