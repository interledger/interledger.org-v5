---
import { paginateAllPosts } from '@/utils'
import type { GetStaticPaths, Page } from 'astro'
import FoundationBlogListingPage from '@/components/blog/FoundationBlogListingPage.astro'

type Props = {
  page: Page
  allTags: string[]
}

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const paths = await paginateAllPosts({
    paginate,
    collection: 'foundation-blog',
    lang: 'en'
  })
  return paths
}

const { page, allTags } = Astro.props
---

<FoundationBlogListingPage page={page} allTags={allTags} blogPath="/blog" />
