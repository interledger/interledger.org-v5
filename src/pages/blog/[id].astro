---
import FoundationBlogPostPage from '@/components/blog/FoundationBlogPostPage.astro'
import { getLocalizedPaths } from '@/utils'

export async function getStaticPaths() {
  return getLocalizedPaths('foundation-blog', 'en', 'id')
}

const { slug, locale: contentLocale } = Astro.props
---

<FoundationBlogPostPage slug={slug} contentLocale={contentLocale} />
