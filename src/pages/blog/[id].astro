---
import FoundationBlogPostPage from '@/components/blog/FoundationBlogPostPage.astro'
import { getLocalizedPaths } from '@/utils/static-paths'

export async function getStaticPaths() {
  return getLocalizedPaths('foundation-blog', 'en', 'id')
}

const { slug, locale } = Astro.props
---

<FoundationBlogPostPage slug={slug} locale={locale} />
