---
import FoundationContentPage from '@/components/pages/FoundationContentPage.astro'
import GrantOverviewPage from '@/components/pages/GrantOverviewPage.astro'
import GrantPage from '@/components/pages/GrantPage.astro'
import ProfileDetailPage from '@/components/pages/ProfileDetailPage.astro'
import { getLocalizedPaths, getProfilePaths } from '@/utils'

export async function getStaticPaths() {
  const [foundationPages, grantPages, grantOverviews, profiles] =
    await Promise.all([
      getLocalizedPaths('foundation-pages', 'en', 'page'),
      getLocalizedPaths('grant-pages', 'en', 'page'),
      getLocalizedPaths('grant-overview-pages', 'en', 'page'),
      getProfilePaths('foundation', 'en', 'page')
    ])

  return [
    ...profiles,
    ...foundationPages.map((p) => ({
      ...p,
      props: { ...p.props, kind: 'page' as const }
    })),
    ...grantPages.map((p) => ({
      params: { page: `grant/${p.params.page}` },
      props: { ...p.props, kind: 'grant-page' as const }
    })),
    ...grantOverviews.map((p) => ({
      params: { page: `grant/${p.params.page}` },
      props: { ...p.props, kind: 'grant-overview-page' as const }
    }))
  ]
}

const { slug, locale: contentLocale, kind, isFallback } = Astro.props
---

{
  kind === 'profile' ? (
    <ProfileDetailPage
      slug={slug}
      contentLocale={contentLocale}
      isFallback={isFallback}
    />
  ) : kind === 'grant-page' ? (
    <GrantPage
      slug={slug}
      contentLocale={contentLocale}
      isFallback={isFallback}
    />
  ) : kind === 'grant-overview-page' ? (
    <GrantOverviewPage
      slug={slug}
      contentLocale={contentLocale}
      isFallback={isFallback}
    />
  ) : (
    <FoundationContentPage slug={slug} contentLocale={contentLocale} />
  )
}
