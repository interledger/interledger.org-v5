---
import FoundationContentPage from '@/components/pages/FoundationContentPage.astro'
import { getLocalizedPaths } from '@/utils/static-paths'
import { HOME_CONTENT_SLUG } from '@/utils/routes'

export async function getStaticPaths() {
  return getLocalizedPaths('foundation-pages', 'en', 'page', {
    excludeSlug: HOME_CONTENT_SLUG
  })
}

const { slug, locale: contentLocale } = Astro.props
---

<FoundationContentPage slug={slug} contentLocale={contentLocale} />
