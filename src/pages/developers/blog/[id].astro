---
import DevelopersBlogPostPage from '@/components/pages/DevelopersBlogPostPage.astro'
import { getLocalizedPaths } from '@/utils/static-paths'

export async function getStaticPaths() {
  return getLocalizedPaths('developers-blog', 'en', 'id')
}

const { slug, locale } = Astro.props
---

<DevelopersBlogPostPage slug={slug} locale={locale} />
