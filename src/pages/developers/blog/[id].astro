---
import DevelopersBlogPostPage from '@/components/pages/DevelopersBlogPostPage.astro'
import { getLocalizedPaths } from '@/utils'

export async function getStaticPaths() {
  return getLocalizedPaths('developers-blog', 'en', 'id')
}

const { slug, locale: contentLocale } = Astro.props
---

<DevelopersBlogPostPage slug={slug} contentLocale={contentLocale} />
