---
import { paginateAllPosts } from '@/utils/tagFilter'
import type { GetStaticPaths, Page } from 'astro'
import DevelopersBlogListingPage from '@/components/pages/DevelopersBlogListingPage.astro'

type Props = {
  page: Page
  allTags: string[]
}

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const paths = await paginateAllPosts({
    paginate,
    collection: 'developers-blog',
    lang: 'en'
  })
  return paths
}

const { page, allTags } = Astro.props
---

<DevelopersBlogListingPage
  page={page}
  allTags={allTags}
  blogPath="/developers/blog"
  developersHomePath="/developers"
  foundationBlogPath="/blog"
/>
