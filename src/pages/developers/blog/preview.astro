---
import FoundationPageLayout from '@/layouts/FoundationPageLayout.astro'
import { buildBlogIndexLanguageHrefs } from '@/utils/blog-language-hrefs'

// Developers blog is not in Strapi (phase 1). Content is rendered from MDX files.
// Preview from Strapi is not available until developers-blog-posts is added to the CMS.
export const prerender = false
const languageHrefs = buildBlogIndexLanguageHrefs('/developers/blog')
---

<FoundationPageLayout
  title="Preview not available"
  description="Developers blog content is rendered from MDX files in the repository. Strapi preview is not available for this content type."
  languageHrefs={languageHrefs}
>
  <main class="mx-auto max-w-content px-[5%] py-space-xl">
    <p class="text-step-0">
      Developers blog preview is not available. Content is loaded from MDX files
      in <code>src/content/developers-blog-posts/</code> and rendered at build time.
    </p>
    <p class="mt-space-m text-step-0">
      <a href="/developers/blog" class="text-primary underline"
        >View the developers blog</a
      >
    </p>
  </main>
</FoundationPageLayout>
