---
import FoundationPageLayout from '@/layouts/FoundationPageLayout.astro'
import { applyPreviewNoStore } from '@/utils/cache'
import { useTranslations } from '@/utils/i18'

// Developers blog is not in Strapi (phase 1). Content is rendered from MDX files.
// Preview from Strapi is not available until developers-blog-posts is added to the CMS.
export const prerender = false
applyPreviewNoStore(Astro.response.headers)
const { routeLocale } = Astro.locals
const t = useTranslations(routeLocale)
---

<FoundationPageLayout
  title={t('blog.preview.title')}
  description={t('blog.preview.description')}
>
  <main class="mx-auto max-w-content px-[5%] py-space-xl">
    <p class="text-step-0">
      {t('blog.preview.body')}
      <code>src/content/developers-blog-posts/</code>
      {t('blog.preview.body_suffix')}
    </p>
    <p class="mt-space-m text-step-0">
      <a href="/developers/blog" class="text-primary underline"
        >{t('blog.preview.link')}</a
      >
    </p>
  </main>
</FoundationPageLayout>
