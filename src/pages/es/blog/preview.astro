---
import CommunityLinksFoundation from '@/components/blog/CommunityLinksFoundation.astro'
import BlogPostLayout from '@/layouts/BlogPostLayout.astro'
import { fetchStrapi } from '@/utils'
import { marked } from 'marked'

interface BlogPostPreview {
  title: string
  description: string
  pathSlug: string
  locale: string
  publishedAt: string
  lastUpdated?: string
  featured?: boolean
  featureImage?: { url?: string; alternativeText?: string }
  featureImageMobile?: { url?: string; alternativeText?: string }
  content?: string
}

// Get the documentId from the query string
export const prerender = false
const documentId = Astro.url.searchParams.get('pathSlug')
if (!documentId) {
  throw new Error('Missing documentId in preview URL')
}

// Always fetch draft content for preview
const response = await fetchStrapi<BlogPostPreview>(
  `api/foundation-blog-posts/${documentId}?status=draft`
)
if (response instanceof Error) throw response
const article = response.data
if (!article) {
  throw new Error(`Preview: No article found for documentId "${documentId}"`)
}

// Map Strapi fields to BlogPostLayout frontmatter
const frontmatter = {
  title: article.title,
  description: article.description,
  pathSlug: article.pathSlug,
  locale: article.locale,
  date: new Date(article.publishedAt),
  lastUpdated: article.lastUpdated ? new Date(article.lastUpdated) : undefined,
  featured: article.featured ?? false,
  featureImage: article.featureImage?.url,
  featureImageAlt: article.featureImage?.alternativeText ?? '',
  featureImageMobile: article.featureImageMobile?.url,
  featureImageMobileAlt: article.featureImageMobile?.alternativeText ?? '',
  articleBios: [],
  categories: [],
  relatedArticles: [],
  legacy: false
}

const bodyHtml = marked.parse(article.content ? article.content : '')
---

<BlogPostLayout frontmatter={frontmatter}>
  <article set:html={bodyHtml} />
  <CommunityLinksFoundation />
</BlogPostLayout>
