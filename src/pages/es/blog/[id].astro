---
import FoundationBlogPostPage from '@/components/blog/FoundationBlogPostPage.astro'
import { getLocalizedPaths } from '@/utils/static-paths'

export async function getStaticPaths() {
  return getLocalizedPaths('foundation-blog', 'es', 'id')
}

const { slug, locale: contentLocale } = Astro.props
---

<FoundationBlogPostPage
  slug={slug}
  contentLocale={contentLocale}
  routeLocale="es"
/>
