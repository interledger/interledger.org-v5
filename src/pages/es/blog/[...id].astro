---
import { getCollection, render } from 'astro:content'
import CommunityLinksFoundation from '@/components/blog/CommunityLinksFoundation.astro'
import ArticleTags from '@/components/blog/ArticleTags.astro'
import ArticleBio from '@/components/blog/ArticleBio.astro'
import FoundationBlogLayout from '@/layouts/FoundationBlogLayout.astro'
import {
  buildBlogPostLanguageHrefs,
  stripLocaleFromEntryId
} from '@/utils/blog-language-hrefs'

export async function getStaticPaths() {
  const blogEntries = await getCollection('foundation-blog')
  const ids = Array.from(
    new Set(blogEntries.map((entry) => stripLocaleFromEntryId(entry.id)))
  )

  return ids.map((id) => ({
    params: { id }
  }))
}

const id = Astro.params.id
if (!id) {
  throw new Error('Missing foundation blog id.')
}

const blogEntries = await getCollection('foundation-blog')
const entry =
  blogEntries.find((candidate) => candidate.id === `es/${id}`) ??
  blogEntries.find((candidate) => candidate.id === id)

if (!entry) {
  throw new Error(`Foundation blog entry "${id}" was not found.`)
}

const { Content } = await render(entry)
const languageHrefs = buildBlogPostLanguageHrefs('/blog', entry.id)
---

<FoundationBlogLayout frontmatter={entry.data} languageHrefs={languageHrefs}>
  <Content />
  <CommunityLinksFoundation />
  {
    entry.data.articleBios &&
      entry.data.articleBios.map((bio) => {
        if (!bio.text) return
        return (
          <ArticleBio
            text={bio.text}
            imageUrl={bio.image}
            imageAlt={bio.author}
          />
        )
      })
  }
  {entry.data.tags?.length > 0 && <ArticleTags tags={entry.data.tags} />}
</FoundationBlogLayout>
