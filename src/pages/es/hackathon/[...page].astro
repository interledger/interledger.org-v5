---
import ProfileDetailPage from '@/components/pages/ProfileDetailPage.astro'
import FaqPage from '@/components/pages/FaqPage.astro'
import ReportPage from '@/components/pages/ReportPage.astro'
import HackathonContentPage from '@/components/pages/HackathonContentPage.astro'
import { getLocalizedPaths, getCrossSectionPaths } from '@/utils'

export async function getStaticPaths() {
  const pages = (await getLocalizedPaths('hackathon-pages', 'es', 'page')).map(
    (p) => ({ ...p, props: { ...p.props, kind: 'page' as const } })
  )
  const crossSectionPaths = await getCrossSectionPaths(
    'hackathon',
    'es',
    'page'
  )
  return [...crossSectionPaths, ...pages]
}

const { slug, locale: contentLocale, kind, isFallback } = Astro.props
---

{
  kind === 'faq' ? (
    <FaqPage
      slug={slug}
      contentLocale={contentLocale}
      isFallback={isFallback}
    />
  ) : kind === 'report' ? (
    <ReportPage
      slug={slug}
      contentLocale={contentLocale}
      isFallback={isFallback}
    />
  ) : kind === 'profile' ? (
    <ProfileDetailPage
      slug={slug}
      contentLocale={contentLocale}
      isFallback={isFallback}
    />
  ) : (
    <HackathonContentPage
      slug={slug}
      contentLocale={contentLocale}
      isFallback={isFallback}
    />
  )
}
