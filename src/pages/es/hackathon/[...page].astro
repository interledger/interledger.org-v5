---
import ProfileDetailPage from '@/components/pages/ProfileDetailPage.astro'
import FaqDetailPage from '@/components/pages/FaqDetailPage.astro'
import { getCrossSectionPaths } from '@/utils'

export async function getStaticPaths() {
  return getCrossSectionPaths('hackathon', 'es', 'page')
}

const { slug, locale: contentLocale, kind, isFallback } = Astro.props
---

{
  kind === 'faq' ? (
    <FaqDetailPage
      slug={slug}
      contentLocale={contentLocale}
      isFallback={isFallback}
    />
  ) : (
    <ProfileDetailPage
      slug={slug}
      contentLocale={contentLocale}
      isFallback={isFallback}
    />
  )
}
