---
import AmbassadorDetailPage from '@/components/pages/AmbassadorDetailPage.astro'
import { getLocalizedPaths, type Locale } from '@/utils'

interface Props {
  slug: string
  locale: Locale
  isFallback?: boolean
}

export async function getStaticPaths() {
  return getLocalizedPaths('ambassadors', 'es', 'id')
}

const { slug, locale: contentLocale, isFallback } = Astro.props
---

<AmbassadorDetailPage
  slug={slug}
  contentLocale={contentLocale}
  isFallback={isFallback}
/>
