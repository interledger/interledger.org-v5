---
import GrantPage from '@/components/pages/GrantPage.astro'
import GrantOverviewPage from '@/components/pages/GrantOverviewPage.astro'
import ProfileDetailPage from '@/components/pages/ProfileDetailPage.astro'
import { getLocalizedPaths, getProfilePaths } from '@/utils'
import type { Locale } from '@/utils'

type GrantCollection = 'grant-pages' | 'grant-overview-pages' | 'profiles'

interface Props {
  slug: string
  locale: Locale
  isFallback?: boolean
  collection: GrantCollection
}

export async function getStaticPaths() {
  const [grantPaths, overviewPaths, profilePaths] = await Promise.all([
    getLocalizedPaths('grant-pages', 'es', 'page'),
    getLocalizedPaths('grant-overview-pages', 'es', 'page'),
    getProfilePaths('grant', 'es', 'page')
  ])

  const seen = new Set<string>()
  const duplicates = new Set<string>()
  for (const p of [...grantPaths, ...overviewPaths, ...profilePaths]) {
    const slug = p.params.page
    if (seen.has(slug)) duplicates.add(slug)
    else seen.add(slug)
  }
  if (duplicates.size > 0) {
    throw new Error(
      `[es/grant/[...page]] Duplicate slugs found: ${[...duplicates].join(', ')}. Each slug must be unique within /grant/.`
    )
  }

  return [
    ...grantPaths.map((p) => ({
      ...p,
      props: { ...p.props, collection: 'grant-pages' as GrantCollection }
    })),
    ...overviewPaths.map((p) => ({
      ...p,
      props: { ...p.props, collection: 'grant-overview-pages' as GrantCollection }
    })),
    ...profilePaths.map((p) => ({
      ...p,
      props: { ...p.props, collection: 'profiles' as GrantCollection }
    }))
  ]
}

const { slug, locale: contentLocale, collection } = Astro.props
---

{
  collection === 'profiles' ? (
    <ProfileDetailPage
      slug={slug}
      contentLocale={contentLocale}
      isFallback={Astro.props.isFallback}
    />
  ) : collection === 'grant-pages' ? (
    <GrantPage
      slug={slug}
      contentLocale={contentLocale}
      isFallback={Astro.props.isFallback}
    />
  ) : (
    <GrantOverviewPage
      slug={slug}
      contentLocale={contentLocale}
      isFallback={Astro.props.isFallback}
    />
  )
}
