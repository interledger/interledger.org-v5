---
import GrantPage from '@/components/pages/GrantPage.astro'
import GrantOverviewPage from '@/components/pages/GrantOverviewPage.astro'
import { getLocalizedPaths } from '@/utils'
import type { Locale } from '@/utils'

type GrantCollection = 'grant-pages' | 'grant-overview-pages'

interface Props {
  slug: string
  locale: Locale
  isFallback?: boolean
  collection: GrantCollection
}

export async function getStaticPaths() {
  const [grantPaths, overviewPaths] = await Promise.all([
    getLocalizedPaths('grant-pages', 'es', 'page'),
    getLocalizedPaths('grant-overview-pages', 'es', 'page')
  ])

  const seen = new Set<string>()
  const duplicates = new Set<string>()
  for (const p of [...grantPaths, ...overviewPaths]) {
    const slug = p.params.page
    if (seen.has(slug)) duplicates.add(slug)
    else seen.add(slug)
  }
  if (duplicates.size > 0) {
    throw new Error(
      `[es/grant/[...page]] Duplicate slugs found: ${[...duplicates].join(', ')}. Each slug must be unique within /grant/.`
    )
  }

  return [
    ...grantPaths.map((p) => ({
      ...p,
      props: { ...p.props, collection: 'grant-pages' as GrantCollection }
    })),
    ...overviewPaths.map((p) => ({
      ...p,
      props: {
        ...p.props,
        collection: 'grant-overview-pages' as GrantCollection
      }
    }))
  ]
}

const { slug, locale: contentLocale, collection } = Astro.props
---

{
  collection === 'grant-pages' ? (
    <GrantPage
      slug={slug}
      contentLocale={contentLocale}
      isFallback={Astro.props.isFallback}
    />
  ) : (
    <GrantOverviewPage
      slug={slug}
      contentLocale={contentLocale}
      isFallback={Astro.props.isFallback}
    />
  )
}
