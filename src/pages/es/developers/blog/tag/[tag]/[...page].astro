---
import type { Page, GetStaticPaths } from 'astro'
import { paginatePostsByTerm } from '@/utils'
import DevelopersBlogListingPage from '@/components/pages/DevelopersBlogListingPage.astro'

type Props = {
  page: Page
  allTerms: string[]
  selectedTerm: string
}

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const paths = await paginatePostsByTerm({
    paginate,
    collection: 'developers-blog',
    lang: 'es'
  })
  return paths
}

const { page, allTerms, selectedTerm } = Astro.props
---

<DevelopersBlogListingPage
  page={page}
  allTerms={allTerms}
  selectedTerm={selectedTerm}
/>
