---
import type { Page, GetStaticPaths } from 'astro'
import { paginatePostsByTag } from '@/utils'
import DevelopersBlogListingPage from '@/components/blog/DevelopersBlogListingPage.astro'

type Props = {
  page: Page
  allTags: string[]
  selectedTag: string
}

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const paths = await paginatePostsByTag({
    paginate,
    collection: 'developers-blog',
    lang: 'es'
  })
  return paths
}

const { page, allTags, selectedTag } = Astro.props
---

<DevelopersBlogListingPage
  page={page}
  allTags={allTags}
  selectedTag={selectedTag}
/>
