---
import { getCollection, render } from 'astro:content'
import CommunityLinksDevelopers from '@/components/blog/CommunityLinksDevelopers.astro'
import DevelopersBlogLayout from '@/layouts/DevelopersBlogLayout.astro'

export async function getStaticPaths() {
  const blogEntries = await getCollection(
    'developers-blog',
    ({ data }) => data.locale === 'es'
  )

  return blogEntries.map((entry) => ({
    params: { id: entry.data.pathSlug },
    props: { entry }
  }))
}

const { entry } = Astro.props
const { Content } = await render(entry)
---

<DevelopersBlogLayout frontmatter={entry.data}>
  <Content />
  <CommunityLinksDevelopers />
</DevelopersBlogLayout>
