---
import DevelopersBlogPostPage from '@/components/blog/DevelopersBlogPostPage.astro'
import { getLocalizedPaths } from '@/utils'

export async function getStaticPaths() {
  return getLocalizedPaths(['developers-blog'], 'es', 'id')
}

const { slug, locale: contentLocale } = Astro.props
---

<DevelopersBlogPostPage
  slug={slug}
  contentLocale={contentLocale}
  isFallback={Astro.props.isFallback}
/>
