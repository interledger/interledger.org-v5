---
import FoundationContentPage from '@/components/pages/FoundationContentPage.astro'
import { defaultLocale, type Locale, HOME_CONTENT_SLUG } from '@/utils'
import { getCollection } from 'astro:content'

const pageLang: Locale = 'es'

const pages = await getCollection('foundation-pages')
const localizedHomePage = pages.find(
  (page) =>
    page.data.pathSlug === HOME_CONTENT_SLUG && page.data.locale === pageLang
)

const contentLocale = localizedHomePage ? pageLang : defaultLocale
const isFallback = !localizedHomePage
---

<FoundationContentPage
  slug={HOME_CONTENT_SLUG}
  contentLocale={contentLocale}
  isFallback={isFallback}
/>
