---
import FoundationContentPage from '@/components/pages/FoundationContentPage.astro'
import { getLocalizedPaths } from '@/utils'

export async function getStaticPaths() {
  return getLocalizedPaths('foundation-pages', 'es', 'page')
}

const { slug, locale: contentLocale } = Astro.props
---

<FoundationContentPage
  slug={slug}
  contentLocale={contentLocale}
  isFallback={Astro.props.isFallback}
/>
