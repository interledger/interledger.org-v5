---
import SummitContentPage from '@/components/pages/SummitContentPage.astro'
import ProfileDetailPage from '@/components/pages/ProfileDetailPage.astro'
import ReportPage from '@/components/pages/ReportPage.astro'
import {
  getLocalizedPaths,
  getCrossSectionPaths,
  HOME_CONTENT_SLUG
} from '@/utils'

export async function getStaticPaths() {
  const pages = (
    await getLocalizedPaths('summit-pages', 'es', 'page', {
      excludeSlug: HOME_CONTENT_SLUG
    })
  ).map((p) => ({ ...p, props: { ...p.props, kind: 'page' as const } }))
  const crossSectionPaths = await getCrossSectionPaths('summit', 'es', 'page')
  return [...crossSectionPaths, ...pages]
}

const { slug, locale: contentLocale, kind, isFallback } = Astro.props
---

{
  kind === 'profile' ? (
    <ProfileDetailPage
      slug={slug}
      contentLocale={contentLocale}
      isFallback={isFallback}
    />
  ) : kind === 'report' ? (
    <ReportPage
      slug={slug}
      contentLocale={contentLocale}
      isFallback={isFallback}
    />
  ) : (
    <SummitContentPage
      slug={slug}
      contentLocale={contentLocale}
      isFallback={isFallback}
    />
  )
}
