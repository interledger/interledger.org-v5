---
import type { GetStaticPaths } from 'astro'
import { getSpeakerPages } from '@/utils'
import SpeakerDetailPage from '@/components/summit/SpeakerDetailPage.astro'
import type { Speaker } from '@/types/summit'
import { localizeRoute } from '@/utils/routes'

interface Props {
  entry: Speaker
}

export const getStaticPaths: GetStaticPaths = async () => {
  const entries = await getSpeakerPages()
  return entries
}

const { year } = Astro.params
const { entry } = Astro.props
const { routeLocale } = Astro.locals
if (!year) {
  throw new Error('Year param is required')
}
if (!entry) {
  return Astro.redirect(localizeRoute('/404', routeLocale))
}

const isFallback = entry.es === null
---

<SpeakerDetailPage entry={entry} year={year} isFallback={isFallback} />
