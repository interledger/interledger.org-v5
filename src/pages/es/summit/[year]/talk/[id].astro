---
import type { GetStaticPaths } from 'astro'
import { getSessionPages } from '@/utils'
import SessionDetailPage from '@/components/summit/SessionDetailPage.astro'
import type { Talk } from '@/types/summit'
import { localizeRoute } from '@/utils/routes'

interface Props {
  entry: Talk
}

export const getStaticPaths: GetStaticPaths = async () => {
  const entries = await getSessionPages()
  return entries
}

const { year } = Astro.params
const { entry } = Astro.props
const { routeLocale } = Astro.locals
if (!year) {
  throw new Error('Year param is required')
}
if (!entry) {
  return Astro.redirect(localizeRoute('/404', routeLocale))
}

const isFallback = entry.es === null
---

<SessionDetailPage entry={entry} year={year} isFallback={isFallback} />
