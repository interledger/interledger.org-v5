---
import type { GetStaticPaths } from 'astro'
import { getSessionPages } from '@/utils/summit-talks-speakers'
import SessionDetailPage from '@/components/summit/SessionDetailPage.astro'

export const getStaticPaths: GetStaticPaths = async () => {
  const entries = await getSessionPages('es')
  return entries
}

const { year } = Astro.params
const { entry } = Astro.props
---

<SessionDetailPage entry={entry} year={year} />
