---
import type { GetStaticPaths } from 'astro'
import { getSessionPages } from '@/utils/summit-talks-speakers'
import SessionDetailPage from '@/components/summit/SessionDetailPage.astro'
import type { Talk } from '@/types/summit'

interface Props {
  entry: Talk
}

const lang = 'es'
export const getStaticPaths: GetStaticPaths = async () => {
  const entries = await getSessionPages()
  return entries
}

const { year } = Astro.params
const { entry } = Astro.props
---

<SessionDetailPage entry={entry} year={year} lang={lang} />
