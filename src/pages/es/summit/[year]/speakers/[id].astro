---
import type { GetStaticPaths } from 'astro'
import { getSpeakerPages } from '@/utils'
import SpeakerDetailPage from '@/components/pages/SpeakerDetailPage.astro'
import type { Speaker } from '@/types/summit'
interface Props {
  entry: Speaker
}

export const getStaticPaths: GetStaticPaths = async () => {
  const entries = await getSpeakerPages()
  return entries
}

const { year } = Astro.params
const { entry } = Astro.props
if (!year) {
  throw new Error('Year param is required')
}
if (!entry) {
  return Astro.redirect('/404')
}

const isFallback = entry.es === null
---

<SpeakerDetailPage entry={entry} year={year} isFallback={isFallback} />
