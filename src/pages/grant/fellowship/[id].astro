---
import AmbassadorDetailPage from '@/components/pages/AmbassadorDetailPage.astro'
import { getLocalizedPaths, type Locale } from '@/utils'

interface Props {
  slug: string
  locale: Locale
  isFallback?: boolean
}

export async function getStaticPaths() {
  return getLocalizedPaths('ambassadors', 'en', 'id')
}

const { slug, locale: contentLocale } = Astro.props
---

<AmbassadorDetailPage slug={slug} contentLocale={contentLocale} />
