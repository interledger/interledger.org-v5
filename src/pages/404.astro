---
/**
 * Custom 404 page for static hosting (Netlify serves 404.html).
 */
import FoundationPageLayout from '../layouts/FoundationPageLayout.astro'
import { HOME_CONTENT_SLUG, translatePath } from '@/utils'

const { routeLocale } = Astro.locals
---

<FoundationPageLayout
  title="Page not found"
  description="The page you requested could not be found."
>
  <main class="flex-1 flex items-center justify-center py-4xl">
    <section class="text-center px-2xl">
      <h1 class="text-6xl font-semibold text-primary mb-xl">404</h1>
      <p class="text-lg text-neutral-75 mb-2xl max-w-narrow mx-auto">
        The page you requested could not be found.
      </p>
      <a
        href={translatePath('foundation-pages', routeLocale, HOME_CONTENT_SLUG)}
        class="inline-block text-primary font-medium underline hover:no-underline"
      >
        ← Back to home
      </a>
    </section>
  </main>
</FoundationPageLayout>
