{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "dist",
    "rootDir": ".",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "allowJs": true,
    "paths": {
      "@/utils": ["./src/utils/index.ts"],
      "@/utils/*": ["./src/utils/*"],
      "@/*": ["./src/*"],
      "@site/*": ["../src/*"],
      "@_sh/strapi-plugin-ckeditor": [
        "./node_modules/@_sh/strapi-plugin-ckeditor/dist/admin/src/index"
      ]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.json",
    "config/**/*.ts",
    "types/**/*.ts"
  ],
  "exclude": [
    "node_modules/**",
    "build/**",
    "dist/**",
    ".cache/**",
    ".tmp/**",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/admin/**",
    "src/plugins/**"
  ]
}
