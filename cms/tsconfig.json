{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "dist",
    "rootDir": ".",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "allowJs": true,
    "baseUrl": ".",
    "paths": {
      "@/utils": ["src/utils/index.ts"],
      "@/utils/*": ["src/utils/*"],
      "@/*": ["src/*"],
      "@site/*": ["../src/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.json",
    "config/**/*.ts",
    "types/**/*.ts"
  ],
  "exclude": ["node_modules/**", "build/**", "dist/**", ".cache/**", ".tmp/**"]
}
