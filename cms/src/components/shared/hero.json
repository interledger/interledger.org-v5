{
  "collectionName": "components_shared_heroes",
  "info": {
    "displayName": "Hero",
    "icon": "star",
    "description": "Hero section with title, description and background image"
  },
  "options": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "description": {
      "type": "text",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "backgroundImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"],
      "description": "Desktop hero image. Recommended size: 1440×600px.",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "backgroundImageMobile": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"],
      "description": "Optional mobile hero image. Recommended size: 768×480px. Falls back to desktop image when absent.",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "hero_call_to_action": {
      "type": "component",
      "component": "shared.cta-link",
      "repeatable": true,
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    }
  }
}
