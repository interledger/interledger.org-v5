{
  "collectionName": "components_blocks_image_rows",
  "info": {
    "displayName": "Image Row",
    "icon": "picture",
    "description": "Image with text content, image can be positioned left or right"
  },
  "options": {},
  "attributes": {
    "heading": {
      "type": "string",
      "required": true,
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "content": {
      "type": "customField",
      "customField": "plugin::ckeditor5.CKEditor",
      "options": {
        "preset": "defaultMarkdown"
      },
      "required": true,
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "media": {
      "type": "component",
      "component": "shared.localized-media",
      "repeatable": false,
      "required": true,
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "imagePosition": {
      "type": "enumeration",
      "enum": ["left", "right"],
      "default": "right",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "attribution": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    }
  }
}
