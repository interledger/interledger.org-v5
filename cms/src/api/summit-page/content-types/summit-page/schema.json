{
  "kind": "collectionType",
  "collectionName": "summit_pages",
  "info": {
    "singularName": "summit-page",
    "pluralName": "summit-pages",
    "displayName": "Summit Page",
    "description": "Summit pages with dark theme. Full path slug sets the URL and file location."
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "title": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "required": true
    },
    "pathSlug": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "required": true,
      "unique": true
    },
    "seo": {
      "type": "component",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "component": "shared.seo",
      "repeatable": false
    },
    "hero": {
      "type": "component",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "component": "shared.hero",
      "repeatable": false
    },
    "content": {
      "type": "dynamiczone",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "components": [
        "blocks.paragraph",
        "blocks.profile-grid",
        "blocks.blockquote",
        "blocks.cta-strip",
        "blocks.pdf-embed",
        "blocks.video-embed"
      ]
    }
  }
}
