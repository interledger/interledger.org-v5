{
  "kind": "collectionType",
  "collectionName": "grant-overview-pages",
  "info": {
    "singularName": "grant-overview-page",
    "pluralName": "grant-overview-pages",
    "displayName": "Grant Overview Page",
    "description": "Overview pages for grant categories. Path slug is relative to /grant/ — e.g. education → /grant/education. Slugs must not clash with Grant Page slugs."
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "title": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "required": true
    },
    "pathSlug": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "required": true,
      "unique": true,
      "description": "Path relative to /grant/. Example: education → /grant/education. No leading slash. Must not clash with any Grant Page slug."
    },
    "description": {
      "type": "text",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "required": true,
      "description": "Short description used for SEO and card text. Aim for 120–160 characters."
    },
    "ctaStrip": {
      "type": "component",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "component": "blocks.cta-strip",
      "repeatable": false,
      "required": true
    },
    "content": {
      "type": "dynamiczone",
      "components": [
        "blocks.paragraph",
        "blocks.split-layout",
        "blocks.blockquote",
        "blocks.callout-text",
        "blocks.video-embed",
        "blocks.image-block",
        "blocks.cta-strip",
        "blocks.cta-banner",
        "blocks.carousel"
      ],
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "followUpContent": {
      "type": "customField",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "customField": "plugin::ckeditor5.CKEditor",
      "options": {
        "preset": "defaultMarkdown"
      }
    }
  }
}
