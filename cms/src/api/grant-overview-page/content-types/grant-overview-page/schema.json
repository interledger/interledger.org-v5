{
  "kind": "collectionType",
  "collectionName": "grant-overview-pages",
  "info": {
    "singularName": "grant-overview-page",
    "pluralName": "grant-overview-pages",
    "displayName": "Grant Overview Page",
    "description": "Overview pages for grant categories. Path slug is relative to /grant/ — e.g. education → /grant/education. Slugs must not clash with Grant Page slugs."
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "title": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "required": true
    },
    "pathSlug": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "required": true,
      "unique": true
    },
    "description": {
      "type": "text",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "required": true
    },
    "ctaStrip": {
      "type": "component",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "component": "blocks.cta-strip",
      "repeatable": false,
      "required": true
    },
    "followUpContent": {
      "type": "customField",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "customField": "plugin::ckeditor5.CKEditor",
      "options": {
        "preset": "defaultMarkdown"
      }
    }
  }
}
