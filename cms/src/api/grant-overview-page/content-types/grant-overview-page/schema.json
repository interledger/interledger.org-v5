{
  "kind": "collectionType",
  "collectionName": "grant-overview-pages",
  "info": {
    "singularName": "grant-overview-page",
    "pluralName": "grant-overview-pages",
    "displayName": "Grant Overview Page",
    "description": "Overview pages for grant categories. Path slug is relative to /grants/ — e.g. our-grantmaking → /grants/our-grantmaking, education → /grants/education. Slugs must not clash with Grant Page slugs."
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "title": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "required": true
    },
    "pathSlug": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "required": true,
      "unique": true
    },
    "description": {
      "type": "text",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "required": true
    },
    "hero": {
      "type": "component",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "component": "shared.hero",
      "repeatable": false
    },
    "ctaStrip": {
      "type": "component",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "component": "blocks.cta-strip",
      "repeatable": false,
      "required": true
    },
    "content": {
      "type": "dynamiczone",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "components": [
        "blocks.paragraph",
        "blocks.split-layout",
        "blocks.blockquote",
        "blocks.callout-text",
        "blocks.video-embed",
        "blocks.image-block",
        "blocks.cta-strip",
        "blocks.carousel",
        "blocks.number-tiles",
        "blocks.title-card-grid"
      ]
    },
    "followUpContent": {
      "type": "customField",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "customField": "plugin::ckeditor5.CKEditor",
      "options": {
        "preset": "defaultMarkdown"
      }
    }
  }
}
