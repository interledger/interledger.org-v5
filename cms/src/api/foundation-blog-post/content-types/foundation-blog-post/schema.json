{
  "kind": "collectionType",
  "collectionName": "foundation_blog_posts",
  "info": {
    "singularName": "foundation-blog-post",
    "pluralName": "foundation-blog-posts",
    "displayName": "Foundation Blog Post",
    "description": "Foundation blog posts (grants, policy, announcements) with distinct styling from Tech Blog"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "title": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "maxLength": 255,
      "required": true
    },
    "pathSlug": {
      "type": "uid",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "targetField": "title",
      "required": true,
      "description": "Path relative to /blog/. Example: my-article-title → /blog/my-article-title. Do not include /blog/ or a leading slash."
    },
    "date": {
      "type": "date",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "required": true
    },
    "pillar": {
      "type": "enumeration",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "required": true,
      "enum": [
        "vision",
        "mission",
        "tech",
        "values"
      ]
    },
    "featureImage": {
      "type": "media",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images"
      ]
    },
    "thumbnailImage": {
      "type": "media",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "description": {
      "type": "text",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "required": true
    },
    "content": {
      "type": "dynamiczone",
      "components": ["blocks.paragraph", "blocks.video-embed"],
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "articleBio": {
      "type": "component",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "component": "shared.article-bio",
      "repeatable": true
    },
    "tags": {
      "type": "component",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "component": "shared.tags",
      "repeatable": true
    }
  }
}
