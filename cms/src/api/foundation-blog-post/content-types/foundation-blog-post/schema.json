{
  "kind": "collectionType",
  "collectionName": "foundation_blog_posts",
  "info": {
    "singularName": "foundation-blog-post",
    "pluralName": "foundation-blog-posts",
    "displayName": "Blog post",
    "description": "Blog posts (grants, policy, announcements, technology)"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "title": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "maxLength": 255,
      "required": true
    },
    "pathSlug": {
      "type": "uid",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "targetField": "title",
      "required": true,
      "description": "Path relative to /blog/. Example: my-article-title → /blog/my-article-title. Do not include /blog/ or a leading slash."
    },
    "date": {
      "type": "date",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "required": true
    },
    "lastUpdated": {
      "type": "date",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "required": false,
      "description": "Only fill in this field when the post has had a meaningful editorial update (revised text, new sections, or corrected facts)."
    },
    "featured": {
      "type": "boolean",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "required": true,
      "default": false,
      "description": "Check to pin this post as a featured article. Up to three featured posts appear in the section at the top of the blog listing page."
    },
    "featureImage": {
      "type": "media",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "images"
      ],
      "description": "Desktop feature image (required). Dimensions: 720 x 428. Click the edit (pencil) icon on the selected image to set Alternative text."
    },
    "featureImageMobile": {
      "type": "media",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images"
      ],
      "description": "Optional mobile feature image. Dimensions: 358 x 240. Falls back to the desktop image when empty."
    },
    "thumbnailImage": {
      "type": "media",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "multiple": false,
      "allowedTypes": [
        "images"
      ],
      "description": "Optional listing thumbnail. Dimensions: 260 x 160. Click the edit (pencil) icon on the selected image to set Alternative text."
    },
    "description": {
      "type": "text",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "required": true,
      "description": "Short description shown on listings and link previews. Aim for 120–160 characters."
    },
    "content": {
      "type": "dynamiczone",
      "components": [
        "blocks.paragraph",
        "blocks.video-embed",
        "blocks.image-block"
      ],
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "articleBio": {
      "type": "component",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "component": "shared.article-bio",
      "repeatable": true
    },
    "categories": {
      "type": "component",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "component": "shared.category",
      "repeatable": true
    },
    "relatedArticles": {
      "type": "component",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "component": "shared.related-article",
      "repeatable": true,
      "max": 3,
      "required": false,
      "description": "Add exactly 3 slugs of related blog posts to display in the \"You may also like\" section. Enter the slug only (e.g. my-related-post), not the full URL."
    },
    "legacy": {
      "type": "boolean",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "required": false,
      "default": false,
      "conditions": {
        "visible": { "==": [true, false] }
      }
    }
  }
}
