{
  "kind": "collectionType",
  "collectionName": "grant-pages",
  "info": {
    "singularName": "grant-page",
    "pluralName": "grant-pages",
    "displayName": "Grant Page",
    "description": "Individual grant program pages. Path slug is relative to /grant/ — e.g. education/on-campus → /grant/education/on-campus."
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "title": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "required": true
    },
    "pathSlug": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "required": true,
      "unique": true
    },
    "description": {
      "type": "text",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "required": true
    },
    "programOverview": {
      "type": "customField",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "customField": "plugin::ckeditor5.CKEditor",
      "options": {
        "preset": "defaultMarkdown"
      }
    },
    "primaryCta": {
      "type": "component",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "component": "shared.primary-cta-link",
      "repeatable": false
    },
    "ctaStrip": {
      "type": "component",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "component": "blocks.cta-strip",
      "repeatable": false,
      "required": true
    },
    "content": {
      "type": "dynamiczone",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "components": [
        "blocks.carousel"
      ]
    }
  }
}
